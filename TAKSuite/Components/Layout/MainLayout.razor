@inherits LayoutComponentBase

<MediaQueryList>
<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-1 d-flex justify-content-end align-items-center">
            @* <a href="https://learn.microsoft.com/aspnet/core/" target="_blank">About</a> *@

            <AuthorizeView>
                <Authorized>
                   <div class="float-end"> <div class="d-flex align-items-center">
                        <NavLink class="nav-link me-3" href="Account/Manage">
                            <span class="bi bi-person-fill" aria-hidden="true"></span> @context.User.Identity?.Name
                        </NavLink>
                        <form action="Account/Logout" method="post" class="m-0">
                            <AntiforgeryToken />
                            <input type="hidden" name="ReturnUrl" value="@currentUrl" />
                            <Button Type="ButtonType.Submit"><Icon CustomIconName="bi bi-box-arrow-right" Style="font-size: 1.5rem;" /></Button>
                            
                            @* <button type="submit" class="btn btn-link nav-link">
                                <span class="material-icons" aria-hidden="true">logout</span>
                            </button> *@
                        </form>
                            </div>
                        </div>
                </Authorized>
                <NotAuthorized>
                    <div class="d-flex">
                        <NavLink class="nav-link me-3" href="Account/Register">
                            <span class="bi bi-person" aria-hidden="true"></span> Register
                        </NavLink>
                        <NavLink class="nav-link" href="Account/Login">
                            <span class="bi bi-person-badge" aria-hidden="true"></span> Login
                        </NavLink>
                    </div>
                </NotAuthorized>
            </AuthorizeView>
                <div class="float-end">
                    <ThemeSwitcher Position="DropdownMenuPosition.End" />
                </div>

                
        </div>

        <article class="content px-4">
            @Body
        </article>


    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>
    <Toasts class="p-3" AutoHide="true" Delay="4000" StackLength="3" Placement="ToastsPlacement.BottomRight" />

</MediaQueryList>

@code {
    private string? currentUrl;

    [Inject] private NavigationManager NavigationManager { get; set; } = default!;
    [Inject] protected ToastService ToastService { get; set; } = default!;


    protected override void OnInitialized()
    {
        currentUrl = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        NavigationManager.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        currentUrl = NavigationManager.ToBaseRelativePath(e.Location);
        StateHasChanged();
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }
}