@page "/missiontak/{MissionTakId:guid}"
@attribute [Authorize]
@implements IDisposable
@using Microsoft.AspNetCore.Authorization
@using TAKSuite.Components.Pages.Components
@using TAKSuite.Components.Pages.Tasks.TaskComponents
@using TAKSuite.Data.Models
@using TAKSuite.Data.Services
@using TAKSuite.Data.ModelsTak
@using TAKSuite.Data.ServicesTak
@using TAKSuite.TAK.Helper
@using TAKSuite.TAK.CoT
@using TAKSuite.Helper
@inject MissionSuiteEntityServices entityService
@inject TaskService service
@inject NavigationManager Navigation
@inject ToastService ToastService
@inject WaypointService WaypointService
@inject AttachmentService AttachmentService
@inject CoTManager CoTManager
@inject IJSRuntime JS
@inject TAKSuite.TAK.CoT.MartiApiClient MartiClient
@inject TAKSuite.Data.Services.TakSubscriptionService SubscriptionService

<PageTitle>@missionTak?.Name</PageTitle>
@if (missionTak == null)
{
    <p>Caricamento...</p>
}
else
{
    <!-- Add POI modal -->
    <ModalAddPoi @ref="_addPoiModal"
                 MissionTakUid="@missionTak.TakMissionUid"
                 OnPoiCreated="OnPoiCreated" />

    <!-- Import from AI modal -->
    <ModalImportFromAi @ref="_importAiModal"
                       MissionTakSuiteId="@MissionTakId"
                       MissionTakUid="@missionTak.TakMissionUid"
                       OnImportCompleted="OnAiImportCompleted" />

    <!-- Allegati waypoint modal -->
    <Modal @ref="_wpAttachmentModal" Title="Allegati waypoint" Size="ModalSize.Large">
        <BodyTemplate>
            <div class="mb-3 d-flex gap-2 align-items-center">
                <InputFile OnChange="OnWpAttachFileSelected" class="form-control form-control-sm" />
                <Button Color="ButtonColor.Primary" Size="ButtonSize.Small"
                        @onclick="UploadWpAttachmentAsync"
                        Loading="_wpUploading" LoadingText="Caricamento..."
                        Disabled="@(_wpUploadFile == null || _wpUploading)">
                    <Icon Name="IconName.CloudUploadFill" /> Allega
                </Button>
            </div>
            <Grid @ref="_wpAttachGrid"
                  TItem="AtakAttachment"
                  Class="table table-hover"
                  HeaderRowCssClass="bg-success text-white border-bottom-0"
                  DataProvider="WpAttachmentDataProvider"
                  AllowFiltering="false"
                  AllowPaging="false"
                  AllowSorting="true"
                  Responsive="true">
                <GridColumns>
                    <GridColumn TItem="AtakAttachment" HeaderText="Nome" SortKeySelector="x => x.Name">
                        @context.Name
                    </GridColumn>
                    <GridColumn TItem="AtakAttachment" HeaderText="">
                        <Button Size="ButtonSize.Small" @onclick="() => ViewWpAttachment(context)">
                            @if (context.MediaType?.Contains("jpeg") == true)
                            {
                                <Icon Name="IconName.FileEarmarkImage" Color="IconColor.Primary" />
                            }
                            else if (context.MediaType?.Contains("pdf") == true)
                            {
                                <Icon Name="IconName.FileEarmarkPdfFill" Color="IconColor.Primary" />
                            }
                            else
                            {
                                <Icon Name="IconName.FileEarmarkArrowDownFill" Color="IconColor.Primary" />
                            }
                        </Button>
                        <Button Size="ButtonSize.Small" Color="ButtonColor.Danger"
                                @onclick="async () => await DeleteWpAttachmentAsync(context)">
                            <Icon Name="IconName.Trash3Fill" />
                        </Button>
                    </GridColumn>
                </GridColumns>
            </Grid>
        </BodyTemplate>
        <FooterTemplate>
            <Button Color="ButtonColor.Secondary" @onclick="() => _wpAttachmentModal.HideAsync()">Chiudi</Button>
        </FooterTemplate>
    </Modal>

    <!-- GL Modal -->
    <Modal @ref="_glModal" Title="@($"Luce Verde — {_editingGlTask?.Name}")">
        <BodyTemplate>
            <div class="d-flex gap-2 align-items-end flex-wrap">
                <div>
                    <label class="form-label small mb-1">Data/ora (ora locale)</label>
                    <input type="datetime-local" class="form-control"
                           value="@ToLocalInput(_editingGlValue)"
                           @onchange="e => _editingGlValue = ParseLocalDt(e.Value?.ToString())" />
                </div>
                <Button Color="ButtonColor.Secondary" @onclick="SetEditingGlNow">Ora</Button>
            </div>
        </BodyTemplate>
        <FooterTemplate>
            <Button Color="ButtonColor.Success" @onclick="SaveEditingGl"
                    Loading="_savingGl" LoadingText="Salvataggio...">
                <Icon Name="IconName.Save" /> Salva
            </Button>
            @if (_editingGlTask?.GreenLightDateTime.HasValue == true)
            {
                <Button Color="ButtonColor.Danger" @onclick="ClearEditingGl">
                    <Icon Name="IconName.XCircle" /> Rimuovi
                </Button>
            }
            <Button Color="ButtonColor.Secondary" @onclick='async () => await _glModal.HideAsync()'>Annulla</Button>
        </FooterTemplate>
    </Modal>

    <PageHeader Title="@missionTak.Name" Subtitle="@missionTak.Descrizione">
        <ChildContent>
            <!-- pulsanti + separatore + orologio -->
            <div class="d-flex align-items-center gap-3">
                <div class="d-flex gap-2">
                    <Dropdown Color="DropdownColor.Secondary">
                        <DropdownToggleButton>@missionTak.Status.GetDisplayName()</DropdownToggleButton>
                        <DropdownMenu Class="p-0 text-muted" Style="width: 320px;">
                            <div class="px-2 py-1 d-flex flex-column">
                                <TAKSuite.Components.Pages.Components.MissionProgress MissionEntity="missionTak" />
                            </div>
                        </DropdownMenu>
                    </Dropdown>
                    @if (missionTak.Status == MissionStatusTak.Created || missionTak.Status == MissionStatusTak.Assigned)
                    {
                        <Button Color="ButtonColor.Primary"
                                @onclick="async () => await SetStatusAsync(MissionStatusTak.InProgress)"
                                Loading="_savingStatus" LoadingText="...">
                            <Icon Name="IconName.PlayFill" /> Avvia
                        </Button>
                    }
                    @if (missionTak.Status == MissionStatusTak.InProgress)
                    {
                        <Button Color="ButtonColor.Success"
                                @onclick="async () => await SetStatusAsync(MissionStatusTak.Completed)"
                                Loading="_savingStatus" LoadingText="...">
                            <Icon Name="IconName.CheckLg" /> Concludi
                        </Button>
                    }
                    @if (missionTak.Status == MissionStatusTak.InProgress || missionTak.Status == MissionStatusTak.Completed)
                    {
                        <Button Color="ButtonColor.Secondary"
                                @onclick="async () => await SetStatusAsync(MissionStatusTak.Archived)"
                                Loading="_savingStatus" LoadingText="...">
                            <Icon Name="IconName.Archive" /> Archivia
                        </Button>
                    }
                    <Button Color="ButtonColor.Secondary" Outline="true"
                            @onclick='() => Navigation.NavigateTo($"/missionedit/{MissionTakId}")'>
                        <Icon Name="IconName.GearFill" /> Configura
                    </Button>
                </div>
                <div class="vr align-self-stretch"></div>
                <div class="text-end lh-1">
                    <div style="font-size: 1.9rem; font-weight: 700; letter-spacing: .05em; font-variant-numeric: tabular-nums;">
                        @DateTime.Now.ToString("HH:mm:ss")
                    </div>
                    <div class="text-muted" style="font-size: .75rem;">@DateTime.Now.ToString("dd/MM/yyyy")</div>
                </div>
            </div>
        </ChildContent>
    </PageHeader>
    @if (!string.IsNullOrEmpty(GetMissionCountdown()))
    {
        <div class="alert @GetMissionCountdownClass() d-flex align-items-center gap-2 mb-2 py-1">
            <Icon Name="IconName.ClockFill" />
            <strong>@GetMissionCountdown()</strong>
        </div>
    }

    <!-- Dettagli + Grafico -->
    <div class="row g-3 mb-4">
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-header fw-bold">Dettagli Missione</div>
                <ul class="list-group list-group-flush">
                    <li class="list-group-item d-flex justify-content-between">
                        <span class="text-muted">Stato</span>
                        <Badge Color="BadgeColor.Primary">@missionTak.Status.GetDisplayName()</Badge>
                    </li>
                    <li class="list-group-item d-flex justify-content-between">
                        <span class="text-muted">Team responsabile</span>
                        <span>@(missionTak.Team?.Name ?? "—")</span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between">
                        <span class="text-muted">Creata il</span>
                        <span>@ToLocalDisplay(missionTak.CreationDate)</span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between">
                        <span class="text-muted">Ultima modifica</span>
                        <span>@ToLocalDisplay(missionTak.LastModified)</span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between">
                        <span class="text-muted">Task totali</span>
                        <span class="d-flex gap-1 align-items-center">
                            <Badge Color="BadgeColor.Secondary">@_tasks.Count</Badge>
                            @if (_completedObjectives.Count > 0)
                            {
                                <Badge Color="BadgeColor.Success">@_completedObjectives.Count completati</Badge>
                            }
                        </span>
                    </li>
                    @if (!string.IsNullOrEmpty(missionTak.TakMissionUid))
                    {
                        <li class="list-group-item d-flex justify-content-between">
                            <span class="text-muted">Waypoints</span>
                            <span class="d-flex gap-1 align-items-center">
                                <Badge Color="BadgeColor.Secondary">@(_activeWaypoints.Count + _completedWaypoints.Count) totali</Badge>
                                @if (_completedWaypoints.Count > 0)
                                {
                                    <Badge Color="BadgeColor.Success">@_completedWaypoints.Count completati</Badge>
                                }
                            </span>
                        </li>
                    }
                    <li class="list-group-item d-flex justify-content-between">
                        <span class="text-muted">TAK Mission UID</span>
                        <span class="font-monospace small">@(missionTak.TakMissionUid ?? "N/D")</span>
                    </li>
                    @if (missionTak.StartDateTime.HasValue || missionTak.EndDateTime.HasValue)
                    {
                        <li class="list-group-item d-flex justify-content-between">
                            <span class="text-muted">Periodo</span>
                            <span class="text-end lh-1">
                                @if (missionTak.StartDateTime.HasValue)
                                {
                                    <span>@ToLocalDisplay(missionTak.StartDateTime.Value)</span>
                                }
                                @if (missionTak.StartDateTime.HasValue && missionTak.EndDateTime.HasValue)
                                {
                                    <span class="text-muted mx-1">→</span>
                                }
                                @if (missionTak.EndDateTime.HasValue)
                                {
                                    <span>@ToLocalDisplay(missionTak.EndDateTime.Value)</span>
                                }
                            </span>
                        </li>
                    }
                </ul>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-header fw-bold">Stato Task</div>
                <div class="card-body d-flex justify-content-center align-items-center" style="min-height:220px">
                    @if (_chartData != null)
                    {
                        <PieChart @ref="_pieChart" Width="300" />
                    }
                    else
                    {
                        <span class="text-muted">Nessun task</span>
                    }
                </div>
                @{
                    var totalItems = _tasks.Count + _activeWaypoints.Count + _completedWaypoints.Count;
                    var completedItems = _completedObjectives.Count + _completedWaypoints.Count;
                    var pct = totalItems > 0 ? (int)Math.Round(completedItems * 100.0 / totalItems) : 0;
                }
                @if (totalItems > 0)
                {
                    <div class="card-footer">
                        <div class="d-flex justify-content-between small text-muted mb-1">
                            <span>Completamento missione</span>
                            <span>@completedItems / @totalItems (@pct%)</span>
                        </div>
                        <div class="progress" style="height: 10px;">
                            <div class="progress-bar bg-success" role="progressbar"
                                 style="width: @(pct)%;"
                                 aria-valuenow="@pct" aria-valuemin="0" aria-valuemax="100"></div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Obiettivi attivi -->
    <div class="card mb-4">
        <div class="card-header fw-bold">
            Obiettivi attivi (@_activeObjectives.Count)
        </div>
        <div class="card-body p-2">
            @if (!_activeObjectives.Any())
            {
                <p class="text-muted text-center py-3 mb-0">
                    Nessun obiettivo attivo. Aggiungili dalla pagina
                    <NavLink href="@($"/missionedit/{MissionTakId}")">Configura</NavLink>.
                </p>
            }
            @for (int i = 0; i < _activeObjectives.Count; i++)
            {
                var task = _activeObjectives[i];
                var glEnd = (task.GreenLightDateTime.HasValue && task.Durata is > 0)
                    ? task.GreenLightDateTime.Value.AddMinutes(task.Durata.Value)
                    : (DateTime?)null;
                var nowUtc = DateTime.UtcNow;
                var inGlWindow = task.GreenLightDateTime.HasValue
                    && task.Durata is > 0
                    && nowUtc >= task.GreenLightDateTime.Value
                    && nowUtc < glEnd!.Value;
                var glRemaining = (inGlWindow && glEnd.HasValue) ? glEnd.Value - nowUtc : (TimeSpan?)null;

                @if (i > 0)
                {
                    var prev = _activeObjectives[i - 1];
                    if (prev.GreenLightDateTime.HasValue && task.GreenLightDateTime.HasValue)
                    {
                        var prevGlEnd = prev.Durata.HasValue
                            ? prev.GreenLightDateTime.Value.AddMinutes(prev.Durata.Value)
                            : prev.GreenLightDateTime.Value;
                        var gap = task.GreenLightDateTime.Value - prevGlEnd;
                        var timeToNext = task.GreenLightDateTime.Value - nowUtc;
                        if (gap.TotalSeconds > 0 && timeToNext.TotalSeconds > 0)
                        {
                            <div class="text-center text-muted small py-1" style="letter-spacing:.03em;">
                                <span>↕ @FormatTs(timeToNext)</span>
                            </div>
                        }
                    }
                }

                <div class="border rounded mb-1 @(inGlWindow ? "border-success border-2" : "")">
                    <div class="d-flex justify-content-between align-items-center px-3 py-2"
                         style="position: sticky; top: 0; z-index: 5; background: var(--bs-body-bg); border-radius: inherit;">
                        <div class="d-flex align-items-center gap-2 flex-wrap">
                            <NavLink href="@($"/taskdetail/{task.Id}")"
                                     class="fw-semibold text-decoration-none text-body">
                                @task.Name
                            </NavLink>
                            @if (!string.IsNullOrEmpty(task.Sottotitolo))
                            {
                                <span class="text-muted small">@task.Sottotitolo</span>
                            }
                            @if (task.Priority != null)
                            {
                                <span class="badge bg-secondary">@task.Priority.Name</span>
                            }
                            @if (inGlWindow)
                            {
                                <span class="badge bg-success px-2">
                                    IN FINESTRA
                                    @if (glRemaining.HasValue)
                                    {
                                        <span class="ms-1 fw-normal">@FormatTs(glRemaining.Value)</span>
                                    }
                                </span>
                            }
                        </div>
                        <div class="d-flex align-items-center gap-2 flex-shrink-0">
                            @if (task.Durata is > 0)
                            {
                                <span class="badge bg-secondary fw-normal" style="font-size:.75em;">@task.Durata min</span>
                            }
                            @if (task.GreenLightDateTime.HasValue)
                            {
                                <span class="text-success small fw-semibold text-end lh-1">
                                    <Icon Name="IconName.CircleFill" />
                                    @ToLocalDisplay(task.GreenLightDateTime.Value, "HH:mm")
                                    <br /><span class="text-muted fw-normal" style="font-size:.8em;">@ToLocalDisplay(task.GreenLightDateTime.Value, "dd/MM")</span>
                                </span>
                            }
                            else if (task.StartDateTime.HasValue)
                            {
                                <span class="text-muted small text-end lh-1">
                                    @ToLocalDisplay(task.StartDateTime.Value, "HH:mm")
                                    <br /><span style="font-size:.8em;">@ToLocalDisplay(task.StartDateTime.Value, "dd/MM")</span>
                                </span>
                            }
                            <Button Size="ButtonSize.Small"
                                    Color="@(task.GreenLightDateTime.HasValue ? ButtonColor.Success : ButtonColor.Secondary)"
                                    Outline="true"
                                    @onclick="() => OpenGlModal(task)">
                                <Icon Name="IconName.CircleFill" /> GL
                            </Button>
                            <NavLink class="btn btn-sm btn-outline-primary" href="@($"/taskdetail/{task.Id}")">
                                <Icon Name="IconName.Eye" />
                            </NavLink>
                        </div>
                    </div>

                    @if (_hasMissionWindow)
                    {
                        <div class="px-3 pb-2">
                            <MissionTimelineBar
                                MissionStart="missionTak.StartDateTime!.Value"
                                MissionEnd="missionTak.EndDateTime!.Value"
                                Windows="@(task.TimeWindows.Count > 0 ? task.TimeWindows : null)"
                                Durata="task.Durata"
                                TaskStart="task.StartDateTime"
                                TaskEnd="task.EndDateTime"
                                GreenLight="task.GreenLightDateTime"
                                GreenLightEnd="glEnd"
                                PlannedStart="task.PlannedStartDateTime"
                                PlannedEnd="task.PlannedEndDateTime" />
                        </div>
                    }
                </div>
            }
        </div>
    </div>

    <!-- Waypoints -->
    @if (!string.IsNullOrEmpty(missionTak.TakMissionUid))
    {
        <div class="row g-3 mb-4">
            <div class="col-md-6">
                <div class="card h-100">
                    <div class="card-header fw-bold d-flex justify-content-between align-items-center">
                        <span>Waypoints attivi (@_activeWaypoints.Count)</span>
                        <div class="d-flex gap-1">
                            <Button Size="ButtonSize.Small" Color="ButtonColor.Secondary" Outline="true"
                                    @onclick="async () => await _importAiModal.ShowAsync()">
                                <Icon Name="IconName.Stars" /> Importa da AI
                            </Button>
                            <Button Size="ButtonSize.Small" Color="ButtonColor.Primary"
                                    @onclick="async () => await _addPoiModal.ShowAsync()">
                                <Icon Name="IconName.GeoFill" /> Aggiungi POI
                            </Button>
                        </div>
                    </div>
                    <div class="card-body p-0">
                        @if (_activeWaypoints.Any())
                        {
                            <ul class="list-group list-group-flush">
                                @foreach (var wp in _activeWaypoints)
                                {
                                    <li class="list-group-item d-flex align-items-center gap-2">
                                        @if (wp.Color.HasValue)
                                        {
                                            <div style="width:14px;height:14px;border-radius:50%;background-color:@ColorConverterHelper.ArgbToHex(wp.Color.Value);border:1px solid #888;flex-shrink:0;"></div>
                                        }
                                        <span class="fw-semibold">@wp.Callsign</span>
                                        <div class="ms-auto d-flex gap-1">
                                            <Button Size="ButtonSize.Small" Color="ButtonColor.Secondary" Position="Position.Relative"
                                                    @onclick="async () => await OpenWpAttachments(wp)">
                                                <Icon Name="IconName.Paperclip" />
                                                @if (wp.AttachmentUidList.Count > 0)
                                                {
                                                    <Badge Color="BadgeColor.Danger"
                                                           Position="Position.Absolute"
                                                           Placement="BadgePlacement.TopRight"
                                                           IndicatorType="BadgeIndicatorType.RoundedPill">
                                                        @wp.AttachmentUidList.Count
                                                    </Badge>
                                                }
                                            </Button>
                                            <Button Size="ButtonSize.Small" Color="ButtonColor.Success"
                                                    @onclick="async () => await CompleteWaypointAsync(wp)">
                                                <Icon Name="IconName.CheckLg" />
                                            </Button>
                                        </div>
                                    </li>
                                }
                            </ul>
                        }
                        else
                        {
                            <div class="text-center text-muted py-3">Nessun waypoint attivo</div>
                        }
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card h-100">
                    <div class="card-header fw-bold text-muted">
                        Waypoints completati (@_completedWaypoints.Count)
                    </div>
                    <div class="card-body p-0">
                        @if (_completedWaypoints.Any())
                        {
                            <ul class="list-group list-group-flush">
                                @foreach (var wp in _completedWaypoints)
                                {
                                    <li class="list-group-item d-flex align-items-center gap-2 text-muted">
                                        <div style="width:14px;height:14px;border-radius:50%;background-color:#8c8c8c;border:1px solid #666;flex-shrink:0;"></div>
                                        <span>@wp.Callsign</span>
                                        @if (wp.AttachmentUidList.Count > 0)
                                        {
                                            <Button Size="ButtonSize.Small" Color="ButtonColor.Secondary" Position="Position.Relative"
                                                    Class="ms-auto"
                                                    @onclick="async () => await OpenWpAttachments(wp)">
                                                <Icon Name="IconName.Paperclip" />
                                                <Badge Color="BadgeColor.Danger"
                                                       Position="Position.Absolute"
                                                       Placement="BadgePlacement.TopRight"
                                                       IndicatorType="BadgeIndicatorType.RoundedPill">
                                                    @wp.AttachmentUidList.Count
                                                </Badge>
                                            </Button>
                                        }
                                    </li>
                                }
                            </ul>
                        }
                        else
                        {
                            <div class="text-center text-muted py-3">Nessun waypoint completato</div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- Obiettivi completati -->
    <div class="card">
        <div class="card-header fw-bold">Obiettivi completati (@_completedObjectives.Count)</div>
        @if (_completedObjectives.Any())
        {
            <div class="table-responsive">
                <table class="table table-sm table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Obiettivo</th>
                            <th>Stato</th>
                            <th>Team assegnato</th>
                            <th>Ultima modifica</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var task in _completedObjectives)
                        {
                            <tr>
                                <td>
                                    <NavLink href="@($"/taskdetail/{task.Id}")"
                                             class="text-decoration-none text-body fw-semibold">
                                        @task.Name
                                    </NavLink>
                                    @if (!string.IsNullOrEmpty(task.Sottotitolo))
                                    {
                                        <span class="text-muted small ms-1">@task.Sottotitolo</span>
                                    }
                                </td>
                                <td>
                                    <span class="badge @GetCompletedBadgeClass(task.Status)">
                                        @task.Status.GetDisplayName()
                                    </span>
                                </td>
                                <td>@(task.AssignedTeam?.Name ?? "—")</td>
                                <td class="text-muted small">@ToLocalDisplay(task.LastModified, "dd/MM HH:mm")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="card-body text-center text-muted">Nessun obiettivo completato.</div>
        }
    </div>
}

@code {
    [Parameter] public Guid MissionTakId { get; set; }

    private MissionSuite? missionTak;
    private List<TaskEntity> _tasks = new();

    private PieChart _pieChart = default!;
    private ChartData? _chartData;
    private PieChartOptions _chartOptions = new() { Responsive = true, Plugins = new() { Legend = new() { Position = "bottom" } } };
    private bool _chartInitialized;

    private System.Timers.Timer? _timer;

    // GL modal
    private Modal _glModal = default!;
    private TaskEntity? _editingGlTask;
    private DateTime? _editingGlValue;
    private bool _savingGl;

    private static readonly HashSet<TaskStatusTak> _completedStatuses = new()
    {
        TaskStatusTak.Completed,
        TaskStatusTak.Aborted,
        TaskStatusTak.Failed,
        TaskStatusTak.Canceled
    };

    private List<TaskEntity> _activeObjectives = new();
    private List<TaskEntity> _completedObjectives = new();
    private bool _hasMissionWindow;

    private List<Waypoint> _activeWaypoints = new();
    private List<Waypoint> _completedWaypoints = new();

    private bool _savingStatus;

    // Waypoint attachments + POI + AI import
    private Modal _wpAttachmentModal = default!;
    private Grid<AtakAttachment> _wpAttachGrid = default!;
    private ModalAddPoi _addPoiModal = default!;
    private ModalImportFromAi _importAiModal = default!;
    private string? _selectedWpUid;
    private IBrowserFile? _wpUploadFile;
    private bool _wpUploading;

    private void ComputeView()
    {
        
        _activeObjectives = _tasks
            .Where(t => !_completedStatuses.Contains(t.Status))

            // 1️⃣ Prima quelli con PlannedStartDateTime valorizzata
            .OrderBy(t => t.PlannedStartDateTime.HasValue ? 0 : 1)

            // 2️⃣ Poi per PlannedStartDateTime (fallback MaxValue)
            .ThenBy(t => t.PlannedStartDateTime ?? DateTime.MaxValue)

            // 3️⃣ Poi per GreenLightDateTime (stessa logica)
            .ThenBy(t => t.GreenLightDateTime.HasValue ? 0 : 1)
            .ThenBy(t => t.GreenLightDateTime ?? DateTime.MaxValue)

            // 4️⃣ Infine nome
            .ThenBy(t => t.Name)

            .ToList();

        _completedObjectives = _tasks
            .Where(t => _completedStatuses.Contains(t.Status))
            .OrderByDescending(t => t.LastModified)
            .ToList();
        _hasMissionWindow = missionTak?.StartDateTime.HasValue == true && missionTak.EndDateTime.HasValue;
    }

    private DateTime _lastCoTRefreshWp = DateTime.MinValue;
    private DateTime _lastCoTRefreshTasks = DateTime.MinValue;

    private Guid _loadedMissionId = Guid.Empty;

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        CoTManager.CoTMessageReceived += OnCoTMessage;
    }

    protected override async Task OnParametersSetAsync()
    {
        if (MissionTakId == _loadedMissionId) return;
        _loadedMissionId = MissionTakId;

        missionTak = null;
        _tasks = new();
        _activeObjectives = new();
        _completedObjectives = new();
        _activeWaypoints = new();
        _completedWaypoints = new();
        _chartData = null;
        _chartInitialized = false;

        missionTak = await entityService.GetAsync(MissionTakId);
        await AutoSubscribeIfNeededAsync(missionTak?.TakMissionUid);
        _tasks = await LoadData();
        ComputeView();
        BuildChartData();
        await LoadWaypointsAsync();
        StartTimerIfNeeded();
        StateHasChanged();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_chartData != null && !_chartInitialized && _pieChart is not null)
        {
            _chartInitialized = true;
            await _pieChart.InitializeAsync(_chartData, _chartOptions);
        }
    }

    // --- Timer ---

    private void StartTimerIfNeeded()
    {
        if (_timer == null)
        {
            _timer = new System.Timers.Timer(1000);
            _timer.Elapsed += async (_, _) => await InvokeAsync(StateHasChanged);
            _timer.AutoReset = true;
            _timer.Start();
        }
    }

    // --- Mission countdown ---

    private string GetMissionCountdown()
    {
        if (missionTak?.StartDateTime == null || missionTak.EndDateTime == null) return "";
        var now = DateTime.UtcNow;
        if (now < missionTak.StartDateTime.Value)
            return $"Inizio tra {FormatTs(missionTak.StartDateTime.Value - now)}";
        if (now <= missionTak.EndDateTime.Value)
            return $"Fine missione tra {FormatTs(missionTak.EndDateTime.Value - now)}";
        return "Missione terminata";
    }

    private string GetMissionCountdownClass()
    {
        if (missionTak?.StartDateTime == null || missionTak.EndDateTime == null) return "alert-secondary";
        var now = DateTime.UtcNow;
        if (now < missionTak.StartDateTime.Value) return "alert-info";
        if (now <= missionTak.EndDateTime.Value) return "alert-warning";
        return "alert-secondary";
    }

    // --- Task countdown ---

    private string GetTaskCountdownLabel(TaskEntity task)
    {
        var now = DateTime.UtcNow;
        if (task.GreenLightDateTime.HasValue)
        {
            var gs = task.GreenLightDateTime.Value;
            if (task.Durata is 0 && now >= gs) return "GL terminata";
            DateTime? ge = (task.Durata is > 0) ? gs.AddMinutes(task.Durata.Value) : null;
            if (now < gs) return $"GL tra {FormatTs(gs - now)}";
            if (ge.HasValue && now < ge.Value) return $"GL — {FormatTs(ge.Value - now)}";
            if (ge.HasValue) return "GL terminata";
            return "LUCE VERDE";
        }
        if (task.EndDateTime.HasValue)
        {
            if (now < task.EndDateTime.Value) return $"Fine tra {FormatTs(task.EndDateTime.Value - now)}";
            return "Scaduto";
        }
        return "";
    }

    private string GetTaskCountdownBadgeClass(TaskEntity task)
    {
        var now = DateTime.UtcNow;
        if (task.GreenLightDateTime.HasValue)
        {
            var gs = task.GreenLightDateTime.Value;
            if (task.Durata is 0 && now >= gs) return "bg-secondary";
            DateTime? ge = (task.Durata is > 0) ? gs.AddMinutes(task.Durata.Value) : null;
            if (ge.HasValue && now >= gs && now < ge.Value) return "bg-success";
            if (ge.HasValue && now >= ge.Value) return "bg-secondary";
            if (now >= gs) return "bg-info";
            return "bg-warning text-dark";
        }
        if (task.EndDateTime.HasValue && now >= task.EndDateTime.Value) return "bg-secondary";
        return "bg-warning text-dark";
    }

    // --- GL modal ---

    private async Task SetStatusAsync(MissionStatusTak newStatus)
    {
        if (missionTak == null) return;
        _savingStatus = true;
        try
        {
            missionTak.Status = newStatus;
            missionTak.LastModified = DateTime.UtcNow;
            if (newStatus == MissionStatusTak.InProgress && !missionTak.StartDateTime.HasValue)
                missionTak.StartDateTime = DateTime.UtcNow;
            if ((newStatus == MissionStatusTak.Completed || newStatus == MissionStatusTak.Archived)
                && !missionTak.EndDateTime.HasValue)
                missionTak.EndDateTime = DateTime.UtcNow;
            await entityService.UpdateAsync(missionTak);
            ToastService.Notify(new(ToastType.Success, "Missione", $"Stato aggiornato: {newStatus.GetDisplayName()}"));
        }
        finally { _savingStatus = false; }
    }

    private async Task OpenGlModal(TaskEntity task)
    {
        _editingGlTask = task;
        _editingGlValue = task.GreenLightDateTime;
        await _glModal.ShowAsync();
    }

    private void SetEditingGlNow() => _editingGlValue = DateTime.UtcNow;

    private async Task SaveEditingGl()
    {
        if (_editingGlTask == null) return;
        _savingGl = true;
        try
        {
            _editingGlTask.GreenLightDateTime = _editingGlValue;
            _editingGlTask.LastModified = DateTime.UtcNow;
            await service.UpdateAsync(_editingGlTask);
            _tasks = await LoadData();
            ComputeView();
            await _glModal.HideAsync();
            ToastService.Notify(new(ToastType.Success, "Task", "Luce verde aggiornata"));
        }
        finally { _savingGl = false; }
    }

    private async Task ClearEditingGl()
    {
        _editingGlValue = null;
        await SaveEditingGl();
    }

    // --- Data ---

    private async Task<List<TaskEntity>> LoadData()
    {
        var all = await service.GetAllAsync();
        return all
            .Where(t => t.MissionTAKSuiteId == MissionTakId)
            .OrderByDescending(x => x.CreationDate)
            .ToList();
    }

    // --- Helpers ---

    private static string GetCompletedBadgeClass(TaskStatusTak status) => status switch
    {
        TaskStatusTak.Completed => "bg-success",
        TaskStatusTak.Failed    => "bg-danger",
        TaskStatusTak.Aborted   => "bg-warning text-dark",
        _                       => "bg-secondary"
    };

    private static string FormatTs(TimeSpan ts)
    {
        if (ts.TotalDays >= 1) return $"{(int)ts.TotalDays}g {ts.Hours:00}h {ts.Minutes:00}m {ts.Seconds:00}s";
        if (ts.TotalHours >= 1) return $"{(int)ts.TotalHours:00}h {ts.Minutes:00}m {ts.Seconds:00}s";
        return $"{ts.Minutes:00}m {ts.Seconds:00}s";
    }

    private static string ToLocalDisplay(DateTime utc, string format = "dd/MM/yyyy HH:mm")
        => DateTime.SpecifyKind(utc, DateTimeKind.Utc).ToLocalTime().ToString(format);

    private static string ToLocalInput(DateTime? utc)
        => utc.HasValue ? DateTime.SpecifyKind(utc.Value, DateTimeKind.Utc).ToLocalTime().ToString("yyyy-MM-ddTHH:mm") : "";

    private static DateTime? ParseLocalDt(string? s)
        => string.IsNullOrWhiteSpace(s) ? null
           : DateTime.SpecifyKind(DateTime.Parse(s), DateTimeKind.Local).ToUniversalTime();

    private void BuildChartData()
    {
        if (_tasks.Count == 0) { _chartData = null; return; }
        var grouped = _tasks.GroupBy(t => t.Status).OrderBy(g => g.Key).ToList();
        var colors = new[]
        {
            "rgba(108,117,125,0.8)", "rgba(13,202,240,0.8)", "rgba(255,193,7,0.8)",
            "rgba(13,110,253,0.8)", "rgba(111,66,193,0.8)", "rgba(25,135,84,0.8)",
            "rgba(220,53,69,0.8)", "rgba(253,126,20,0.8)", "rgba(102,16,242,0.8)",
            "rgba(32,201,151,0.8)", "rgba(214,51,132,0.8)", "rgba(23,162,184,0.8)"
        };
        var dataset = new PieChartDataset
        {
            Data = grouped.Select(g => (double?)g.Count()).ToList(),
            BackgroundColor = grouped.Select((_, i) => colors[i % colors.Length]).ToList()
        };
        _chartData = new ChartData
        {
            Labels = grouped.Select(g => g.Key.GetDisplayName()).ToList(),
            Datasets = new List<IChartDataset> { dataset }
        };
    }

    private async Task CompleteWaypointAsync(Waypoint wp)
    {
        await CoTManager.ChangeCotColor(missionTak!.TakMissionUid!, wp.Uid, ATAKHelper.COLOR_WAYPOINT_COMPLETED);
        await LoadWaypointsAsync();
        StateHasChanged();
    }

    private async Task LoadWaypointsAsync()
    {
        if (string.IsNullOrEmpty(missionTak?.TakMissionUid)) return;
        try
        {
            var wps = await WaypointService.GetAllWaypointsAsync(missionTak.TakMissionUid);
            _activeWaypoints = wps
                .Where(w => w.Color != ATAKHelper.COLOR_WAYPOINT_COMPLETED)
                .OrderBy(w => w.Callsign)
                .ThenBy(w => w.Color)
                .ToList();
            _completedWaypoints = wps
                .Where(w => w.Color == ATAKHelper.COLOR_WAYPOINT_COMPLETED)
                .OrderBy(w => w.Callsign)
                .ToList();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Errore caricamento waypoints: {ex.Message}");
        }
    }

    private async Task OnPoiCreated(ModalAddPoi.PoiResult result)
    {
        await LoadWaypointsAsync();
        StateHasChanged();
    }

    private async Task OnAiImportCompleted(ModalImportFromAi.ImportResult result)
    {
        if (result.WpCount > 0)
            await LoadWaypointsAsync();
        if (result.ObjCount > 0)
        {
            _tasks = await LoadData();
            ComputeView();
            BuildChartData();
        }
        if (result.WpCount > 0 || result.ObjCount > 0)
        {
            ToastService.Notify(new(ToastType.Success, "Importazione AI",
                $"{result.WpCount} WP e {result.ObjCount} obiettivi importati."));
        }
        StateHasChanged();
    }

    private async Task OpenWpAttachments(Waypoint wp)
    {
        _selectedWpUid = wp.Uid;
        _wpUploadFile = null;
        await _wpAttachmentModal.ShowAsync();
    }

    private void OnWpAttachFileSelected(InputFileChangeEventArgs e) => _wpUploadFile = e.File;

    private async Task UploadWpAttachmentAsync()
    {
        if (_wpUploadFile == null || string.IsNullOrEmpty(_selectedWpUid) || string.IsNullOrEmpty(missionTak?.TakMissionUid)) return;
        _wpUploading = true;
        try
        {
            using var ms = new System.IO.MemoryStream();
            await _wpUploadFile.OpenReadStream(maxAllowedSize: 20 * 1024 * 1024).CopyToAsync(ms);
            var ok = await AttachmentService.UploadAndAttachAsync(
                missionTak.TakMissionUid, _selectedWpUid,
                ms.ToArray(), _wpUploadFile.Name,
                string.IsNullOrEmpty(_wpUploadFile.ContentType) ? "application/octet-stream" : _wpUploadFile.ContentType);
            if (ok)
            {
                ToastService.Notify(new(ToastType.Success, "Allegato", "File allegato con successo."));
                _wpUploadFile = null;
                await _wpAttachGrid.RefreshDataAsync();
            }
            else
            {
                ToastService.Notify(new(ToastType.Danger, "Errore", "Impossibile allegare il file."));
            }
        }
        finally { _wpUploading = false; }
    }

    private async Task DeleteWpAttachmentAsync(AtakAttachment attach)
    {
        if (string.IsNullOrEmpty(missionTak?.TakMissionUid)) return;
        var ok = await AttachmentService.DeleteAsync(missionTak.TakMissionUid, attach);
        if (ok)
        {
            ToastService.Notify(new(ToastType.Success, "Allegato", "Allegato rimosso."));
            await _wpAttachGrid.RefreshDataAsync();
        }
        else
        {
            ToastService.Notify(new(ToastType.Danger, "Errore", "Impossibile rimuovere l'allegato."));
        }
    }

    private async Task<GridDataProviderResult<AtakAttachment>> WpAttachmentDataProvider(GridDataProviderRequest<AtakAttachment> request)
    {
        var list = string.IsNullOrEmpty(_selectedWpUid)
            ? new List<AtakAttachment>()
            : await AttachmentService.GetAllAsync(_selectedWpUid);
        return request.ApplyTo(list);
    }

    private async Task ViewWpAttachment(AtakAttachment attach)
    {
        if (attach.FileBytes == null) return;
        var base64 = Convert.ToBase64String(attach.FileBytes);
        var mediaType = attach.MediaType ?? "application/octet-stream";
        await JS.InvokeVoidAsync("viewFile", base64, mediaType);
    }

    private void OnCoTMessage(CoTManager.CoTMessageEventArgs e)
    {
        try
        {
            var doc = System.Xml.Linq.XDocument.Parse(e.Message);
            var type = (string?)doc.Root?.Attribute("type") ?? "";

            if (type.StartsWith("b-m-"))
            {
                if (DateTime.UtcNow - _lastCoTRefreshWp < TimeSpan.FromSeconds(2)) return;
                _lastCoTRefreshWp = DateTime.UtcNow;
                _ = InvokeAsync(async () =>
                {
                    await LoadWaypointsAsync();
                    StateHasChanged();
                });
            }
            else if (type.StartsWith("t-x-m-"))
            {
                if (DateTime.UtcNow - _lastCoTRefreshTasks < TimeSpan.FromSeconds(3)) return;
                _lastCoTRefreshTasks = DateTime.UtcNow;
                _ = InvokeAsync(async () =>
                {
                    _tasks = await LoadData();
                    ComputeView();
                    BuildChartData();
                    await LoadWaypointsAsync();
                    StateHasChanged();
                });
            }
        }
        catch { }
    }

    private async Task AutoSubscribeIfNeededAsync(string? takMissionUid)
    {
        if (string.IsNullOrEmpty(takMissionUid)) return;
        if (await SubscriptionService.IsSubscribedAsync(takMissionUid)) return;
        try
        {
            await MartiClient.SubscribeMissionAsync(takMissionUid);
            await SubscriptionService.AddAsync(takMissionUid);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[AutoSubscribe] {takMissionUid}: {ex.Message}");
        }
    }

    public void Dispose()
    {
        CoTManager.CoTMessageReceived -= OnCoTMessage;
        _timer?.Stop();
        _timer?.Dispose();
    }
}
