@code {
    private List<Medevac> list = null;
    Grid<Medevac> grid = default!;


    private async Task<GridDataProviderResult<Medevac>> RequestDataProvider(GridDataProviderRequest<Medevac> request)
    {
        list = await MedevacService.GetAllAsync("TEST FEED2");
        return await Task.FromResult(request.ApplyTo(list));
    }

    private Task OnSelectedItemsChanged(HashSet<Medevac> codes)
    {
        var selecteCodes = codes is not null && codes.Any() ? codes : new();
        return Task.CompletedTask;
    }

    private async Task CompleteWaypoint(Medevac item)
    {
        bool res = await CoTManager.DeleteMissionUidAsync("TEST FEED2", item.Uid);
        await grid.RefreshDataAsync();
        StateHasChanged();
    }



    protected override async Task OnInitializedAsync()
    { 
        // var user = await UserManager.GetUserAsync(User);
        // var teamColor = user?.Team?.Color ?? "black"; // Usa un colore di default se non esiste

        // list = await MedevacService.GetAllAsync("TEST FEED2");
        CoTManager.CoTMessageReceived += MessageProcessing; 
        StateHasChanged();


    }

    private void MessageProcessing(CoTManager.CoTMessageEventArgs e)
    {
        if (e.Message.Contains("b-r-f-h-c"))
            grid.RefreshDataAsync();
    }


    public void Dispose()
    {
        CoTManager.CoTMessageReceived -= MessageProcessing;
    }

    protected override void OnInitialized()
    {
    }

}