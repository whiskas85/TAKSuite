@inherits LayoutComponentBase
@inject NavigationManager NavigationManager
@implements IDisposable

<MediaQueryList>
    <div class="page">
        <AuthorizeView>
            <Authorized>
                @if (_mobileSidebarOpen)
                {
                    <div class="mobile-sidebar-overlay" @onclick="CloseSidebar"></div>
                }
                <div class="sidebar @(_mobileSidebarOpen ? "mobile-sidebar-open" : "")">
                    <NavMenu />
                </div>
            </Authorized>
        </AuthorizeView>

        <main>
            <AuthorizeView>
                <Authorized>
                    <div class="mobile-topbar">
                        <button type="button" class="mobile-topbar-hamburger" @onclick="ToggleSidebar">
                            @if (_mobileSidebarOpen)
                            {<span class="bi bi-x-lg"></span>}
                            else
                            {<span class="bi bi-list"></span>}
                        </button>
                        <span class="mobile-topbar-title">TAK Suite</span>
                    </div>
                </Authorized>
                <NotAuthorized>
                    <div class="guest-topbar d-flex align-items-center justify-content-between px-3 py-2 border-bottom">
                        <div class="d-flex align-items-center">
                            <img src="images/tak trasp.png" alt="TAK Logo" style="height: 32px;" class="me-2" />
                            <span class="fw-bold">TAK Suite</span>
                        </div>
                        <div class="d-flex gap-2">
                            <NavLink class="nav-link" href="Account/Register">
                                <span class="bi bi-person" aria-hidden="true"></span> Register
                            </NavLink>
                            <NavLink class="nav-link" href="Account/Login">
                                <span class="bi bi-person-badge" aria-hidden="true"></span> Login
                            </NavLink>
                        </div>
                    </div>
                </NotAuthorized>
            </AuthorizeView>

            <article class="content px-4">
                @Body
            </article>
        </main>
    </div>

    <div id="blazor-error-ui" data-nosnippet>
        An unhandled error has occurred.
        <a href="." class="reload">Reload</a>
        <span class="dismiss">🗙</span>
    </div>

    <Toasts class="p-3" AutoHide="true" Delay="4000" StackLength="3" Placement="ToastsPlacement.BottomRight" />

    <AuthorizeView>
        <Authorized>
            <AiChatPanel @ref="_aiPanel" />
            <ClientsPanel @ref="_clientsPanel" />
            <button class="ai-fab" @onclick="OpenAiPanel" title="TAKSuite AI">
                <span class="bi bi-robot"></span>
            </button>
            <button class="clients-fab" @onclick="OpenClientsPanel" title="Client connessi">
                <span class="bi bi-people-fill"></span>
            </button>
        </Authorized>
    </AuthorizeView>
</MediaQueryList>

@code {
    [Inject] protected ToastService ToastService { get; set; } = default!;

    private AiChatPanel _aiPanel = default!;
    private ClientsPanel _clientsPanel = default!;
    private bool _mobileSidebarOpen;

    private async Task OpenAiPanel() => await _aiPanel.OpenAsync();
    private async Task OpenClientsPanel() => await _clientsPanel.OpenAsync();

    private void ToggleSidebar() => _mobileSidebarOpen = !_mobileSidebarOpen;
    private void CloseSidebar()  => _mobileSidebarOpen = false;

    protected override void OnInitialized()
    {
        NavigationManager.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        _mobileSidebarOpen = false;
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }
}
