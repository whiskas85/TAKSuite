@page "/settings/tak"
@attribute [Authorize]
@rendermode InteractiveServer
@implements IDisposable

@using Microsoft.AspNetCore.Authorization
@using System.Net.Http.Headers
@using System.Security.Cryptography
@using System.Text
@using System.Text.Json.Nodes
@using System.Xml.Linq
@using TAKSuite.Data.Models
@using TAKSuite.Data.Services
@using TAKSuite.TAK
@using TAKSuite.TAK.Helper
@using TakLib

@inject TakSettingsService SettingsService
@inject TakClientProvider TakProvider
@inject CoTApiClient CotClient
@inject IJSRuntime JS

<PageTitle>Connessione TAK</PageTitle>

<PageHeader Title="Connessione TAK Server" TitleIcon="IconName.ShieldLockFill">
    <ChildContent>
        <Button Color="ButtonColor.Primary" @onclick="SaveAsync" Loading="_saving" LoadingText="Salvataggio...">
            <Icon Name="IconName.Save" /> Salva
        </Button>
        <Button Color="ButtonColor.Warning" @onclick="ApplyAndReconnectAsync" Loading="_reconnecting" LoadingText="Riconnessione...">
            <Icon Name="IconName.ArrowRepeat" /> Applica e Riconnetti
        </Button>
    </ChildContent>
</PageHeader>

<div class="container-fluid">

    @if (_errorMessage != null)
    {
        <Alert Color="AlertColor.Danger" Dismissable="true">@_errorMessage</Alert>
    }
    @if (_successMessage != null)
    {
        <Alert Color="AlertColor.Success" Dismissable="true">@_successMessage</Alert>
    }

    <div class="row g-4">

        @* ── Connessione ──────────────────────────────────────────────────────── *@
        <div class="col-12 col-lg-6">
            <div class="card h-100">
                <div class="card-header"><Icon Name="IconName.Wifi" /> Connessione</div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label">TAK Server IP</label>
                        <input class="form-control" @bind="_settings.TakServerIp" placeholder="10.147.19.5" />
                    </div>
                    <div class="row g-2">
                        <div class="col-4">
                            <label class="form-label">HTTPS Port</label>
                            <input type="number" class="form-control" @bind="_settings.HttpsPort" />
                        </div>
                        <div class="col-4">
                            <label class="form-label">Streaming Port</label>
                            <input type="number" class="form-control" @bind="_settings.StreamingPort" />
                        </div>
                        <div class="col-4">
                            <label class="form-label">Enrollment Port</label>
                            <input type="number" class="form-control" @bind="_settings.EnrollmentPort" />
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @* ── Identità ─────────────────────────────────────────────────────────── *@
        <div class="col-12 col-lg-6">
            <div class="card h-100">
                <div class="card-header"><Icon Name="IconName.PersonBadge" /> Identità</div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label">Callsign</label>
                        <input class="form-control" @bind="_settings.Callsign" placeholder="TAKSuiteServer" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Client UID</label>
                        <input class="form-control" @bind="_settings.ClientUid" placeholder="TAKSUITE-SERVER" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Ruolo</label>
                        <select class="form-select" @bind="_settings.Role">
                            @foreach (var r in Roles)
                            {
                                <option value="@r.Value" title="@r.Note">@r.Label@(string.IsNullOrEmpty(r.Note) ? "" : $" — {r.Note}")</option>
                            }
                        </select>
                    </div>
                    <div class="mb-1">
                        <label class="form-label">Colore ATAK</label>
                        <div class="d-flex flex-wrap gap-2">
                            @foreach (var c in AtakColors)
                            {
                                var isSelected = string.Equals(_settings.Color, c.Name, StringComparison.OrdinalIgnoreCase);
                                var checkColor = c.IsDark ? "#fff" : "#000";
                                <button type="button"
                                        class="color-swatch @(isSelected ? "color-swatch--selected" : "")"
                                        style="background-color:@c.Hex"
                                        title="@c.Name"
                                        @onclick="() => _settings.Color = c.Name">
                                    @if (isSelected)
                                    {
                                        <Icon Name="IconName.CheckLg" style="@($"color:{checkColor}")" />
                                    }
                                </button>
                            }
                        </div>
                        @if (!string.IsNullOrEmpty(_settings.Color))
                        {
                            <div class="mt-1 small text-muted">Selezionato: <strong>@_settings.Color</strong></div>
                        }
                    </div>
                </div>
            </div>
        </div>

        @* ── Posizione ────────────────────────────────────────────────────────── *@
        <div class="col-12">
            <div class="card">
                <div class="card-header"><Icon Name="IconName.GeoAltFill" /> Posizione</div>
                <div class="card-body">
                    <div class="row g-3 align-items-start">

                        <div class="col-12 col-md-5">
                            <label class="form-label">Inserisci coordinata</label>
                            <div class="input-group mb-2">
                                <input class="form-control"
                                       @bind="_coordInput"
                                       @bind:event="oninput"
                                       placeholder="32T 371610 4993569 · 45.12,8.45 · URL Google Maps" />
                                <button class="btn btn-outline-primary" type="button" @onclick="ParseCoordInputAsync">
                                    <Icon Name="IconName.GeoAltFill" /> Imposta
                                </button>
                            </div>
                            <div class="form-text text-muted small mb-3">
                                Formati supportati: UTM (32T 371610 4993569), WGS84 decimale (45.12, 8.45), URL Google Maps
                            </div>

                            @if (_settings.Latitude.HasValue && _settings.Longitude.HasValue)
                            {
                                var lat = _settings.Latitude.Value;
                                var lon = _settings.Longitude.Value;
                                var utm = FormatUtm(lat, lon);
                                <div class="p-2 rounded border mb-2 small">
                                    <div class="d-flex gap-2 align-items-center mb-1">
                                        <Icon Name="IconName.GeoAltFill" class="text-primary" />
                                        <strong>UTM:</strong> <span class="font-monospace">@utm</span>
                                    </div>
                                    <div class="d-flex gap-2 align-items-center">
                                        <Icon Name="IconName.Globe" class="text-secondary" />
                                        <strong>WGS84:</strong> <span class="font-monospace">@lat.ToString("F6"), @lon.ToString("F6")</span>
                                    </div>
                                </div>
                                <button class="btn btn-sm btn-outline-danger" @onclick="ClearPosition">
                                    <Icon Name="IconName.Trash" /> Rimuovi posizione
                                </button>
                            }
                            else
                            {
                                <div class="text-muted small fst-italic">Nessuna posizione impostata.</div>
                            }
                        </div>

                        <div class="col-12 col-md-7">
                            <label class="form-label">Seleziona dalla mappa <span class="text-muted small">(click per posizionare)</span></label>
                            <div id="coord-picker-map" style="height:280px;border-radius:.5rem;border:1px solid var(--bs-border-color)"></div>
                        </div>

                    </div>
                </div>
            </div>
        </div>

        @* ── Certificato ──────────────────────────────────────────────────────── *@
        <div class="col-12 col-lg-6">
            <div class="card">
                <div class="card-header"><Icon Name="IconName.PatchCheckFill" /> Certificato</div>
                <div class="card-body">
                    <div class="mb-3">
                        <div class="d-flex align-items-center gap-2 mb-2">
                            <span>Stato:</span>
                            @if (_settings.HasCertificate)
                            {
                                <Badge Color="BadgeColor.Success"><Icon Name="IconName.CheckCircleFill" /> Certificato presente</Badge>
                            }
                            else
                            {
                                <Badge Color="BadgeColor.Danger"><Icon Name="IconName.XCircleFill" /> Nessun certificato</Badge>
                            }
                        </div>
                        <div class="text-muted small">
                            Ultimo aggiornamento: @_settings.LastModified.ToString("dd/MM/yyyy HH:mm") UTC
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Password Certificato (P12)</label>
                        <input type="password" class="form-control" @bind="_settings.CertificatePassword" placeholder="atakatak" />
                    </div>
                    <div>
                        <label class="form-label">Carica P12 esistente</label>
                        <InputFile class="form-control" OnChange="OnP12UploadAsync" accept=".p12,.pfx" />
                        @if (_uploadedBytes != null)
                        {
                            <div class="text-success small mt-1">
                                <Icon Name="IconName.CheckCircle" /> File caricato (@_uploadedBytes.Length bytes). Salva per applicare.
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        @* ── Cache protobuf ───────────────────────────────────────────────────── *@
        <div class="col-12 col-lg-6">
            <div class="card">
                <div class="card-header"><Icon Name="IconName.DatabaseFillCheck" /> Cache punti protobuf</div>
                <div class="card-body">
                    <p class="text-muted small">
                        Punti SA ricevuti via UDP multicast (protobuf, porta 6969) da dispositivi non connessi al server.
                        La cache è persistente e sopravvive ai riavvii.
                    </p>
                    <div class="row g-3">
                        <div class="col-6">
                            <label class="form-label">
                                Stale time <span class="text-muted small">(min)</span>
                                <span class="ms-1" title="Dopo quanto tempo un punto non aggiornato viene considerato stale (grigio sulla mappa)">
                                    <Icon Name="IconName.QuestionCircle" style="font-size:.85rem;" />
                                </span>
                            </label>
                            <input type="number" class="form-control" min="1" max="1440"
                                   @bind="_settings.ProtoStaleMinutes" />
                            <div class="form-text">Default: 10 min</div>
                        </div>
                        <div class="col-6">
                            <label class="form-label">
                                Delete time <span class="text-muted small">(min)</span>
                                <span class="ms-1" title="Dopo quanto tempo il punto viene rimosso dalla cache e dal DB">
                                    <Icon Name="IconName.QuestionCircle" style="font-size:.85rem;" />
                                </span>
                            </label>
                            <input type="number" class="form-control" min="1" max="10080"
                                   @bind="_settings.ProtoDeleteMinutes" />
                            <div class="form-text">Default: 30 min</div>
                        </div>
                    </div>
                    @if (_settings.ProtoStaleMinutes >= _settings.ProtoDeleteMinutes)
                    {
                        <div class="alert alert-warning mt-2 mb-0 py-1 small">
                            Lo stale time deve essere inferiore al delete time.
                        </div>
                    }
                </div>
            </div>
        </div>

        @* ── Enrollment ───────────────────────────────────────────────────────── *@
        <div class="col-12 col-lg-6">
            <div class="card">
                <div class="card-header"><Icon Name="IconName.KeyFill" /> Enrollment (CSR)</div>
                <div class="card-body">
                    <p class="text-muted small">
                        Genera un certificato client firmato dal server TAK tramite CSR.
                        La chiave privata non lascia mai il server.
                    </p>
                    <div class="mb-3">
                        <label class="form-label">Utente Enrollment</label>
                        <input class="form-control" @bind="_settings.EnrollUser" placeholder="webadmin" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Password Enrollment</label>
                        <input type="password" class="form-control" @bind="_settings.EnrollPassword" placeholder="password" />
                    </div>
                    <Button Color="ButtonColor.Success" @onclick="EnrollAsync" Loading="_enrolling" LoadingText="Enrollment in corso...">
                        <Icon Name="IconName.KeyFill" /> Enroll via CSR
                    </Button>

                    @if (_enrollLog.Count > 0)
                    {
                        <div class="mt-3 p-2 bg-dark rounded small font-monospace" style="max-height:150px;overflow-y:auto;">
                            @foreach (var line in _enrollLog)
                            {
                                <div>@line</div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>

    </div>
</div>

@* Stili inline per i swatches colore *@
<style>
    .color-swatch {
        width: 36px;
        height: 36px;
        border-radius: 6px;
        border: 2px solid transparent;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: transform .1s, border-color .1s;
        padding: 0;
    }
    .color-swatch:hover { transform: scale(1.15); }
    .color-swatch--selected { border-color: var(--bs-body-color) !important; transform: scale(1.15); }
</style>

@code {
    // ── Dati ─────────────────────────────────────────────────────────────────────

    private TakSettings _settings = new();
    private bool _saving, _reconnecting, _enrolling;
    private string? _errorMessage, _successMessage;
    private byte[]? _uploadedBytes;
    private List<string> _enrollLog = new();

    // Coordinate picker
    private string _coordInput = "";
    private DotNetObjectReference<TakConnectionPage>? _mapRef;
    private bool _mapInitialized;

    // ── Lookup table: ruoli ───────────────────────────────────────────────────────

    private static readonly (string Value, string Label, string Note)[] Roles =
    {
        ("Team Member",      "Team Member",      "Default — operatore generico"),
        ("Team Lead",        "Team Lead",        "Capo squadra"),
        ("HQ",               "HQ",               "Quartier generale"),
        ("Sniper",           "Sniper",           ""),
        ("Medic",            "Medic",            ""),
        ("Forward Observer", "Forward Observer", "Osservatore avanzato"),
        ("RTO",              "RTO",              "Radio Telephone Operator"),
        ("K9",               "K9",               "Unità cinofila"),
        ("JTAC",             "JTAC",             "Joint Terminal Attack Controller"),
        ("XO",               "XO",              "Executive Officer"),
        ("Instructor",       "Instructor",       ""),
        ("Safety Officer",   "Safety Officer",   ""),
    };

    // ── Lookup table: colori ATAK ─────────────────────────────────────────────────

    private static readonly (string Name, string Hex, bool IsDark)[] AtakColors =
    {
        ("White",      "#e0e0e0", false),
        ("Yellow",     "#ffc107", false),
        ("Orange",     "#fd7e14", false),
        ("Maroon",     "#800000", true),
        ("Red",        "#dc3545", true),
        ("Purple",     "#9b59b6", true),
        ("Dark Blue",  "#003087", true),
        ("Blue",       "#0d6efd", true),
        ("Cyan",       "#00bcd4", false),
        ("Teal",       "#008080", true),
        ("Green",      "#198754", true),
        ("Dark Green", "#1a5c2a", true),
        ("Brown",      "#795548", true),
        ("Magenta",    "#e91e96", true),
    };

    // ── Lifecycle ─────────────────────────────────────────────────────────────────

    protected override async Task OnInitializedAsync()
    {
        _settings = await SettingsService.GetOrCreateAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_mapInitialized)
        {
            _mapInitialized = true;
            _mapRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("coordPicker.init",
                "coord-picker-map",
                _settings.Latitude,
                _settings.Longitude,
                _mapRef);
        }
    }

    public void Dispose()
    {
        _mapRef?.Dispose();
        _ = JS.InvokeVoidAsync("coordPicker.dispose");
    }

    // ── Coordinate picker ─────────────────────────────────────────────────────────

    [JSInvokable]
    public async Task OnMapClick(double lat, double lon)
    {
        _settings.Latitude  = Math.Round(lat, 6);
        _settings.Longitude = Math.Round(lon, 6);
        await InvokeAsync(StateHasChanged);
    }

    private async Task ParseCoordInputAsync()
    {
        if (string.IsNullOrWhiteSpace(_coordInput)) return;

        double lat, lon;
        bool ok = TryParseGoogleMapsUrl(_coordInput, out lat, out lon)
               || GeoUtils.TryParseCoordinate(_coordInput, out lat, out lon);

        if (ok)
        {
            _settings.Latitude  = Math.Round(lat, 6);
            _settings.Longitude = Math.Round(lon, 6);
            _coordInput = "";
            _errorMessage = null;
            await JS.InvokeVoidAsync("coordPicker.setMarker", lat, lon);
        }
        else
        {
            _errorMessage = "Formato non riconosciuto. Usa: UTM (32T 371610 4993569), WGS84 (45.12, 8.45) o URL Google Maps.";
        }
    }

    private void ClearPosition()
    {
        _settings.Latitude  = null;
        _settings.Longitude = null;
    }

    private static bool TryParseGoogleMapsUrl(string url, out double lat, out double lon)
    {
        lat = 0; lon = 0;
        if (!url.Contains("google.com/maps", StringComparison.OrdinalIgnoreCase)) return false;

        // https://www.google.com/maps/@lat,lon,zoom  or  .../place/.../@lat,lon,zoom
        var atIdx = url.LastIndexOf('@');
        if (atIdx >= 0)
        {
            var after = url[(atIdx + 1)..];
            var parts = after.Split(',');
            if (parts.Length >= 2
                && double.TryParse(parts[0], System.Globalization.NumberStyles.Float, System.Globalization.CultureInfo.InvariantCulture, out lat)
                && double.TryParse(parts[1], System.Globalization.NumberStyles.Float, System.Globalization.CultureInfo.InvariantCulture, out lon)
                && lat is >= -90 and <= 90 && lon is >= -180 and <= 180)
                return true;
        }

        // https://maps.google.com/maps?q=lat,lon
        var qIdx = url.IndexOf("q=", StringComparison.OrdinalIgnoreCase);
        if (qIdx >= 0)
        {
            qIdx += 2;
            var qEnd = url.IndexOf('&', qIdx);
            var qVal = qEnd < 0 ? url[qIdx..] : url[qIdx..qEnd];
            var parts = qVal.Split(',');
            if (parts.Length >= 2
                && double.TryParse(parts[0], System.Globalization.NumberStyles.Float, System.Globalization.CultureInfo.InvariantCulture, out lat)
                && double.TryParse(parts[1], System.Globalization.NumberStyles.Float, System.Globalization.CultureInfo.InvariantCulture, out lon)
                && lat is >= -90 and <= 90 && lon is >= -180 and <= 180)
                return true;
        }

        return false;
    }

    private static string FormatUtm(double lat, double lon)
    {
        var (zone, band, e, n) = GeoUtils.LatLonToUtm(lat, lon);
        return $"{zone}{band} {(int)e} {(int)n}";
    }

    // ── Save / Reconnect ──────────────────────────────────────────────────────────

    private async Task SaveAsync()
    {
        _saving = true;
        _errorMessage = null;
        _successMessage = null;
        try
        {
            if (_uploadedBytes != null)
                _settings.CertificateP12 = _uploadedBytes;

            await SettingsService.SaveAsync(_settings);
            await TakProvider.ReconfigureAsync(_settings);
            await CotClient.SendSaAsync();
            _uploadedBytes = null;
            _successMessage = "Impostazioni salvate.";
            _settings = await SettingsService.GetOrCreateAsync();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Errore salvataggio: {ex.Message}";
        }
        finally { _saving = false; }
    }

    private async Task ApplyAndReconnectAsync()
    {
        _reconnecting = true;
        _errorMessage = null;
        _successMessage = null;
        try
        {
            if (_uploadedBytes != null)
                _settings.CertificateP12 = _uploadedBytes;

            await SettingsService.SaveAsync(_settings);
            await TakProvider.ReconfigureAsync(_settings);
            await CotClient.SendSaAsync();
            _uploadedBytes = null;
            _successMessage = "Impostazioni applicate. TakClient riconfigurato.";
            _settings = await SettingsService.GetOrCreateAsync();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Errore riconfigurazione: {ex.Message}";
        }
        finally { _reconnecting = false; }
    }

    // ── Upload P12 ────────────────────────────────────────────────────────────────

    private async Task OnP12UploadAsync(InputFileChangeEventArgs e)
    {
        try
        {
            using var ms = new MemoryStream();
            await e.File.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024).CopyToAsync(ms);
            _uploadedBytes = ms.ToArray();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Errore lettura file: {ex.Message}";
        }
    }

    // ── Enrollment ────────────────────────────────────────────────────────────────

    private async Task EnrollAsync()
    {
        _enrolling = true;
        _enrollLog.Clear();
        _errorMessage = null;
        _successMessage = null;

        try
        {
            Log("Connessione al server enrollment...");

            using var handler = new HttpClientHandler();
            handler.ServerCertificateCustomValidationCallback = (_, _, _, _) => true;
            using var enrollClient = new HttpClient(handler)
            {
                BaseAddress = new Uri($"https://{_settings.TakServerIp}:{_settings.EnrollmentPort}")
            };

            var token = Convert.ToBase64String(
                Encoding.UTF8.GetBytes($"{_settings.EnrollUser}:{_settings.EnrollPassword}"));
            enrollClient.DefaultRequestHeaders.Authorization =
                new AuthenticationHeaderValue("Basic", token);

            Log("GET /Marti/api/tls/config ...");
            var configResp = await enrollClient.GetAsync("/Marti/api/tls/config");
            var configBody = await configResp.Content.ReadAsStringAsync();
            if (!configResp.IsSuccessStatusCode)
                throw new HttpRequestException($"tls/config HTTP {(int)configResp.StatusCode}: {configBody}");

            var doc  = XDocument.Parse(configBody);
            var rdns = doc.Descendants()
                          .Where(el => el.Name.LocalName == "nameEntry")
                          .Select(el => (
                              Name:  (el.Attribute("name")?.Value  ?? "").ToUpper(),
                              Value: el.Attribute("value")?.Value ?? ""))
                          .ToList();
            Log($"RDN ricevuti: {string.Join(", ", rdns.Select(r => $"{r.Name}={r.Value}"))}");

            Log("Generazione CSR locale...");
            var (privateKey, csrPem) = TakCsr.Build(_settings.EnrollUser, rdns);
            Log($"CSR generata (CN={_settings.EnrollUser}).");

            Log($"POST /Marti/api/tls/signClient/v2?clientUid={_settings.ClientUid} ...");
            var url     = $"/Marti/api/tls/signClient/v2?clientUid={Uri.EscapeDataString(_settings.ClientUid)}";
            var content = new StringContent(csrPem, Encoding.UTF8, "application/octet-stream");
            var request = new HttpRequestMessage(HttpMethod.Post, url) { Content = content };
            request.Headers.Accept.Add(new MediaTypeWithQualityHeaderValue("application/json"));

            var signResp = await enrollClient.SendAsync(request);
            var signBody = await signResp.Content.ReadAsStringAsync();
            if (!signResp.IsSuccessStatusCode)
                throw new HttpRequestException($"signClient HTTP {(int)signResp.StatusCode}: {signBody}");

            var json = JsonNode.Parse(signBody)!;
            var signedCert = WrapPem(json["signedCert"]!.GetValue<string>());
            var caPems = new List<string>();
            for (int i = 0; json[$"ca{i}"] is JsonNode ca; i++)
                caPems.Add(WrapPem(ca.GetValue<string>()));
            Log($"Certificato firmato ricevuto. CA chain: {caPems.Count} certs.");

            Log("Assemblaggio P12...");
            var p12Bytes = TakCsr.ExportP12(privateKey, signedCert, caPems, _settings.CertificatePassword);
            Log($"P12 generato ({p12Bytes.Length} bytes).");

            _settings.CertificateP12 = p12Bytes;
            await SettingsService.SaveAsync(_settings);
            await TakProvider.ReconfigureAsync(_settings);

            _settings = await SettingsService.GetOrCreateAsync();
            Log("Enrollment completato. TakClient riconfigurato.");
            _successMessage = "Enrollment completato con successo.";
        }
        catch (Exception ex)
        {
            _errorMessage = $"Enrollment fallito: {ex.Message}";
            Log($"ERRORE: {ex.Message}");
        }
        finally
        {
            _enrolling = false;
        }
    }

    private void Log(string msg)
    {
        _enrollLog.Add($"[{DateTime.Now:HH:mm:ss}] {msg}");
        StateHasChanged();
    }

    private static string WrapPem(string data)
    {
        data = data.Trim();
        return data.StartsWith("-----BEGIN", StringComparison.Ordinal)
            ? data
            : "-----BEGIN CERTIFICATE-----\n" + data + "\n-----END CERTIFICATE-----";
    }
}
