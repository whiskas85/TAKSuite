                navItems.Add(new NavItem { Href = $"{hrefBase}/waypoints", Text = "Waypoint", IconName = IconName.PinAngleFill, ParentId = teamMenuid, Id = $"{id}.{team.Id}.{counter++}" });

            }
        }
        return navItems;
    }











    private string? currentUrl;

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
    }
    protected override void OnInitialized()
    {
        currentUrl = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        NavigationManager.LocationChanged += OnLocationChanged;
        NavRefreshService.OnNavChanged += OnNavRefreshed;
        NavRefreshService.OnTaskNameChanged += OnTaskNameChanged;
    }

    private void OnNavRefreshed()
    {
        navItems = null;
        _navVersion++;
        _ = InvokeAsync(StateHasChanged);
    }

    private void OnTaskNameChanged(Guid taskId, string newName)
    {
        if (navItems == null) return;
        var operativoItem = navItems.FirstOrDefault(n => n.Href == $"/taskdetail/{taskId}");
        if (operativoItem == null) return;
        var parentItem = navItems.FirstOrDefault(n => n.Id == operativoItem.ParentId);
        if (parentItem != null)
            parentItem.Text = newName;
        _ = InvokeAsync(StateHasChanged);
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        currentUrl = NavigationManager.ToBaseRelativePath(e.Location);
        StateHasChanged();
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
        NavRefreshService.OnNavChanged -= OnNavRefreshed;
        NavRefreshService.OnTaskNameChanged -= OnTaskNameChanged;
    }
