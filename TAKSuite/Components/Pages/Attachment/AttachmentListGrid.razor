@using System.Reflection
@using TAKSuite.Data.ModelsTak
@using TAKSuite.Data.ServicesTak
@inject AttachmentService AttachmentService    
@inject IJSRuntime JS
@inject ToastService ToastService

<Grid TItem="AtakAttachment"
Class="table table-hover"
HeaderRowCssClass="bg-success text-white border-bottom-0 h5"
FiltersRowCssClass="bg-success text-white bg-opacity-25 border-bottom-0"
Data="list"
AllowFiltering="false"
AllowPaging="false"
PageSize="5"
AllowSorting="true"
Responsive="true">

    <GridColumns>
        <GridColumn TItem="AtakAttachment" HeaderText="" class="align-middle icon-header">
            <Icon Name="IconName.Paperclip" Color="IconColor.Secondary" />
        </GridColumn>
        <GridColumn TItem="AtakAttachment" HeaderText="Callsign" Class="align-middle" SortKeySelector="item => item.Name">
            @context.Name
        </GridColumn>
        <GridColumn TItem="AtakAttachment" HeaderText="Tipo" Class="align-middle" SortKeySelector="item => item.MediaType">
            @context.LastUpdateTime
        </GridColumn>
        <GridColumn TItem="AtakAttachment" HeaderText="Apri">
            @if (context.MediaType.Contains("jpeg"))
            {
                <Button @onclick="()=> DocumentationHelper.OpenAttachment(context,JS)">
                    <Icon Name="IconName.FileEarmarkImage" Color="IconColor.Primary"></Icon>
                </Button>
            }
            else if (context.MediaType.Contains("pdf"))
            {
                <Button @onclick="()=> DocumentationHelper.OpenAttachment(context,JS)">
                    <Icon Name="IconName.FileEarmarkPdfFill" Color="IconColor.Primary"></Icon>
                </Button>
            }
            else
            {
                <Button @onclick="()=> DocumentationHelper.OpenAttachment(context,JS)">
                    <Icon Name="IconName.FileEarmarkArrowDownFill" Color="IconColor.Primary"></Icon>
                </Button>

            }
            <Button @onclick="()=> DeleteAttachment(context)"><Icon Name="IconName.X" Color="IconColor.Danger"></Icon></Button>
        </GridColumn>

    </GridColumns>

</Grid>

@code {
    [Parameter] public Waypoint? Item { get; set; }

    private List<AtakAttachment> list = new();


    protected override async Task OnParametersSetAsync()
    {
        await base.OnParametersSetAsync();

        if (Item == null)
            return;

        list = await AttachmentService.GetAllAsync(Item.Uid);
    }

    private async Task DeleteAttachment(AtakAttachment attach)
    {
        bool res = await AttachmentService.DeleteAsync(attach);
        if (res)
        {
            ToastService.Notify(new(ToastType.Success, "Eliminazione", $"Il file {attach.Name} è stato eliminato"));
        }
        else
        {
            ToastService.Notify(new(ToastType.Danger, "Errore", $"Attenzione non è stato possibile eliminare: {attach.Name}"));

        }
    }

}
