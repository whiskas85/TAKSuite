@page "/missiontak/{MissionTakId:guid}"
@attribute [Authorize]
@implements IDisposable
@using Microsoft.AspNetCore.Authorization
@using TAKSuite.Components.Pages.Components
@using TAKSuite.Components.Pages.Tasks.TaskComponents
@using TAKSuite.Data.Models
@using TAKSuite.Data.Services
@inject MissionSuiteEntityServices entityService
@inject TaskService service
@inject NavigationManager Navigation
@inject ToastService ToastService

<PageTitle>@missionTak?.Name</PageTitle>
@if (missionTak == null)
{
    <p>Caricamento...</p>
}
else
{
    <!-- GL Modal -->
    <Modal @ref="_glModal" Title="@($"Luce Verde — {_editingGlTask?.Name}")">
        <BodyTemplate>
            <div class="d-flex gap-2 align-items-end flex-wrap">
                <div>
                    <label class="form-label small mb-1">Data/ora (ora locale)</label>
                    <input type="datetime-local" class="form-control"
                           value="@ToLocalInput(_editingGlValue)"
                           @onchange="e => _editingGlValue = ParseLocalDt(e.Value?.ToString())" />
                </div>
                <Button Color="ButtonColor.Secondary" @onclick="SetEditingGlNow">Ora</Button>
            </div>
        </BodyTemplate>
        <FooterTemplate>
            <Button Color="ButtonColor.Success" @onclick="SaveEditingGl"
                    Loading="_savingGl" LoadingText="Salvataggio...">
                <Icon Name="IconName.Save" /> Salva
            </Button>
            @if (_editingGlTask?.GreenLightDateTime.HasValue == true)
            {
                <Button Color="ButtonColor.Danger" @onclick="ClearEditingGl">
                    <Icon Name="IconName.XCircle" /> Rimuovi
                </Button>
            }
            <Button Color="ButtonColor.Secondary" @onclick='async () => await _glModal.HideAsync()'>Annulla</Button>
        </FooterTemplate>
    </Modal>

    <!-- Header fisso -->
    <div style="position: fixed; top: 0; left: 300px; right: 0; z-index: 100;
                background: var(--bs-body-bg); border-bottom: 1px solid var(--bs-border-color);
                padding: 0.5rem 1.5rem;">
        <div class="d-flex justify-content-between align-items-center">
            <!-- Sinistra: nome + descrizione -->
            <div>
                <h1 class="mb-0 fs-3">@missionTak.Name</h1>
                @if (!string.IsNullOrEmpty(missionTak.Descrizione))
                {
                    <p class="text-muted mb-0 small">@missionTak.Descrizione</p>
                }
            </div>
            <!-- Destra: pulsanti + separatore + orologio -->
            <div class="d-flex align-items-center gap-3">
                <div class="d-flex gap-2">
                    <Dropdown Color="DropdownColor.Secondary">
                        <DropdownToggleButton>@missionTak.Status.GetDisplayName()</DropdownToggleButton>
                        <DropdownMenu Class="p-0 text-muted" Style="width: 320px;">
                            <div class="px-2 py-1 d-flex flex-column">
                                <TAKSuite.Components.Pages.Components.MissionProgress MissionEntity="missionTak" />
                            </div>
                        </DropdownMenu>
                    </Dropdown>
                    <Button Color="ButtonColor.Secondary" Outline="true"
                            @onclick='() => Navigation.NavigateTo($"/missionedit/{MissionTakId}")'>
                        <Icon Name="IconName.GearFill" /> Configura
                    </Button>
                </div>
                <div class="vr align-self-stretch"></div>
                <div class="text-end lh-1">
                    <div style="font-size: 1.9rem; font-weight: 700; letter-spacing: .05em; font-variant-numeric: tabular-nums;">
                        @DateTime.Now.ToString("HH:mm:ss")
                    </div>
                    <div class="text-muted" style="font-size: .75rem;">@DateTime.Now.ToString("dd/MM/yyyy")</div>
                </div>
            </div>
        </div>
        <!-- Countdown missione -->
        @if (!string.IsNullOrEmpty(GetMissionCountdown()))
        {
            <div class="alert @GetMissionCountdownClass() d-flex align-items-center gap-2 mb-0 mt-2 py-1">
                <Icon Name="IconName.ClockFill" />
                <strong>@GetMissionCountdown()</strong>
            </div>
        }
    </div>
    <!-- Spacer per compensare l'header fisso -->
    <div style="height: @(string.IsNullOrEmpty(GetMissionCountdown()) ? "80px" : "130px");"></div>

    <!-- Dettagli + Grafico -->
    <div class="row g-3 mb-4">
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-header fw-bold">Dettagli Missione</div>
                <ul class="list-group list-group-flush">
                    <li class="list-group-item d-flex justify-content-between">
                        <span class="text-muted">Stato</span>
                        <Badge Color="BadgeColor.Primary">@missionTak.Status.GetDisplayName()</Badge>
                    </li>
                    <li class="list-group-item d-flex justify-content-between">
                        <span class="text-muted">Team responsabile</span>
                        <span>@(missionTak.Team?.Name ?? "—")</span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between">
                        <span class="text-muted">Creata il</span>
                        <span>@ToLocalDisplay(missionTak.CreationDate)</span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between">
                        <span class="text-muted">Ultima modifica</span>
                        <span>@ToLocalDisplay(missionTak.LastModified)</span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between">
                        <span class="text-muted">Task totali</span>
                        <Badge Color="BadgeColor.Secondary">@_tasks.Count</Badge>
                    </li>
                    <li class="list-group-item d-flex justify-content-between">
                        <span class="text-muted">TAK Mission UID</span>
                        <span class="font-monospace small">@(missionTak.TakMissionUid ?? "N/D")</span>
                    </li>
                    @if (missionTak.StartDateTime.HasValue)
                    {
                        <li class="list-group-item d-flex justify-content-between">
                            <span class="text-muted">Inizio</span>
                            <span>@ToLocalDisplay(missionTak.StartDateTime.Value)</span>
                        </li>
                    }
                    @if (missionTak.EndDateTime.HasValue)
                    {
                        <li class="list-group-item d-flex justify-content-between">
                            <span class="text-muted">Fine</span>
                            <span>@ToLocalDisplay(missionTak.EndDateTime.Value)</span>
                        </li>
                    }
                </ul>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-header fw-bold">Stato Task</div>
                <div class="card-body d-flex justify-content-center align-items-center" style="min-height:220px">
                    @if (_chartData != null)
                    {
                        <PieChart @ref="_pieChart" Width="300" />
                    }
                    else
                    {
                        <span class="text-muted">Nessun task</span>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Obiettivi attivi -->
    <div class="card mb-4">
        <div class="card-header fw-bold">
            Obiettivi attivi (@_activeObjectives.Count)
        </div>
        <div class="card-body p-2">
            @if (!_activeObjectives.Any())
            {
                <p class="text-muted text-center py-3 mb-0">
                    Nessun obiettivo attivo. Aggiungili dalla pagina
                    <NavLink href="@($"/missionedit/{MissionTakId}")">Configura</NavLink>.
                </p>
            }
            @for (int i = 0; i < _activeObjectives.Count; i++)
            {
                var task = _activeObjectives[i];
                var glEnd = task.GreenLightDateTime.HasValue && task.Durata.HasValue
                    ? task.GreenLightDateTime.Value.AddMinutes(task.Durata.Value)
                    : (DateTime?)null;
                var nowUtc = DateTime.UtcNow;
                var inGlWindow = task.GreenLightDateTime.HasValue
                    && nowUtc >= task.GreenLightDateTime.Value
                    && (glEnd == null || nowUtc < glEnd.Value);
                var glRemaining = (inGlWindow && glEnd.HasValue) ? glEnd.Value - nowUtc : (TimeSpan?)null;

                @if (i > 0)
                {
                    var prev = _activeObjectives[i - 1];
                    if (prev.GreenLightDateTime.HasValue && task.GreenLightDateTime.HasValue)
                    {
                        var prevGlEnd = prev.Durata.HasValue
                            ? prev.GreenLightDateTime.Value.AddMinutes(prev.Durata.Value)
                            : prev.GreenLightDateTime.Value;
                        var gap = task.GreenLightDateTime.Value - prevGlEnd;
                        var timeToNext = task.GreenLightDateTime.Value - nowUtc;
                        if (gap.TotalSeconds > 0 && timeToNext.TotalSeconds > 0)
                        {
                            <div class="text-center text-muted small py-1" style="letter-spacing:.03em;">
                                <span>↕ @FormatTs(timeToNext)</span>
                            </div>
                        }
                    }
                }

                <div class="border rounded mb-1 @(inGlWindow ? "border-success border-2" : "")">
                    <div class="d-flex justify-content-between align-items-center px-3 py-2"
                         style="position: sticky; top: 0; z-index: 5; background: var(--bs-body-bg); border-radius: inherit;">
                        <div class="d-flex align-items-center gap-2 flex-wrap">
                            <NavLink href="@($"/taskdetail/{task.Id}")"
                                     class="fw-semibold text-decoration-none text-body">
                                @task.Name
                            </NavLink>
                            @if (!string.IsNullOrEmpty(task.Sottotitolo))
                            {
                                <span class="text-muted small">@task.Sottotitolo</span>
                            }
                            @if (task.Priority != null)
                            {
                                <span class="badge bg-secondary">@task.Priority.Name</span>
                            }
                            @if (inGlWindow)
                            {
                                <span class="badge bg-success px-2">
                                    IN FINESTRA
                                    @if (glRemaining.HasValue)
                                    {
                                        <span class="ms-1 fw-normal">@FormatTs(glRemaining.Value)</span>
                                    }
                                </span>
                            }
                        </div>
                        <div class="d-flex align-items-center gap-2 flex-shrink-0">
                            @if (task.GreenLightDateTime.HasValue)
                            {
                                <span class="text-success small fw-semibold text-end lh-1">
                                    <Icon Name="IconName.CircleFill" />
                                    @ToLocalDisplay(task.GreenLightDateTime.Value, "HH:mm")
                                    <br /><span class="text-muted fw-normal" style="font-size:.8em;">@ToLocalDisplay(task.GreenLightDateTime.Value, "dd/MM")</span>
                                </span>
                            }
                            else if (task.StartDateTime.HasValue)
                            {
                                <span class="text-muted small text-end lh-1">
                                    @ToLocalDisplay(task.StartDateTime.Value, "HH:mm")
                                    <br /><span style="font-size:.8em;">@ToLocalDisplay(task.StartDateTime.Value, "dd/MM")</span>
                                </span>
                            }
                            <Button Size="ButtonSize.Small"
                                    Color="@(task.GreenLightDateTime.HasValue ? ButtonColor.Success : ButtonColor.Secondary)"
                                    Outline="true"
                                    @onclick="() => OpenGlModal(task)">
                                <Icon Name="IconName.CircleFill" /> GL
                            </Button>
                            <NavLink class="btn btn-sm btn-outline-primary" href="@($"/taskdetail/{task.Id}")">
                                <Icon Name="IconName.Eye" />
                            </NavLink>
                        </div>
                    </div>

                    @if (_hasMissionWindow)
                    {
                        <div class="px-3 pb-2">
                            <MissionTimelineBar
                                MissionStart="missionTak.StartDateTime!.Value"
                                MissionEnd="missionTak.EndDateTime!.Value"
                                TaskStart="task.StartDateTime"
                                TaskEnd="task.EndDateTime"
                                GreenLight="task.GreenLightDateTime"
                                GreenLightEnd="glEnd"
                                PlannedStart="task.PlannedStartDateTime"
                                PlannedEnd="task.PlannedEndDateTime" />
                        </div>
                    }
                </div>
            }
        </div>
    </div>

    <!-- Obiettivi completati -->
    <div class="card">
        <div class="card-header fw-bold">Obiettivi completati (@_completedObjectives.Count)</div>
        @if (_completedObjectives.Any())
        {
            <div class="table-responsive">
                <table class="table table-sm table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Obiettivo</th>
                            <th>Stato</th>
                            <th>Team assegnato</th>
                            <th>Ultima modifica</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var task in _completedObjectives)
                        {
                            <tr>
                                <td>
                                    <NavLink href="@($"/taskdetail/{task.Id}")"
                                             class="text-decoration-none text-body fw-semibold">
                                        @task.Name
                                    </NavLink>
                                    @if (!string.IsNullOrEmpty(task.Sottotitolo))
                                    {
                                        <span class="text-muted small ms-1">@task.Sottotitolo</span>
                                    }
                                </td>
                                <td>
                                    <span class="badge @GetCompletedBadgeClass(task.Status)">
                                        @task.Status.GetDisplayName()
                                    </span>
                                </td>
                                <td>@(task.AssignedTeam?.Name ?? "—")</td>
                                <td class="text-muted small">@ToLocalDisplay(task.LastModified, "dd/MM HH:mm")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="card-body text-center text-muted">Nessun obiettivo completato.</div>
        }
    </div>
}

@code {
    [Parameter] public Guid MissionTakId { get; set; }

    private MissionSuite? missionTak;
    private List<TaskEntity> _tasks = new();

    private PieChart _pieChart = default!;
    private ChartData? _chartData;
    private PieChartOptions _chartOptions = new() { Responsive = true, Plugins = new() { Legend = new() { Position = "bottom" } } };
    private bool _chartInitialized;

    private System.Timers.Timer? _timer;

    // GL modal
    private Modal _glModal = default!;
    private TaskEntity? _editingGlTask;
    private DateTime? _editingGlValue;
    private bool _savingGl;

    private static readonly HashSet<TaskStatusTak> _completedStatuses = new()
    {
        TaskStatusTak.Completed,
        TaskStatusTak.Aborted,
        TaskStatusTak.Failed,
        TaskStatusTak.Canceled
    };

    private List<TaskEntity> _activeObjectives = new();
    private List<TaskEntity> _completedObjectives = new();
    private bool _hasMissionWindow;

    private void ComputeView()
    {
        _activeObjectives = _tasks
            .Where(t => !_completedStatuses.Contains(t.Status))
            .OrderBy(t => t.GreenLightDateTime.HasValue ? 0 : 1)
            .ThenBy(t => t.GreenLightDateTime ?? DateTime.MaxValue)
            .ThenBy(t => t.Name)
            .ToList();
        _completedObjectives = _tasks
            .Where(t => _completedStatuses.Contains(t.Status))
            .OrderByDescending(t => t.LastModified)
            .ToList();
        _hasMissionWindow = missionTak?.StartDateTime.HasValue == true && missionTak.EndDateTime.HasValue;
    }

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        missionTak = await entityService.GetAsync(MissionTakId);
        _tasks = await LoadData();
        ComputeView();
        BuildChartData();
        StartTimerIfNeeded();
        StateHasChanged();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_chartData != null && !_chartInitialized && _pieChart is not null)
        {
            _chartInitialized = true;
            await _pieChart.InitializeAsync(_chartData, _chartOptions);
        }
    }

    // --- Timer ---

    private void StartTimerIfNeeded()
    {
        if (_timer == null)
        {
            _timer = new System.Timers.Timer(1000);
            _timer.Elapsed += async (_, _) => await InvokeAsync(StateHasChanged);
            _timer.AutoReset = true;
            _timer.Start();
        }
    }

    // --- Mission countdown ---

    private string GetMissionCountdown()
    {
        if (missionTak?.StartDateTime == null || missionTak.EndDateTime == null) return "";
        var now = DateTime.UtcNow;
        if (now < missionTak.StartDateTime.Value)
            return $"Inizio tra {FormatTs(missionTak.StartDateTime.Value - now)}";
        if (now <= missionTak.EndDateTime.Value)
            return $"Fine missione tra {FormatTs(missionTak.EndDateTime.Value - now)}";
        return "Missione terminata";
    }

    private string GetMissionCountdownClass()
    {
        if (missionTak?.StartDateTime == null || missionTak.EndDateTime == null) return "alert-secondary";
        var now = DateTime.UtcNow;
        if (now < missionTak.StartDateTime.Value) return "alert-info";
        if (now <= missionTak.EndDateTime.Value) return "alert-warning";
        return "alert-secondary";
    }

    // --- Task countdown ---

    private string GetTaskCountdownLabel(TaskEntity task)
    {
        var now = DateTime.UtcNow;
        if (task.GreenLightDateTime.HasValue)
        {
            var gs = task.GreenLightDateTime.Value;
            DateTime? ge = task.Durata.HasValue ? gs.AddMinutes(task.Durata.Value) : null;
            if (now < gs) return $"GL tra {FormatTs(gs - now)}";
            if (ge.HasValue && now < ge.Value) return $"GL — {FormatTs(ge.Value - now)}";
            if (!ge.HasValue) return "LUCE VERDE";
            return "GL terminata";
        }
        if (task.EndDateTime.HasValue)
        {
            if (now < task.EndDateTime.Value) return $"Fine tra {FormatTs(task.EndDateTime.Value - now)}";
            return "Scaduto";
        }
        return "";
    }

    private string GetTaskCountdownBadgeClass(TaskEntity task)
    {
        var now = DateTime.UtcNow;
        if (task.GreenLightDateTime.HasValue)
        {
            var gs = task.GreenLightDateTime.Value;
            DateTime? ge = task.Durata.HasValue ? gs.AddMinutes(task.Durata.Value) : null;
            if (now >= gs && (!ge.HasValue || now < ge.Value)) return "bg-success";
            if (ge.HasValue && now >= ge.Value) return "bg-secondary";
            return "bg-warning text-dark";
        }
        if (task.EndDateTime.HasValue && now >= task.EndDateTime.Value) return "bg-secondary";
        return "bg-warning text-dark";
    }

    // --- GL modal ---

    private async Task OpenGlModal(TaskEntity task)
    {
        _editingGlTask = task;
        _editingGlValue = task.GreenLightDateTime;
        await _glModal.ShowAsync();
    }

    private void SetEditingGlNow() => _editingGlValue = DateTime.UtcNow;

    private async Task SaveEditingGl()
    {
        if (_editingGlTask == null) return;
        _savingGl = true;
        try
        {
            _editingGlTask.GreenLightDateTime = _editingGlValue;
            _editingGlTask.LastModified = DateTime.UtcNow;
            await service.UpdateAsync(_editingGlTask);
            _tasks = await LoadData();
            ComputeView();
            await _glModal.HideAsync();
            ToastService.Notify(new(ToastType.Success, "Task", "Luce verde aggiornata"));
        }
        finally { _savingGl = false; }
    }

    private async Task ClearEditingGl()
    {
        _editingGlValue = null;
        await SaveEditingGl();
    }

    // --- Data ---

    private async Task<List<TaskEntity>> LoadData()
    {
        var all = await service.GetAllAsync();
        return all
            .Where(t => t.MissionTAKSuiteId == MissionTakId)
            .OrderByDescending(x => x.CreationDate)
            .ToList();
    }

    // --- Helpers ---

    private static string GetCompletedBadgeClass(TaskStatusTak status) => status switch
    {
        TaskStatusTak.Completed => "bg-success",
        TaskStatusTak.Failed    => "bg-danger",
        TaskStatusTak.Aborted   => "bg-warning text-dark",
        _                       => "bg-secondary"
    };

    private static string FormatTs(TimeSpan ts)
    {
        if (ts.TotalDays >= 1) return $"{(int)ts.TotalDays}g {ts.Hours:00}h {ts.Minutes:00}m {ts.Seconds:00}s";
        if (ts.TotalHours >= 1) return $"{(int)ts.TotalHours:00}h {ts.Minutes:00}m {ts.Seconds:00}s";
        return $"{ts.Minutes:00}m {ts.Seconds:00}s";
    }

    private static string ToLocalDisplay(DateTime utc, string format = "dd/MM/yyyy HH:mm")
        => DateTime.SpecifyKind(utc, DateTimeKind.Utc).ToLocalTime().ToString(format);

    private static string ToLocalInput(DateTime? utc)
        => utc.HasValue ? DateTime.SpecifyKind(utc.Value, DateTimeKind.Utc).ToLocalTime().ToString("yyyy-MM-ddTHH:mm") : "";

    private static DateTime? ParseLocalDt(string? s)
        => string.IsNullOrWhiteSpace(s) ? null
           : DateTime.SpecifyKind(DateTime.Parse(s), DateTimeKind.Local).ToUniversalTime();

    private void BuildChartData()
    {
        if (_tasks.Count == 0) { _chartData = null; return; }
        var grouped = _tasks.GroupBy(t => t.Status).OrderBy(g => g.Key).ToList();
        var colors = new[]
        {
            "rgba(108,117,125,0.8)", "rgba(13,202,240,0.8)", "rgba(255,193,7,0.8)",
            "rgba(13,110,253,0.8)", "rgba(111,66,193,0.8)", "rgba(25,135,84,0.8)",
            "rgba(220,53,69,0.8)", "rgba(253,126,20,0.8)", "rgba(102,16,242,0.8)",
            "rgba(32,201,151,0.8)", "rgba(214,51,132,0.8)", "rgba(23,162,184,0.8)"
        };
        var dataset = new PieChartDataset
        {
            Data = grouped.Select(g => (double?)g.Count()).ToList(),
            BackgroundColor = grouped.Select((_, i) => colors[i % colors.Length]).ToList()
        };
        _chartData = new ChartData
        {
            Labels = grouped.Select(g => g.Key.GetDisplayName()).ToList(),
            Datasets = new List<IChartDataset> { dataset }
        };
    }

    public void Dispose()
    {
        _timer?.Stop();
        _timer?.Dispose();
    }
}
