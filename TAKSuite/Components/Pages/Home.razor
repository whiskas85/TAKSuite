@page "/"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Identity
@using TAKSuite.Data
@using TAKSuite.Data.Seeder
@using TAKSuite.Data.Services

@inject RadioChannelSeeder _seeder;
@inject IUserStore<ApplicationUser> UserStore
@inject UserManager<ApplicationUser> UserManager
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject UserServiceAtak _userServiceAtak;

<PageTitle>Home</PageTitle>

<h1>Buongiorno @nick</h1>
<p>Questa è la tuta pagina personale</p>

@code {
    private string nick;


    protected override async Task OnInitializedAsync()
    {
        await User();
        StateHasChanged();

    }
    private async Task User()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = await UserManager.GetUserAsync(authState.User);

        if (user != null)
        {
            var id = user.UserId; // Assumendo che "Nick" sia una proprietà di ApplicationUser
            var atakUser = await _userServiceAtak.GetAsync(id);
            
            if (atakUser == null) return;
            nick = atakUser.Nick;
        }
        else
        {
            Console.WriteLine("Utente non trovato.");
        }
    }
}