@page "/missiontak/{MissionTakId:guid}/phonecontacts"
@attribute [Authorize]
@using Microsoft.AspNetCore.Authorization
@using TAKSuite.Components.Pages.Components
@using TAKSuite.Data.Models
@using TAKSuite.Data.Services
@inject MissionSuiteEntityServices MissionSuiteService
@inject MissionPhoneContactService AssignmentService
@inject PhoneContactService PhoneContactService
@inject ToastService ToastService

<PageTitle>Contatti — @(_mission?.Name ?? "Missione")</PageTitle>

<!-- Modal: crea/modifica contatto rubrica (riutilizzabile) -->
<PhoneContactEditModal @ref="_contactModal" OnSaved="OnNewContactSaved" />

<!-- Modal: assegna contatto alla missione -->
<Modal @ref="_modalAssign" Title="Associa contatto" Size="ModalSize.Large">
    <BodyTemplate>
        @if (_selectedContact == null)
        {
            <!-- Step 1: cerca e seleziona contatto -->
            <div class="mb-3 d-flex gap-2">
                <input class="form-control" placeholder="Cerca per nome, cognome, nickname, squadra, telefono..."
                       @bind="_assignSearch" @bind:event="oninput" autofocus />
                <Button Color="ButtonColor.Secondary" Size="ButtonSize.Small" Outline="true"
                        @onclick="OpenNewContactFromAssign"
                        title="Aggiungi un nuovo contatto alla rubrica">
                    <Icon Name="IconName.PersonPlusFill" /> Nuovo
                </Button>
            </div>

            @if (!FilteredForAssign.Any())
            {
                <div class="text-center py-4 text-muted small">
                    @if (string.IsNullOrWhiteSpace(_assignSearch))
                    {
                        <span>Nessun contatto in rubrica. Creane uno con il pulsante "Nuovo".</span>
                    }
                    else
                    {
                        <span>Nessun risultato per "<strong>@_assignSearch</strong>".</span>
                    }
                </div>
            }
            else
            {
                <div class="list-group" style="max-height: 380px; overflow-y: auto;">
                    @foreach (var c in FilteredForAssign)
                    {
                        <button class="list-group-item list-group-item-action d-flex justify-content-between align-items-center"
                                @onclick="() => SelectContact(c)">
                            <div>
                                <span class="fw-semibold">@c.Cognome @c.Nome</span>
                                @if (!string.IsNullOrEmpty(c.Nickname))
                                {
                                    <span class="ms-2 badge bg-secondary fw-normal">@c.Nickname</span>
                                }
                                @if (!string.IsNullOrEmpty(c.Squadra))
                                {
                                    <span class="ms-1 text-muted small">— @c.Squadra</span>
                                }
                                @if (!string.IsNullOrEmpty(c.Telefono))
                                {
                                    <div class="text-muted small font-monospace">@c.Telefono</div>
                                }
                            </div>
                            <Icon Name="IconName.ChevronRight" Color="IconColor.Secondary" />
                        </button>
                    }
                </div>
            }
        }
        else
        {
            <!-- Step 2: inserisci ruolo e descrizione -->
            <div class="d-flex align-items-center gap-2 mb-3 p-2 border rounded bg-light">
                <Icon Name="IconName.PersonFill" Color="IconColor.Primary" />
                <div>
                    <div class="fw-semibold">@_selectedContact.Cognome @_selectedContact.Nome</div>
                    @if (!string.IsNullOrEmpty(_selectedContact.Telefono))
                    {
                        <div class="text-muted small font-monospace">@_selectedContact.Telefono</div>
                    }
                    @if (!string.IsNullOrEmpty(_selectedContact.Squadra))
                    {
                        <div class="text-muted small">@_selectedContact.Squadra</div>
                    }
                </div>
                <Button Size="ButtonSize.Small" Color="ButtonColor.Secondary" Outline="true"
                        Class="ms-auto" @onclick="() => _selectedContact = null">
                    <Icon Name="IconName.ArrowLeft" /> Cambia
                </Button>
            </div>

            <div class="mb-3">
                <label class="form-label">Ruolo <span class="text-danger">*</span></label>
                <input class="form-control" @bind="_assignRole"
                       placeholder="es. DE, TOC, Medico, Coordinatore..." />
                <div class="form-text">Identificativo del ruolo nella missione</div>
            </div>
            <div class="mb-3">
                <label class="form-label">Descrizione <span class="text-muted small">(opzionale)</span></label>
                <input class="form-control" @bind="_assignDescription"
                       placeholder="es. Responsabile evacuazione medica" />
            </div>
        }
    </BodyTemplate>
    <FooterTemplate>
        @if (_selectedContact != null)
        {
            <Button Color="ButtonColor.Success" @onclick="SaveAssignment"
                    Loading="_savingAssign" LoadingText="Salvataggio..."
                    Disabled="@string.IsNullOrWhiteSpace(_assignRole)">
                <Icon Name="IconName.PersonCheckFill" /> Associa
            </Button>
        }
        <Button Color="ButtonColor.Secondary" @onclick="async () => await _modalAssign.HideAsync()">
            Chiudi
        </Button>
    </FooterTemplate>
</Modal>

<!-- Modal: modifica ruolo/descrizione di un'associazione esistente -->
<Modal @ref="_modalEdit" Title="Modifica associazione">
    <BodyTemplate>
        @if (_editingAssignment != null)
        {
            <div class="d-flex align-items-center gap-2 mb-3 p-2 border rounded bg-light">
                <Icon Name="IconName.PersonFill" Color="IconColor.Primary" />
                <div>
                    <div class="fw-semibold">
                        @_editingAssignment.PhoneContact.Cognome @_editingAssignment.PhoneContact.Nome
                    </div>
                    @if (!string.IsNullOrEmpty(_editingAssignment.PhoneContact.Telefono))
                    {
                        <div class="text-muted small font-monospace">@_editingAssignment.PhoneContact.Telefono</div>
                    }
                </div>
            </div>
            <div class="mb-3">
                <label class="form-label">Ruolo <span class="text-danger">*</span></label>
                <input class="form-control" @bind="_editRole" />
            </div>
            <div class="mb-3">
                <label class="form-label">Descrizione <span class="text-muted small">(opzionale)</span></label>
                <input class="form-control" @bind="_editDescription" />
            </div>
        }
    </BodyTemplate>
    <FooterTemplate>
        <Button Color="ButtonColor.Success" @onclick="SaveEditAssignment"
                Loading="_savingEdit" LoadingText="Salvataggio..."
                Disabled="@string.IsNullOrWhiteSpace(_editRole)">
            <Icon Name="IconName.Save" /> Salva
        </Button>
        <Button Color="ButtonColor.Secondary" @onclick="async () => await _modalEdit.HideAsync()">Annulla</Button>
    </FooterTemplate>
</Modal>

@if (_mission == null)
{
    <div class="d-flex justify-content-center align-items-center" style="min-height:60vh">
        <div class="text-center text-muted">
            <div class="spinner-border mb-3" role="status"></div>
            <p>Caricamento...</p>
        </div>
    </div>
}
else
{
    <PageHeader Title="@_mission.Name" TitleIcon="IconName.TelephoneFill"
                Subtitle="Contatti telefonici missione">
        <ChildContent>
            <Button Color="ButtonColor.Primary" @onclick="OpenAssign">
                <Icon Name="IconName.PersonPlusFill" /> Associa contatto
            </Button>
        </ChildContent>
    </PageHeader>

    <div class="px-3 py-3">
        @if (!_assignments.Any())
        {
            <div class="text-center py-5 text-muted">
                <Icon Name="IconName.TelephoneInboundFill" Size="IconSize.x5" />
                <p class="mt-3">Nessun contatto associato alla missione.</p>
            </div>
        }
        else
        {
            <div class="d-flex flex-column gap-2">
                @foreach (var a in _assignments)
                {
                    <div class="card">
                        <div class="card-body py-2 px-3">
                            <div class="d-flex align-items-start gap-3">
                                <div class="flex-shrink-0 pt-1">
                                    <Badge Color="BadgeColor.Primary" Class="px-3 py-2" Style="font-size:.9rem;">
                                        @a.Role
                                    </Badge>
                                </div>
                                <div class="flex-grow-1 min-width-0">
                                    @if (!string.IsNullOrEmpty(a.Description))
                                    {
                                        <div class="text-muted small mb-1">@a.Description</div>
                                    }
                                    <div class="fw-semibold">
                                        @a.PhoneContact.Cognome @a.PhoneContact.Nome
                                        @if (!string.IsNullOrEmpty(a.PhoneContact.Nickname))
                                        {
                                            <Badge Color="BadgeColor.Secondary" Class="ms-2 fw-normal">@a.PhoneContact.Nickname</Badge>
                                        }
                                    </div>
                                    <div class="d-flex flex-wrap gap-3 mt-1">
                                        @if (!string.IsNullOrEmpty(a.PhoneContact.Telefono))
                                        {
                                            <span class="small font-monospace">
                                                <Icon Name="IconName.TelephoneFill" />
                                                @a.PhoneContact.Telefono
                                            </span>
                                        }
                                        @if (!string.IsNullOrEmpty(a.PhoneContact.Squadra))
                                        {
                                            <span class="small text-muted">
                                                <Icon Name="IconName.PeopleFill" />
                                                @a.PhoneContact.Squadra
                                            </span>
                                        }
                                    </div>
                                </div>
                                <div class="d-flex gap-1 flex-shrink-0">
                                    <Button Size="ButtonSize.Small" Color="ButtonColor.Primary"
                                            @onclick="() => OpenEditAssignment(a)">
                                        <Icon Name="IconName.PencilFill" />
                                    </Button>
                                    <Button Size="ButtonSize.Small" Color="ButtonColor.Danger"
                                            @onclick="() => RemoveAssignment(a)">
                                        <Icon Name="IconName.Trash3Fill" />
                                    </Button>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
}

@code {
    [Parameter] public Guid MissionTakId { get; set; }

    private MissionSuite? _mission;
    private List<MissionPhoneContact> _assignments = new();
    private List<PhoneContact> _allContacts = new();

    // Modal: assegna
    private Modal _modalAssign = default!;
    private string _assignSearch = "";
    private PhoneContact? _selectedContact;
    private string _assignRole = "";
    private string? _assignDescription;
    private bool _savingAssign;

    // Modal: modifica associazione
    private Modal _modalEdit = default!;
    private MissionPhoneContact? _editingAssignment;
    private string _editRole = "";
    private string? _editDescription;
    private bool _savingEdit;

    // Modal: nuovo contatto rubrica
    private PhoneContactEditModal _contactModal = default!;

    private IEnumerable<PhoneContact> FilteredForAssign =>
        string.IsNullOrWhiteSpace(_assignSearch)
            ? _allContacts
            : _allContacts.Where(c =>
                c.Nome.Contains(_assignSearch, StringComparison.OrdinalIgnoreCase) ||
                c.Cognome.Contains(_assignSearch, StringComparison.OrdinalIgnoreCase) ||
                (c.Nickname?.Contains(_assignSearch, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (c.Squadra?.Contains(_assignSearch, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (c.Telefono?.Contains(_assignSearch, StringComparison.OrdinalIgnoreCase) ?? false));

    protected override async Task OnParametersSetAsync()
    {
        _mission = await MissionSuiteService.GetAsync(MissionTakId);
        await RefreshAssignments();
    }

    private async Task RefreshAssignments()
    {
        _assignments = await AssignmentService.GetByMissionAsync(MissionTakId);
        StateHasChanged();
    }

    private async Task RefreshAllContacts()
    {
        _allContacts = await PhoneContactService.GetAllAsync();
        _allContacts.Sort((a, b) => string.Compare(a.Cognome, b.Cognome, StringComparison.OrdinalIgnoreCase));
    }

    // --- Assign flow ---

    private async Task OpenAssign()
    {
        _assignSearch = "";
        _selectedContact = null;
        _assignRole = "";
        _assignDescription = null;
        await RefreshAllContacts();
        await _modalAssign.ShowAsync();
    }

    private void SelectContact(PhoneContact c)
    {
        _selectedContact = c;
        _assignRole = "";
        _assignDescription = null;
    }

    private async Task SaveAssignment()
    {
        if (_selectedContact == null || string.IsNullOrWhiteSpace(_assignRole)) return;
        _savingAssign = true;
        try
        {
            await AssignmentService.AddAsync(new MissionPhoneContact
            {
                MissionId = MissionTakId,
                PhoneContactId = _selectedContact.Id,
                Role = _assignRole.Trim(),
                Description = string.IsNullOrWhiteSpace(_assignDescription) ? null : _assignDescription.Trim()
            });

            await _modalAssign.HideAsync();
            await RefreshAssignments();
            ToastService.Notify(new(ToastType.Success, "Contatti", "Contatto associato alla missione."));
        }
        finally { _savingAssign = false; }
    }

    private async Task OpenNewContactFromAssign()
    {
        await _modalAssign.HideAsync();
        await _contactModal.ShowAsync();
    }

    private async Task OnNewContactSaved(PhoneContact saved)
    {
        await RefreshAllContacts();
        _selectedContact = _allContacts.FirstOrDefault(c => c.Id == saved.Id);
        _assignRole = "";
        _assignDescription = null;
        ToastService.Notify(new(ToastType.Success, "Rubrica", "Contatto creato."));
        await _modalAssign.ShowAsync();
        StateHasChanged();
    }

    // --- Edit assignment ---

    private async Task OpenEditAssignment(MissionPhoneContact a)
    {
        _editingAssignment = a;
        _editRole = a.Role;
        _editDescription = a.Description;
        await _modalEdit.ShowAsync();
    }

    private async Task SaveEditAssignment()
    {
        if (_editingAssignment == null || string.IsNullOrWhiteSpace(_editRole)) return;
        _savingEdit = true;
        try
        {
            var existing = await AssignmentService.GetAsync(_editingAssignment.Id);
            if (existing != null)
            {
                existing.Role = _editRole.Trim();
                existing.Description = string.IsNullOrWhiteSpace(_editDescription) ? null : _editDescription.Trim();
                await AssignmentService.UpdateAsync(existing);
            }
            await _modalEdit.HideAsync();
            await RefreshAssignments();
            ToastService.Notify(new(ToastType.Success, "Contatti", "Associazione aggiornata."));
        }
        finally { _savingEdit = false; }
    }

    // --- Remove ---

    private async Task RemoveAssignment(MissionPhoneContact a)
    {
        await AssignmentService.DeleteAsync(a.Id);
        await RefreshAssignments();
        ToastService.Notify(new(ToastType.Success, "Contatti", "Associazione rimossa."));
    }
}
