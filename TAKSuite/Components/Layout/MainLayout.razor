@inherits LayoutComponentBase

<MediaQueryList>
    <div class="page">
        <AuthorizeView>
            <Authorized>
                <div class="sidebar">
                    <NavMenu />
                </div>
            </Authorized>
        </AuthorizeView>

        <main>
            <!-- Top bar con sfondo -->
            <div class="top-row bg-body shadow-sm px-3 py-2 d-flex justify-content-between align-items-center border-bottom">
                <AuthorizeView>
                    <Authorized>
                        <!-- Spazio vuoto per mantenere struttura -->
                        <div></div>
                    </Authorized>

                    <NotAuthorized>
                        <!-- Logo + Titolo visibili solo se non loggato -->
                        <div class="d-flex align-items-center">
                            <img src="images/tak trasp.png" alt="TAK Logo" style="height: 40px;" class="me-2" />
                            <span class="fw-bold fs-5">TAK Suite</span>
                        </div>
                    </NotAuthorized>
                </AuthorizeView>

                <div class="d-flex align-items-center">
                    <AuthorizeView>
                        <Authorized>
                            <div class="d-flex align-items-center">
                                <NavLink class="nav-link me-3" href="account/personal">
                                    <span class="bi bi-person-fill" aria-hidden="true"></span>
                                    @context.User.Identity?.Name
                                </NavLink>
                                <form action="Account/Logout" method="post" class="m-0">
                                    <AntiforgeryToken />
                                    <input type="hidden" name="ReturnUrl" value="@currentUrl" />
                                    <Button Type="ButtonType.Submit">
                                        <Icon CustomIconName="bi bi-box-arrow-right" Style="font-size: 1.5rem;" />
                                    </Button>
                                </form>
                            </div>
                        </Authorized>
                        <NotAuthorized>
                            <div class="d-flex">
                                <NavLink class="nav-link me-3" href="Account/Register">
                                    <span class="bi bi-person" aria-hidden="true"></span> Register
                                </NavLink>
                                <NavLink class="nav-link" href="Account/Login">
                                    <span class="bi bi-person-badge" aria-hidden="true"></span> Login
                                </NavLink>
                            </div>
                        </NotAuthorized>
                    </AuthorizeView>

                    <div class="ms-3">
                        <ThemeSwitcher Position="DropdownMenuPosition.End" />
                    </div>
                </div>
            </div>

            <article class="content px-4">
                @Body
            </article>
        </main>
    </div>

    <div id="blazor-error-ui" data-nosnippet>
        An unhandled error has occurred.
        <a href="." class="reload">Reload</a>
        <span class="dismiss">🗙</span>
    </div>

    <Toasts class="p-3" AutoHide="true" Delay="4000" StackLength="3" Placement="ToastsPlacement.BottomRight" />
</MediaQueryList>

@code {
    private string? currentUrl;

    [Inject] private NavigationManager NavigationManager { get; set; } = default!;
    [Inject] protected ToastService ToastService { get; set; } = default!;

    protected override void OnInitialized()
    {
        currentUrl = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        NavigationManager.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        currentUrl = NavigationManager.ToBaseRelativePath(e.Location);
        StateHasChanged();
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }
}
