@using TAKSuite.Data.Models
@inject IJSRuntime JS

<div class="task-section" style="--accent-color:@AccentColor">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-2">
        <strong class="section-title">
            <Icon Name="@TitleIcon" /> @Title
        </strong>
    </div>

    <!-- ITEMS -->
    @foreach (var item in _items)
    {
        <div class="input-group mb-2 align-items-center item-row @(_dragOver == item ? "drag-over" : "")"
             @key="item.Id"
             @ondragover="() => OnDragOver(item)"
             @ondragover:preventDefault="true"
             @ondrop="() => OnDrop(item)"
             @ondragend="OnDragEnd">

            <span class="drag-handle" title="Trascina per riordinare"
                  draggable="true"
                  @ondragstart="() => OnDragStart(item)"
                  @ondragend="OnDragEnd">
                <Icon Name="IconName.GripVertical" />
            </span>

            <input class="form-control"
                   placeholder="@Placeholder"
                   value="@item.Value"
                   @onchange="e => item.Value = e.Value?.ToString() ?? string.Empty" />

            <button class="btn btn-outline-danger btn-sm remove-btn"
                    @onclick="() => Remove(item)">
                ✕
            </button>
        </div>
    }

    <!-- AREA "CLICK TO ADD" -->
    @if (!_isAdding)
    {
        <div class="add-zone" @onclick="StartAdding">
            <span class="add-zone-icon">+</span>
            <span>@ButtonText</span>
        </div>
    }
    else
    {
        <div class="input-group mb-1">
            <input class="form-control new-item-input"
                   @ref="_newInputRef"
                   placeholder="@Placeholder"
                   @bind="_newValue"
                   @onkeydown="OnNewItemKeyDown"
                   @onblur="async () => await ConfirmAdd()" />
            <button class="btn btn-outline-secondary btn-sm"
                    @onmousedown:preventDefault="true"
                    @onclick="CancelAdd">
                ✕
            </button>
        </div>
    }

</div>

<style>
    .task-section {
        padding: 12px;
        border-radius: 4px;
        border-left: 4px solid var(--accent-color);
        background-color: color-mix(in srgb, var(--accent-color) 12%, transparent);
        min-height: 48px;
    }

    .section-title {
        color: var(--accent-color);
        font-weight: 600;
    }

    .item-row {
        transition: opacity 0.15s;
    }

    .item-row.drag-over {
        outline: 2px dashed var(--accent-color);
        outline-offset: 2px;
        border-radius: 4px;
        opacity: 0.7;
    }

    .drag-handle {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 28px;
        cursor: grab;
        user-select: none;
        color: var(--accent-color);
        opacity: 0.7;
        flex-shrink: 0;
    }

    .drag-handle:active {
        cursor: grabbing;
    }

    .remove-btn {
        border-color: transparent;
        opacity: 0.5;
        transition: opacity 0.15s;
    }

    .remove-btn:hover {
        opacity: 1;
        border-color: var(--bs-danger);
    }

    .add-zone {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 8px 10px;
        margin-top: 6px;
        border: 2px dashed color-mix(in srgb, var(--accent-color) 50%, transparent);
        border-radius: 4px;
        color: color-mix(in srgb, var(--accent-color) 70%, transparent);
        font-size: 0.875rem;
        cursor: pointer;
        transition: border-color 0.15s, color 0.15s, background-color 0.15s;
        user-select: none;
    }

    .add-zone:hover {
        border-color: var(--accent-color);
        color: var(--accent-color);
        background-color: color-mix(in srgb, var(--accent-color) 6%, transparent);
    }

    .add-zone-icon {
        font-size: 1.1rem;
        font-weight: 600;
        line-height: 1;
    }

    .new-item-input {
        animation: fadeIn 0.1s ease-in;
    }

    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(-4px); }
        to   { opacity: 1; transform: translateY(0); }
    }
</style>

@code {
    [Parameter] public string Title { get; set; } = "";
    [Parameter] public string ButtonText { get; set; } = "";
    [Parameter] public string Placeholder { get; set; } = "";
    [Parameter] public string AccentColor { get; set; } = "#0dcaf0";
    [Parameter] public IconName TitleIcon { get; set; } = IconName.InfoCircle;
    [Parameter] public TaskEntity Task { get; set; } = null!;
    [Parameter] public List<TaskStringItem> Items { get; set; } = new();
    [Parameter] public TaskStringItemType SectionType { get; set; }
    [Parameter] public EventCallback OnChanged { get; set; }

    List<TaskStringItem> _items = new();

    // Drag state
    TaskStringItem? _dragged;
    TaskStringItem? _dragOver;

    // Add state
    bool _isAdding;
    string _newValue = string.Empty;
    ElementReference _newInputRef;

    protected override void OnParametersSet()
    {
        _items = Items
            .Where(i => i.Type == SectionType)
            .OrderBy(i => i.Order)
            .ToList();
    }

    // --- Drag & Drop ---

    void OnDragStart(TaskStringItem item) => _dragged = item;

    void OnDragOver(TaskStringItem item) => _dragOver = item;

    async Task OnDrop(TaskStringItem target)
    {
        if (_dragged == null || _dragged == target) return;

        var from = _items.IndexOf(_dragged);
        var to   = _items.IndexOf(target);
        if (from < 0 || to < 0) return;

        _items.RemoveAt(from);
        _items.Insert(to, _dragged);

        SyncOrder();
        _dragged = null;
        _dragOver = null;
        await OnChanged.InvokeAsync();
    }

    void OnDragEnd()
    {
        _dragged  = null;
        _dragOver = null;
    }

    void SyncOrder()
    {
        for (int i = 0; i < _items.Count; i++)
            _items[i].Order = i;
    }

    // --- Add ---

    async Task StartAdding()
    {
        _isAdding = true;
        _newValue = string.Empty;
        StateHasChanged();
        await System.Threading.Tasks.Task.Delay(50); // attendi render
        try { await JS.InvokeVoidAsync("eval", "document.querySelector('.new-item-input')?.focus()"); }
        catch { }
    }

    async Task ConfirmAdd()
    {
        var v = _newValue.Trim();
        if (!string.IsNullOrEmpty(v))
        {
            var item = new TaskStringItem
            {
                TaskEntityId = Task.Id,
                Task = Task,
                Type = SectionType,
                Value = v,
                Order = _items.Count
            };
            Items.Add(item);
            _items.Add(item);
            await OnChanged.InvokeAsync();
        }
        _isAdding = false;
        _newValue = string.Empty;
    }

    void CancelAdd()
    {
        _isAdding = false;
        _newValue = string.Empty;
    }

    async Task OnNewItemKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await ConfirmAdd();
            await StartAdding();
        }
        else if (e.Key == "Escape")
        {
            CancelAdd();
        }
    }

    // --- Remove ---

    async Task Remove(TaskStringItem item)
    {
        Items.Remove(item);
        _items.Remove(item);
        SyncOrder();
        await OnChanged.InvokeAsync();
    }
}
