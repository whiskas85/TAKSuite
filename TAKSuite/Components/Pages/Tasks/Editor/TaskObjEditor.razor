@page "/objeditor/{TaskId:guid}"
@inherits ConnectedUserInfo

@using TAKSuite.Data.Models
@using Microsoft.AspNetCore.Components.Forms
@using BlazorReflection
@using Microsoft.AspNetCore.Authorization
@using TAKSuite.Components.Layout
@using TAKSuite.Components.Pages.Documentation
@using TAKSuite.Components.Pages.Missions
@using TAKSuite.Components.Pages.Tasks.TaskComponents
@using TAKSuite.Data.Models
@using TAKSuite.Data.ModelsTak
@using TAKSuite.Data.Services
@using TAKSuite.TAK.CoT

@inject TaskService taskService
@inject RadioChannelService radioChannelService
@inject TaskTemplateService templateService
@inject IJSRuntime JS

<PageTitle>@taskEntity?.Name</PageTitle>

@if (taskEntity == null)
{
    <p>Caricamento...</p>
}
else
{
    <div class="container-fluid">

        <h3>Task Editor</h3>

        <!-- NOME / SOTTOTITOLO -->
        <div class="row mb-3">
            <div class="col">
                <label class="form-label">Nome</label>
                <InputText class="form-control" @bind-Value="taskEntity.Name" />
            </div>
            <div class="col">
                <label class="form-label">Sottotitolo</label>
                <InputText class="form-control" @bind-Value="taskEntity.Sottotitolo" />
            </div>
        </div>

        <!-- METADATI -->
        <div class="row mb-3">
            <div class="col">
                <label class="form-label">Tipologia Obiettivo</label>
                <InputText class="form-control" @bind-Value="taskEntity.TipologiaObiettivo" />
            </div>
            <div class="col">
                <label class="form-label">Durata (min)</label>
                <InputNumber class="form-control" @bind-Value="taskEntity.Durata" />
            </div>
            <div class="col">
                <label class="form-label">Canale Radio</label>
                <InputSelect class="form-control" @bind-Value="taskEntity.RadioChannelId">
                    <option value="">Seleziona un canale</option>
                    @foreach (var r in RadioList.OrderBy(r => r.Name))
                    {
                        <option value="@r.Id">@r.Name</option>
                    }
                </InputSelect>
            </div>
        </div>

        <!-- DESCRIZIONE -->
        <h5>Descrizione</h5>
        <MarkdownEditor SpellChecker="false" @bind-Value="taskEntity.Description" />

        <div class="mb-3">
            <TaskStringSection Title="ℹ INFO"
                               Items="taskEntity.Items"
                               AccentColor="#3399ff"
                               ButtonText="Aggiungi Info"
                               Placeholder="Inserisci informazione…"
                               Task="taskEntity"
                               SectionType="TaskStringItemType.Info" />
        </div>

        <div class="mb-3">
            <TaskStringSection Title="⚠ NOTE"
                               Items="taskEntity.Items"
                               AccentColor="#ff4444"
                               ButtonText="Aggiungi Nota"
                               Placeholder="Inserisci nota…"
                               Task="taskEntity"
                               SectionType="TaskStringItemType.Note" />
        </div>

        <div class="mb-3">
            <TaskStringSection Title="🚧 AZIONI"
                               Items="taskEntity.Items"
                               AccentColor="#ffcc00"
                               ButtonText="Aggiungi Azione"
                               Placeholder="Inserisci azione operativa…"
                               Task="taskEntity"
                               SectionType="TaskStringItemType.Action" />
        </div>

        <!-- AZIONI -->
        <div class="mt-4 d-flex gap-2 flex-wrap">
            <Button Color="ButtonColor.Success" @onclick="Save">
                Salva Task
            </Button>
            <Button Color="ButtonColor.Primary" @onclick="DownloadHtml">
                <Icon Name="IconName.Download" /> Genera HTML
            </Button>
            <Button Color="ButtonColor.Secondary" @onclick="RefreshPreview">
                <Icon Name="IconName.Eye" /> Aggiorna Anteprima
            </Button>
        </div>

        <!-- ANTEPRIMA -->
        <div class="mt-4">
            <h5>Anteprima</h5>
            <iframe id="task-preview-frame"
                    style="width:100%; height:80vh; border:1px solid #444; border-radius:4px; background:#0f0f0f;"
                    sandbox="allow-same-origin">
            </iframe>
        </div>

    </div>
}

@code {
    [Parameter] public Guid TaskId { get; set; }

    TaskEntity? taskEntity;
    List<RadioChannel> RadioList = new();

    protected override async Task OnInitializedAsync()
    {
        taskEntity = await taskService.GetAsync(TaskId);
        RadioList = await radioChannelService.GetAllAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && taskEntity != null)
            await RefreshPreview();
    }

    private async Task Save()
    {
        if (taskEntity == null) return;
        taskEntity.LastModified = DateTime.UtcNow;
        await taskService.UpdateAsync(taskEntity);
        await RefreshPreview();
    }

    private async Task RefreshPreview()
    {
        if (taskEntity == null) return;
        var html = await templateService.CompileAsync(taskEntity);
        await JS.InvokeVoidAsync("setIframeSrcdoc", "task-preview-frame", html);
    }

    private async Task DownloadHtml()
    {
        if (taskEntity == null) return;
        var html = await templateService.CompileAsync(taskEntity);
        var filename = $"{taskEntity.Name.Replace(" ", "_")}.html";
        await JS.InvokeVoidAsync("downloadTextAsFile", filename, html, "text/html;charset=utf-8");
    }
}
