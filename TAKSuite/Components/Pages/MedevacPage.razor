    <Grid @ref="grid"
    TItem="Medevac"

    Class="table table-hover atak-table-medevac"
    HeaderRowCssClass="bg-success text-white border-bottom-0 h5"
    FiltersRowCssClass="bg-success text-white bg-opacity-25 border-bottom-0"

    DataProvider="RequestDataProvider"
    AllowFiltering="false"
    AllowPaging="false"
    PageSize="20"
    AllowSorting="true"
    AllowSelection="false"
    SelectionMode="GridSelectionMode.Multiple"
    SelectedItemsChanged="OnSelectedItemsChanged"
    Unit="Unit.Px"




    Responsive="true">

    <GridColumns>
        <GridColumn TItem="Medevac" HeaderText="" class="align-middle icon-header" >
            <TAKSuite.Components.Pages.Components.IconComponent Component="context" IconName="add_circle" />
        </GridColumn>
        <GridColumn TItem="Medevac" HeaderText="Callsign" Class="align-middle" SortKeySelector="item => item.Callsign">
            @context.Callsign
        </GridColumn>  
        <GridColumn TItem="Medevac" HeaderText="Report time" Class="align-middle report-time" SortKeySelector="item => item.LastUpdateTime">
            @context.LastUpdateTime
        </GridColumn>

        <GridColumn TItem="Medevac" HeaderText="Reporter" Class="align-middle" SortKeySelector="item => item.ReporterCallsign">
            @context.ReporterCallsign
        </GridColumn>

        <GridColumn TItem="Medevac" HeaderText="Remarks" Class="align-middle" SortKeySelector="item => item.Remarks">
            @context.Remarks
        </GridColumn>

        <GridColumn TItem="Medevac" HeaderText="Remaining" Class="align-middle remaining-time" SortKeySelector="item => item.Remarks">
            <span id="remaining-@context.Uid">remaining</span>
        </GridColumn>
        <GridColumn TItem="Medevac" HeaderText="Resolve case" Class="align-middle">
            <Button @onclick="()=> CompleteWaypoint(context)"><Icon Name="IconName.Check" Color="IconColor.Success"></Icon></Button>
        </GridColumn>
    </GridColumns>

</Grid>
