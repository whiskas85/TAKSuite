<script>
    function copyToClipboard(text) {
    navigator.clipboard.writeText(text).then(() => {
    console.log("Testo copiato: " + text);
    }).catch(err => {
    console.error("Errore nella copia:", err);
    });
    }

    function updateRemainingTime() {
        const table = document.querySelector(".atak-table-medevac");
        if (!table) return;

        const rows = table.querySelectorAll("tbody tr");
        const countdownDuration = 30 * 60 * 1000; // 30 minuti in millisecondi

        rows.forEach(row => {
            const reportTimeCell = row.querySelector(".report-time");
            const remainingCell = row.querySelector(".remaining-time");

            if (reportTimeCell && remainingCell) {
                const reportTimeStr = reportTimeCell.innerText.trim().replace(/\s+/g, ' ');
                const dateTimeParts = reportTimeStr.match(/(\d{2})\/(\d{2})\/(\d{4}) (\d{2}):(\d{2}):(\d{2})/);

                if (dateTimeParts) {
                    const [, day, month, year, hours, minutes, seconds] = dateTimeParts.map(Number);
                    const reportTime = new Date(year, month - 1, day, hours+1, minutes, seconds);

                    if (!isNaN(reportTime.getTime())) {
                        const elapsedTime = new Date().getTime() - reportTime.getTime();
                        const remainingTime = countdownDuration - elapsedTime;

                        if (remainingTime > 0) {
                            const minutes = Math.floor(remainingTime / 60000);
                            const seconds = Math.floor((remainingTime % 60000) / 1000);
                            remainingCell.innerText = `${minutes}m ${seconds}s`;
                        } else {
                            remainingCell.innerText = "Expired";
                        }
                    } else {
                        remainingCell.innerText = "Invalid date";
                    }
                } else {
                    remainingCell.innerText = "Invalid date format";
                }
            }
        });
    }


    // Aggiorna ogni secondo
    setInterval(updateRemainingTime, 1000);
    // Esegui subito all'avvio
    updateRemainingTime();

</script>

