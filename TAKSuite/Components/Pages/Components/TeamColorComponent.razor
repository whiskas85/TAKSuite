@using BlazorReflection.Data
@using Microsoft.AspNetCore.Authorization
@using TAKSuite.Components.Pages.Components
@using TAKSuite.Data.Models
@using TAKSuite.Data.Services
@using TAKSuite.Helper
@using TAKSuite.TAK.Helper

@inject TeamService TeamService

<style>
    .color-button {
        width: 38px;
        height: 38px;
        border: none;
        margin: 5px;
        border-radius: 4px;
        cursor: pointer;
        border: 2px solid #ccc;
    }

    .color-button-active {
        border-color: dodgerblue;
        border-width: 4px;
    }
</style>

<Modal @ref="colorDialog" Title="Seleziona colore" Size="ModalSize.Regular">
    <BodyTemplate>
        <div class="mb-2">
            @foreach (var predefinedColor in ATAKHelper.ATAKPredefinedColors)
            {
                var hexColor = predefinedColor.ToHex();
                var isActive = predefinedColor.Argb == Team.Color;
                <Tooltip Color="TooltipColor.Light" Title="@predefinedColor.Name">
                    <button type="button"
                            class="color-button @(isActive ? "color-button-active" : "")"
                            style="background-color:@hexColor;"
                            @onclick="() => SetColor(hexColor)">
                    </button>
                </Tooltip>
            }
        </div>
        <hr class="my-2" />
        <div class="d-flex align-items-center gap-2">
            <label class="form-label mb-0 small fw-semibold">Colore custom</label>
            <input type="color"
                   class="form-control form-control-color"
                   style="width:48px;height:36px;padding:2px;cursor:pointer;"
                   @bind="_customHex"
                   @bind:event="oninput" />
            <span class="small text-muted font-monospace">@_customHex</span>
            <button type="button" class="btn btn-sm btn-primary ms-auto" @onclick="ApplyCustomColor">
                Applica
            </button>
        </div>
    </BodyTemplate>
</Modal>

<div class="color-button d-flex align-items-stretch"
     style="background-color: @ColorConverterHelper.ArgbToHex(Team.Color); cursor:@(Rights >= GridRightsType.Update ? "pointer" : "default");"
     @onclick="ShowColorDialog">
</div>

@code {
    [Parameter, EditorRequired] public Team Team { get; set; }
    [Parameter] public GridRightsType Rights { get; set; } = GridRightsType.Read;

    private Modal colorDialog = default!;
    private string _customHex = "#ff0000";

    private async Task ShowColorDialog()
    {
        if (Rights < GridRightsType.Update) return;
        _customHex = ColorConverterHelper.ArgbToHex(Team.Color);
        await colorDialog.ShowAsync();
    }

    private async Task SetColor(string hex)
    {
        var intColor = ColorConverterHelper.HexToArgb(hex);
        await colorDialog.HideAsync();
        if (intColor == Team.Color) return;
        Team.Color = intColor;
        await SaveTeam();
    }

    private async Task ApplyCustomColor()
    {
        await SetColor(_customHex);
    }

    private async Task SaveTeam()
    {
        if (Team.Id != Guid.Empty)
        {
            await TeamService.UpdateAsync(Team);
            StateHasChanged();
        }
    }
}
