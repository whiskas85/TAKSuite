@page "/radiochannels"
@attribute [Authorize]

@rendermode InteractiveServer

@using System.ComponentModel.DataAnnotations
@using TAKSuite.Data.Models
@using TAKSuite.Data.Services
@using Microsoft.AspNetCore.Authorization

@inject RadioChannelService RadioChannelService
@inject IJSRuntime JS
@inject ToastService ToastService
@inject NavigationManager NavigationManager

<script>
    function copyToClipboard(text) {
        navigator.clipboard.writeText(text).then(() => {
            console.log("Testo copiato: " + text);
        }).catch(err => {
            console.error("Errore nella copia:", err);
        });
    }
</script>

<PageTitle>Gestione Canali Radio</PageTitle>

<h3>Lista canali radio</h3>
@* <Button Color="ButtonColor.Primary" @onclick="OnShowModalClick">Aggiungi canale radio</Button> *@

<Grid @ref="grid"
      TItem="RadioChannel"
      Class="table table-hover"
      HeaderRowCssClass="bg-success text-white border-bottom-0  h5"
      FiltersRowCssClass="bg-success text-white bg-opacity-25 border-bottom-0"
      DataProvider="RadioChannelsDataProvider"
      AllowFiltering="false"
      AllowPaging="false"
      PageSize="20"
      AllowSorting="true"
      AllowSelection="false"
      SelectionMode="GridSelectionMode.Multiple"
      SelectedItemsChanged="OnSelectedItemsChanged"
      Responsive="true">

    <GridColumns>
        <GridColumn TItem="RadioChannel" HeaderText="Nome Canale" Class="align-middle" IsDefaultSortColumn="true" SortDirection="SortDirection.Ascending" SortKeySelector="item => item.Name">
            @context.Name
        </GridColumn>
        <GridColumn TItem="RadioChannel" HeaderText="Tipo" Class="align-middle" SortKeySelector="item => item.FrequencyType">
            @context.FrequencyType
        </GridColumn>
        <GridColumn TItem="RadioChannel" HeaderText="Frequenza MHz" Class="align-middle" SortKeySelector="item => item.Frequency">
            @context.Frequency
        </GridColumn>
        <GridColumn TItem="RadioChannel" Class="align-middle" HeaderText="Azioni">
            @* <Button Color="ButtonColor.Primary" @onclick="() => ShareRadioChannel(context.Id)">Condividi</Button> *@
            <Button Color="ButtonColor.Danger" @onclick="() => DeleteChannel(context.Id)"><Icon Name="IconName.Trash3Fill"></Icon></Button>

        </GridColumn>
    </GridColumns>
</Grid>


