    private async Task<IEnumerable<NavItem>> RetrieveAllMissions(IList<NavItem> navItems, string listTitle,
        IEnumerable<MissionSuite> missions, IEnumerable<TaskEntity> allTasksEnum)
    {
        var parentId = navItems.FirstOrDefault(x => x.Text == listTitle)?.Id;
        if (parentId == null) return navItems;

        navItems.Add(new NavItem
            {
                Id = $"{parentId}.list",
                Href = "/missionstaksuite",
                IconName = IconName.ListNested,
                Text = "Lista missioni",
                ParentId = parentId
            });
        navItems.Add(new NavItem
            {
                Id = $"{parentId}.datasync",
                Href = "/datasync",
                IconName = IconName.ArrowRepeat,
                Text = "DataSync Mission",
                ParentId = parentId
            });

        var allTasks = allTasksEnum;
        var tasksByMission = allTasks
            .Where(t => t.MissionTAKSuiteId.HasValue)
            .GroupBy(t => t.MissionTAKSuiteId!.Value)
            .ToDictionary(g => g.Key, g => g.OrderBy(t => t.Name).ToList());


        var createdMissions = missions.Where(t =>
            t.Status == MissionStatusTak.Created)
            .ToList();
        var activeMissions = missions.Where(t =>
            t.Status == MissionStatusTak.Assigned ||
            t.Status == MissionStatusTak.InProgress ||
            t.Status == MissionStatusTak.Completed)
            .ToList();
        var archivedMissions = missions.Where(t =>
            t.Status == MissionStatusTak.Archived ||
            t.Status == MissionStatusTak.Canceled)
            .ToList();


        
        if (createdMissions.Count > 0)
            navItems = await RetrieveGroupedMissions(
                navItems, createdMissions, tasksByMission, listTitle, parentId,
                "Missioni create", IconName.PlusCircle);

        if (activeMissions.Count > 0)
            navItems = await RetrieveGroupedMissions(
                navItems, activeMissions, tasksByMission, listTitle, parentId,
                "Missioni attive", IconName.PlayCircle);

        if (archivedMissions.Count > 0)
            navItems = await RetrieveGroupedMissions(
                navItems, archivedMissions, tasksByMission, listTitle, parentId,
                "Missioni archiviate", IconName.Archive);


        return navItems;
    }

