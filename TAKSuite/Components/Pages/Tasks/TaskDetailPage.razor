@page "/taskdetail/{TaskId:guid}"
@attribute [Authorize]
@implements IDisposable
@inherits ConnectedUserInfo
@using Microsoft.AspNetCore.Authorization
@using TAKSuite.Components.Layout
@using TAKSuite.Components.Pages.Tasks.TaskComponents
@using TAKSuite.Data.Models
@using TAKSuite.Data.ModelsTak
@using TAKSuite.Data.Services
@using TAKSuite.Data.ServicesTak
@inject TaskService TaskService
@inject MissionSuiteEntityServices MissionSuiteService
@inject TAKSuite.TAK.CoT.MartiApiClient MartiClient
@inject TAKSuite.Data.Services.TakSubscriptionService SubscriptionService
@inject TaskTemplateService TemplateService
@inject AttachmentService AttachmentService
@inject ToastService ToastService
@inject IJSRuntime JS
@inject TeamService TeamService
@inject NavigationManager Navigation

<PageTitle>@(_task?.Name ?? "Dettagli Task")</PageTitle>

@if (_task == null)
{
    <p>Caricamento...</p>
}
else
{
    <PageHeader Title="@_task.Name" Subtitle="@_task.Sottotitolo">
        <ChildContent>
            @if (_task.GreenLightDateTime.HasValue && _task.Durata is > 0)
            {
                <span class="text-success small fw-semibold text-end lh-1 me-1">
                    <Icon Name="IconName.CircleFill" />
                    @DateTime.SpecifyKind(_task.GreenLightDateTime.Value, DateTimeKind.Utc).ToLocalTime().ToString("HH:mm")
                    <br /><span class="text-muted fw-normal" style="font-size:.8em;">@DateTime.SpecifyKind(_task.GreenLightDateTime.Value, DateTimeKind.Utc).ToLocalTime().ToString("dd/MM")</span>
                </span>
            }
            else if (_task.StartDateTime.HasValue)
            {
                <span class="text-muted small text-end lh-1 me-1">
                    @DateTime.SpecifyKind(_task.StartDateTime.Value, DateTimeKind.Utc).ToLocalTime().ToString("HH:mm")
                    <br /><span style="font-size:.8em;">@DateTime.SpecifyKind(_task.StartDateTime.Value, DateTimeKind.Utc).ToLocalTime().ToString("dd/MM")</span>
                </span>
            }
            @if (_mission != null)
            {
                <Button Color="ButtonColor.Secondary" Outline="true"
                        @onclick='() => Navigation.NavigateTo($"/missiontak/{_mission.Id}")'>
                    <Icon Name="IconName.ArrowLeft" /> @_mission.Name
                </Button>
                <Button Color="ButtonColor.Secondary" Outline="true"
                        @onclick='() => Navigation.NavigateTo($"/missiontak/{_mission.Id}/map")'>
                    <Icon Name="IconName.MapFill" /> Mappa
                </Button>
            }
            @if (!string.IsNullOrEmpty(_task.PoiUid) && !string.IsNullOrEmpty(_mission?.TakMissionUid))
            {
                <Button Color="ButtonColor.Success"
                        @onclick="PushToTak"
                        Loading="_pushing"
                        LoadingText="Invio...">
                    <Icon Name="IconName.CloudUploadFill" /> Invia a TAK
                </Button>
            }
            <Button Color="ButtonColor.Secondary" Outline="true"
                    @onclick='() => Navigation.NavigateTo($"/taskdetail/{_task.Id}/documents")'>
                <Icon Name="IconName.FolderFill" /> Documenti
            </Button>
            <Button Color="ButtonColor.Primary"
                    @onclick='() => Navigation.NavigateTo($"/objeditor/{_task.Id}")'>
                <Icon Name="IconName.PencilFill" /> Editor
            </Button>
        </ChildContent>
    </PageHeader>

    <!-- Timeline grafica (mostrata solo se ci sono le date della missione) -->
    @if (_mission?.StartDateTime.HasValue == true && _mission.EndDateTime.HasValue)
    {
        <div class="card mb-3">
            <div class="card-header fw-bold d-flex justify-content-between align-items-center">
                <span>Timeline Missione</span>
                <small class="text-muted">ora locale</small>
            </div>
            <div class="card-body">
                <MissionTimelineBar MissionStart="_mission.StartDateTime!.Value"
                                    MissionEnd="_mission.EndDateTime!.Value"
                                    Windows="@(_task.TimeWindows.Count > 0 ? _task.TimeWindows : null)"
                                    TaskStart="_task.StartDateTime"
                                    TaskEnd="_task.EndDateTime"
                                    GreenLight="_task.GreenLightDateTime"
                                    GreenLightEnd="@(_task.GreenLightDateTime.HasValue && _task.Durata.HasValue
                                        ? _task.GreenLightDateTime.Value.AddMinutes(_task.Durata.Value)
                                        : (DateTime?)null)"
                                    Durata="_task.Durata"
                                    PlannedStart="_task.PlannedStartDateTime"
                                    PlannedEnd="_task.PlannedEndDateTime" />
            </div>
        </div>
    }

    <!-- Countdown obiettivo -->
    @if (!string.IsNullOrEmpty(GetCountdownLabel()))
    {
        <div class="alert @GetCountdownClass() d-flex align-items-center gap-2 mb-3 py-2">
            <Icon Name="IconName.AlarmFill" />
            <strong style="font-size:1.05rem; letter-spacing:.03em;">@GetCountdownLabel()</strong>
        </div>
    }

    <div class="row g-3">

        <!-- Cambio stato -->
        @if (ConnectedAtakUser?.Team != null)
        {
            <div class="col-12">
                <div class="card shadow-sm">
                    <div class="card-body py-2 px-3 d-flex flex-wrap align-items-center gap-2">

                        <span class="fw-semibold text-muted small text-uppercase me-1">Stato</span>

                        <Dropdown Color="DropdownColor.Secondary">
                            <DropdownToggleButton>@_task.Status.GetDisplayName()</DropdownToggleButton>
                            <DropdownMenu Class="p-0 text-muted" Style="width: 320px;">
                                <div class="px-2 py-2">
                                    <TAKSuite.Components.Pages.Components.TaskProgress TaskEntity="_task" />
                                </div>
                                @if (_task.Logs.Any())
                                {
                                    <div class="border-top">
                                        @foreach (var log in _task.Logs.OrderBy(l => l.Timestamp))
                                        {
                                            var statusName = log.NewStatus.GetDisplayName();
                                            <div class="border-bottom px-3 py-2">
                                                <div class="fw-semibold small">@statusName</div>
                                                <div class="small text-secondary"><Icon Name="IconName.PeopleFill" /> @(log.Team?.Name ?? "—")</div>
                                                <div class="small text-secondary"><Icon Name="IconName.Person" /> @(log.User?.Nick ?? "—")</div>
                                                <div class="small text-muted"><Icon Name="IconName.ClockFill" /> @log.Timestamp.ToString("dd/MM/yyyy HH:mm")</div>
                                            </div>
                                        }
                                    </div>
                                }
                            </DropdownMenu>
                        </Dropdown>

                        <div class="vr mx-1 align-self-stretch"></div>

                        <TaskButtons Team="ConnectedAtakUser.Team"
                                     TaskEnt="_task"
                                     Subteams="_subteams"
                                     ShowButtonTitle="true"
                                     User="ConnectedAtakUser"
                                     OnChanged="OnStatusChanged" />
                    </div>
                </div>
            </div>
        }

        <!-- Luce Verde -->
        @if (_task.Durata is > 0)
        {
        <div class="col-md-6">
            <div class="card h-100 border-success">
                <div class="card-header fw-bold text-success d-flex align-items-center gap-2">
                    <Icon Name="IconName.CircleFill" /> Luce Verde
                </div>
                <div class="card-body">
                    <div class="row g-2 align-items-end">
                        <div class="col">
                            <label class="form-label small mb-1">Data/Ora (ora locale)</label>
                            <input type="datetime-local" class="form-control form-control-sm"
                                   value="@ToLocalInput(_task.GreenLightDateTime)"
                                   @onchange="e => _task.GreenLightDateTime = ParseLocalDt(e.Value?.ToString())" />
                        </div>
                        <div class="col-auto">
                            <Button Color="ButtonColor.Secondary" Size="ButtonSize.Small" @onclick="SetGlNow">Ora</Button>
                        </div>
                    </div>
                    <div class="d-flex gap-2 mt-2">
                        <Button Color="ButtonColor.Success" Size="ButtonSize.Small" @onclick="SaveGreenLight"
                                Loading="_savingGl" LoadingText="...">
                            <Icon Name="IconName.Save" /> Salva
                        </Button>
                        @if (_task.GreenLightDateTime.HasValue)
                        {
                            <Button Color="ButtonColor.Danger" Size="ButtonSize.Small" @onclick="ClearGreenLight">
                                <Icon Name="IconName.XCircle" /> Rimuovi
                            </Button>
                        }
                    </div>
                </div>
            </div>
        </div>
        }

        <!-- Info generali -->
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-header fw-bold">Informazioni generali</div>
                <ul class="list-group list-group-flush">
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        <span class="text-muted">Stato</span>
                        <Badge Color="BadgeColor.Primary">@_task.Status.GetDisplayName()</Badge>
                    </li>
                    @if (_task.Priority != null)
                    {
                        <li class="list-group-item d-flex justify-content-between">
                            <span class="text-muted">Priorità</span>
                            <strong>@_task.Priority.Name</strong>
                        </li>
                    }
                    <li class="list-group-item d-flex justify-content-between">
                        <span class="text-muted">Team Assegnato</span>
                        <span>@(_task.AssignedTeam?.Name ?? "N/D")</span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between">
                        <span class="text-muted">Team Esecutivo</span>
                        <span>@(_task.ExecutingTeam?.Name ?? "N/D")</span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between">
                        <span class="text-muted">Creato il</span>
                        <span>@_task.CreationDate.ToString("dd/MM/yyyy HH:mm")</span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between">
                        <span class="text-muted">Ultima modifica</span>
                        <span>@_task.LastModified.ToString("dd/MM/yyyy HH:mm")</span>
                    </li>
                </ul>
            </div>
        </div>

        <!-- Riferimenti TAK + finestra temporale -->
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-header fw-bold">Riferimenti TAK</div>
                <ul class="list-group list-group-flush">
                    @if (_task.PoiLinks.Count > 0)
                    {
                        <li class="list-group-item">
                            <div class="text-muted small mb-2">POI Riferimento TAK</div>
                            @foreach (var poi in _task.PoiLinks)
                            {
                                <div class="d-flex align-items-start gap-2 @(poi != _task.PoiLinks[0] ? "mt-2 pt-2 border-top" : "")">
                                    <Icon Name="@(poi.IsPrimary ? IconName.GeoAltFill : IconName.GeoAlt)"
                                          class="@(poi.IsPrimary ? "text-danger mt-1" : "text-secondary mt-1")" />
                                    <div class="flex-grow-1">
                                        <div>
                                            <strong>@(string.IsNullOrEmpty(poi.Name) ? poi.Uid : poi.Name)</strong>
                                            <Badge Color="@(poi.IsPrimary ? BadgeColor.Danger : BadgeColor.Secondary)"
                                                   class="ms-1">@poi.Role</Badge>
                                        </div>
                                        <div class="text-muted small font-monospace">@poi.Uid</div>
                                    </div>
                                </div>
                            }
                        </li>
                    }
                    else if (!string.IsNullOrEmpty(_task.PoiName) || !string.IsNullOrEmpty(_task.PoiUid))
                    {
                        <li class="list-group-item">
                            <div class="text-muted small mb-1">POI Riferimento TAK</div>
                            @if (!string.IsNullOrEmpty(_task.PoiName))
                            {
                                <div><Icon Name="IconName.GeoAltFill" class="text-danger" /> <strong>@_task.PoiName</strong></div>
                            }
                            @if (!string.IsNullOrEmpty(_task.PoiUid))
                            {
                                <div class="text-muted small font-monospace">@_task.PoiUid</div>
                            }
                        </li>
                    }
                    @if (_task.RadioChannel != null)
                    {
                        <li class="list-group-item d-flex justify-content-between">
                            <span class="text-muted">Canale Radio</span>
                            <span>@_task.RadioChannel.Name</span>
                        </li>
                    }
                    @if (!string.IsNullOrEmpty(_task.MissionUid))
                    {
                        <li class="list-group-item d-flex justify-content-between">
                            <span class="text-muted">Missione TAK</span>
                            <span class="font-monospace small">@_task.MissionUid</span>
                        </li>
                    }
                    @if (_mission != null)
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <span class="text-muted">Missione Suite</span>
                            <NavLink href="@($"/missiontak/{_mission.Id}")" class="btn btn-sm btn-outline-secondary">
                                @_mission.Name
                            </NavLink>
                        </li>
                    }
                    @if (_task.StartDateTime.HasValue)
                    {
                        <li class="list-group-item d-flex justify-content-between">
                            <span class="text-muted">Inizio finestra obj</span>
                            <span>@ToLocal(_task.StartDateTime.Value)</span>
                        </li>
                    }
                    @if (_task.EndDateTime.HasValue)
                    {
                        <li class="list-group-item d-flex justify-content-between">
                            <span class="text-muted">Fine finestra obj</span>
                            <span>@ToLocal(_task.EndDateTime.Value)</span>
                        </li>
                    }
                    @if (_task.GreenLightDateTime.HasValue && _task.Durata is > 0)
                    {
                        <li class="list-group-item d-flex justify-content-between">
                            <span class="text-muted">Luce verde</span>
                            <span class="text-success fw-semibold">
                                <Icon Name="IconName.CircleFill" class="me-1" />
                                @ToLocal(_task.GreenLightDateTime.Value)
                            </span>
                        </li>
                    }
                </ul>
            </div>
        </div>

        <!-- Descrizione -->
        @if (!string.IsNullOrWhiteSpace(_task.Description))
        {
            <div class="col-12">
                <div class="card">
                    <div class="card-header fw-bold">Descrizione</div>
                    <div class="card-body">
                        <Markdown>@_task.Description</Markdown>
                    </div>
                </div>
            </div>
        }

        <!-- Items: Info, Note, Azioni -->
        @{
            var infoItems   = _task.Items.Where(i => i.Type == TaskStringItemType.Info).OrderBy(i => i.Order).ToList();
            var noteItems   = _task.Items.Where(i => i.Type == TaskStringItemType.Note).OrderBy(i => i.Order).ToList();
            var actionItems = _task.Items.Where(i => i.Type == TaskStringItemType.Action).OrderBy(i => i.Order).ToList();
        }

        @if (infoItems.Any())
        {
            <div class="col-md-4">
                <div class="card">
                    <div class="card-header fw-bold">Info</div>
                    <ul class="list-group list-group-flush">
                        @foreach (var item in infoItems)
                        {
                            <li class="list-group-item"><Markdown>@item.Value</Markdown></li>
                        }
                    </ul>
                </div>
            </div>
        }

        @if (noteItems.Any())
        {
            <div class="col-md-4">
                <div class="card">
                    <div class="card-header fw-bold">Note</div>
                    <ul class="list-group list-group-flush">
                        @foreach (var item in noteItems)
                        {
                            <li class="list-group-item"><Markdown>@item.Value</Markdown></li>
                        }
                    </ul>
                </div>
            </div>
        }

        @if (actionItems.Any())
        {
            <div class="col-md-4">
                <div class="card">
                    <div class="card-header fw-bold">Azioni</div>
                    <ul class="list-group list-group-flush">
                        @foreach (var item in actionItems)
                        {
                            <li class="list-group-item"><Markdown>@item.Value</Markdown></li>
                        }
                    </ul>
                </div>
            </div>
        }

    </div>
}

@code {
    [Parameter] public Guid TaskId { get; set; }

    private TaskEntity? _task;
    private MissionSuite? _mission;
    private List<Team> _subteams = new();
    private bool _pushing;

    private System.Timers.Timer? _timer;

    private Guid _loadedTaskId = Guid.Empty;

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        Navigation.LocationChanged += OnLocationChanged;
        await LoadDataAsync(TaskId);
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        var path = new Uri(e.Location).AbsolutePath;
        const string prefix = "/taskdetail/";
        if (!path.StartsWith(prefix, StringComparison.OrdinalIgnoreCase)) return;
        if (!Guid.TryParse(path[prefix.Length..].TrimEnd('/'), out var newId) || newId == _loadedTaskId) return;
        _ = InvokeAsync(() => LoadDataAsync(newId));
    }

    private async Task LoadDataAsync(Guid id)
    {
        _loadedTaskId = id;
        _task = null;
        _mission = null;
        _subteams = new();
        StateHasChanged();

        _task = await TaskService.GetAsync(id);
        if (_task == null) { StateHasChanged(); return; }

        if (_task.MissionTAKSuiteId.HasValue)
            _mission = await MissionSuiteService.GetAsync(_task.MissionTAKSuiteId.Value);

        await AutoSubscribeIfNeededAsync(_mission?.TakMissionUid);

        if (ConnectedAtakUser?.Team != null)
            _subteams = await TeamService.GetSubTeamsAsync(ConnectedAtakUser.Team);

        StartTimerIfNeeded();

        StateHasChanged();
    }

    private void StartTimerIfNeeded()
    {
        bool hasDates = _task?.GreenLightDateTime.HasValue == true || _task?.EndDateTime.HasValue == true;
        if (hasDates && _timer == null)
        {
            _timer = new System.Timers.Timer(1000);
            _timer.Elapsed += async (_, _) => await InvokeAsync(StateHasChanged);
            _timer.AutoReset = true;
            _timer.Start();
        }
    }

    private async Task OnStatusChanged()
    {
        _task = await TaskService.GetAsync(TaskId);
        StateHasChanged();
    }

    private string GetCountdownLabel()
    {
        if (_task == null) return "";
        var now = DateTime.UtcNow;

        if (_task.GreenLightDateTime.HasValue && _task.Durata is > 0)
        {
            var greenStart = _task.GreenLightDateTime.Value;
            var greenEnd = greenStart.AddMinutes(_task.Durata.Value);

            if (now < greenStart)
                return $"Luce verde tra {FormatTs(greenStart - now)}";

            if (now < greenEnd)
                return $"LUCE VERDE — Fine tra {FormatTs(greenEnd - now)}";

            return "Luce verde terminata";
        }

        if (_task.EndDateTime.HasValue)
        {
            if (now < _task.EndDateTime.Value)
                return $"Fine obiettivo tra {FormatTs(_task.EndDateTime.Value - now)}";
            return "Finestra obiettivo scaduta";
        }

        return "";
    }

    private string GetCountdownClass()
    {
        if (_task == null) return "alert-secondary";
        var now = DateTime.UtcNow;

        if (_task.GreenLightDateTime.HasValue && _task.Durata is > 0)
        {
            var greenStart = _task.GreenLightDateTime.Value;
            var greenEnd = greenStart.AddMinutes(_task.Durata.Value);

            if (now >= greenStart && now < greenEnd)
                return "alert-success";

            if (now >= greenEnd)
                return "alert-secondary";

            return "alert-warning";
        }

        if (_task.EndDateTime.HasValue && now >= _task.EndDateTime.Value)
            return "alert-secondary";

        return "alert-warning";
    }

    private bool _savingGl;

    private void SetGlNow() => _task!.GreenLightDateTime = DateTime.UtcNow;

    private async Task SaveGreenLight()
    {
        if (_task == null) return;
        _savingGl = true;
        try
        {
            _task.LastModified = DateTime.UtcNow;
            await TaskService.UpdateAsync(_task);
            ToastService.Notify(new(ToastType.Success, "Task", "Luce verde salvata"));
            StartTimerIfNeeded();
        }
        finally { _savingGl = false; }
    }

    private async Task ClearGreenLight()
    {
        _task!.GreenLightDateTime = null;
        await SaveGreenLight();
    }

    private static string ToLocalInput(DateTime? utc)
        => utc.HasValue ? DateTime.SpecifyKind(utc.Value, DateTimeKind.Utc).ToLocalTime().ToString("yyyy-MM-ddTHH:mm") : "";

    private static DateTime? ParseLocalDt(string? s)
        => string.IsNullOrWhiteSpace(s) ? null
           : DateTime.SpecifyKind(DateTime.Parse(s), DateTimeKind.Local).ToUniversalTime();

    private static string ToLocal(DateTime utc)
        => DateTime.SpecifyKind(utc, DateTimeKind.Utc).ToLocalTime().ToString("dd/MM/yyyy HH:mm");

    private static string FormatTs(TimeSpan ts)
    {
        if (ts.TotalDays >= 1)
            return $"{(int)ts.TotalDays}g {ts.Hours:00}h {ts.Minutes:00}m {ts.Seconds:00}s";
        if (ts.TotalHours >= 1)
            return $"{(int)ts.TotalHours:00}h {ts.Minutes:00}m {ts.Seconds:00}s";
        return $"{ts.Minutes:00}m {ts.Seconds:00}s";
    }

    private async Task PushToTak()
    {
        if (_task == null || _mission == null) return;
        _pushing = true;
        try
        {
            var ok = await TemplateService.PushHtmlToTakAsync(_task, _mission.TakMissionUid!, AttachmentService);
            if (ok)
                ToastService.Notify(new(ToastType.Success, "TAK", $"HTML allegato al POI \"{_task.PoiName ?? _task.PoiUid}\""));
            else
                ToastService.Notify(new(ToastType.Danger, "TAK", "Errore durante l'invio. Controlla log server."));
        }
        finally
        {
            _pushing = false;
        }
    }

    private async Task AutoSubscribeIfNeededAsync(string? takMissionUid)
    {
        if (string.IsNullOrEmpty(takMissionUid)) return;
        if (await SubscriptionService.IsSubscribedAsync(takMissionUid)) return;
        try
        {
            await MartiClient.SubscribeMissionAsync(takMissionUid);
            await SubscriptionService.AddAsync(takMissionUid);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[AutoSubscribe] {takMissionUid}: {ex.Message}");
        }
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= OnLocationChanged;
        _timer?.Stop();
        _timer?.Dispose();
    }
}
