@using System.Reflection
@using TAKSuite.Data.Models
@using TAKSuite.Data.Services
@using TAKSuite.Data.ServicesTak
@using TAKSuite.Data.ModelsTak
@using TAKSuite.TAK.CoT
@using TAKSuite.TAK.Helper
@using System.Text.Json
@using System.Diagnostics

@inject TaskService taskService
@inject RadioChannelService radioChannelService
@inject MissionSuiteEntityServices missionService
@inject TeamService teamService
@inject CoTManager CoTManager
@inject WaypointService WaypointService
@inject CotTemplateService CotTemplateService
@inject TakSettingsService SettingsService
@inject IJSRuntime JS

<Modal @ref="_modal" Title="Importa Task da Testo" Size="ModalSize.ExtraLarge" OnHidden="OnHidden">
    <BodyTemplate>

        @if (_teams.Count > 0)
        {
            <div class="mb-3 d-flex align-items-center gap-2">
                <label class="form-label small fw-semibold mb-0 text-nowrap">Team assegnato:</label>
                <select class="form-select form-select-sm" style="max-width:260px;" @bind="_selectedTeamId">
                    <option value="">— nessuno —</option>
                    @foreach (var t in _teams)
                    {
                        <option value="@t.Id">@t.Name</option>
                    }
                </select>
                @if (_selectedTeamId == null)
                {
                    <span class="text-warning small">⚠ Senza team i flag automatici della missione non si applicano</span>
                }
            </div>
        }

        <ul class="nav nav-tabs mb-3">
            <li class="nav-item">
                <button class="nav-link @(_tab == 0 ? "active" : "")" @onclick='() => _tab = 0'>
                    1. Incolla testo
                </button>
            </li>
            <li class="nav-item">
                <button class="nav-link @(_tab == 1 ? "active" : "")" @onclick='() => _tab = 1'>
                    2. Importa JSON
                </button>
            </li>
        </ul>

        @if (_tab == 0)
        {
            <p class="text-muted small mb-2">
                Incolla il testo dell'obiettivo (da PDF o altra fonte), poi clicca <strong>Genera Prompt</strong>
                e incollalo su ChatGPT, oppure usa <strong>Invia a Claude locale</strong> per l'importazione automatica.
            </p>
            <textarea class="form-control font-monospace import-textarea"
                      placeholder="Incolla qui il testo…"
                      @bind="_rawText"
                      @bind:event="oninput" />

            <div class="mt-3 d-flex align-items-center gap-3 flex-wrap">
                <Button Color="ButtonColor.Primary"
                        @onclick="GeneratePrompt"
                        Disabled="@(string.IsNullOrWhiteSpace(_rawText))">
                    <Icon Name="IconName.Clipboard" /> Genera e copia prompt
                </Button>
                @if (_promptCopied)
                {
                    <span class="text-success small">✓ Prompt copiato! Incollalo su ChatGPT, poi torna alla tab 2.</span>
                }
            </div>

            <hr class="my-3" />

            <div class="d-flex align-items-center gap-2 flex-wrap">
                <Button Color="ButtonColor.Success"
                        @onclick="SendToClaudeCliAsync"
                        Loading="_sendingToClaude"
                        LoadingText="Claude sta elaborando…"
                        Disabled="@(string.IsNullOrWhiteSpace(_rawText))">
                    <Icon Name="IconName.Robot" /> Invia a Claude locale
                </Button>
                <span class="text-muted small">Richiede <code>claude</code> nel PATH (Claude Code CLI)</span>
            </div>

            @if (!string.IsNullOrEmpty(_claudeError))
            {
                <div class="alert alert-danger mt-2 py-2 small">@_claudeError</div>
            }
            @if (_claudeSuccess)
            {
                <div class="alert alert-success mt-2 py-2 small">
                    ✓ @_importedCount task importati automaticamente da Claude locale!
                </div>
            }
            @if (_coordsCreated + _coordsReused + _coordsStandalone > 0 || _coordWarnings.Count > 0)
            {
                <div class="alert alert-info mt-2 py-2 small">
                    @if (_coordsCreated > 0)
                    {
                        <div>📍 <strong>@_coordsCreated POI creati su ATAK:</strong></div>
                        <ul class="mb-1 ps-3">
                            @foreach (var p in _coordsCreatedDetails)
                            {
                                <li>@p.Name <span class="text-muted">(Template: @p.Template)</span></li>
                            }
                        </ul>
                    }
                    @if (_coordsReused > 0)
                    {
                        <div>♻️ <strong>@_coordsReused POI esistenti riutilizzati:</strong></div>
                        <ul class="mb-1 ps-3">
                            @foreach (var p in _coordsReusedDetails)
                            {
                                <li>@p.Name</li>
                            }
                        </ul>
                    }
                    @if (_coordsStandalone > 0)
                    {
                        <span class="text-warning">⚠️ @_coordsStandalone coordinate non classificate (nessun obiettivo associato). </span>
                    }
                    @foreach (var w in _coordWarnings)
                    {
                        <span class="d-block text-warning">• @w</span>
                    }
                </div>
            }
        }

        @if (_tab == 1)
        {
            <p class="text-muted small mb-2">
                Incolla qui il JSON restituito da ChatGPT, poi clicca <strong>Crea Task</strong>.
            </p>
            <textarea class="form-control font-monospace import-textarea"
                      placeholder='[ { "name": "...", "items": [...] }, { "name": "...", ... } ]'
                      @bind="_jsonText"
                      @bind:event="oninput" />
            @if (_importSuccess && !string.IsNullOrEmpty(_importError))
            {
                <div class="alert alert-warning mt-2 py-2 small">✓ @_importedCount task creati. ⚠ @_importError</div>
            }
            else if (!string.IsNullOrEmpty(_importError))
            {
                <div class="alert alert-danger mt-2 py-2 small">@_importError</div>
            }
            else if (_importSuccess)
            {
                <div class="alert alert-success mt-2 py-2 small">✓ @_importedCount task creati correttamente!</div>
            }
            @if (_coordsCreated + _coordsReused + _coordsStandalone > 0 || _coordWarnings.Count > 0)
            {
                <div class="alert alert-info mt-2 py-2 small">
                    @if (_coordsCreated > 0)
                    {
                        <div>📍 <strong>@_coordsCreated POI creati su ATAK:</strong></div>
                        <ul class="mb-1 ps-3">
                            @foreach (var p in _coordsCreatedDetails)
                            {
                                <li>@p.Name <span class="text-muted">(Template: @p.Template)</span></li>
                            }
                        </ul>
                    }
                    @if (_coordsReused > 0)
                    {
                        <div>♻️ <strong>@_coordsReused POI esistenti riutilizzati:</strong></div>
                        <ul class="mb-1 ps-3">
                            @foreach (var p in _coordsReusedDetails)
                            {
                                <li>@p.Name</li>
                            }
                        </ul>
                    }
                    @if (_coordsStandalone > 0) { <span class="text-warning">⚠️ @_coordsStandalone coordinate non classificate. </span> }
                    @foreach (var w in _coordWarnings) { <span class="d-block text-warning">• @w</span> }
                </div>
            }
            <div class="mt-3">
                <Button Color="ButtonColor.Success"
                        @onclick="ImportJson"
                        Loading="_importing"
                        LoadingText="Creazione…"
                        Disabled="@(string.IsNullOrWhiteSpace(_jsonText))">
                    <Icon Name="IconName.PlusCircle" /> Crea Task
                </Button>
            </div>
        }

    </BodyTemplate>
    <FooterTemplate>
        <Button Color="ButtonColor.Secondary" @onclick="HideAsync">Chiudi</Button>
    </FooterTemplate>
</Modal>

<style>
    .import-textarea {
        height: 320px;
        resize: vertical;
        background: #1e1e1e;
        color: #d4d4d4;
        border-color: #444;
        font-size: 0.82rem;
        line-height: 1.5;
    }
</style>

@code {
    [Parameter] public EventCallback OnTaskCreated { get; set; }
    [Parameter] public Guid? MissionId { get; set; }
    [Parameter] public string? MissionTakUid { get; set; }

    private Modal _modal = default!;
    private int _tab = 0;
    private string _rawText = string.Empty;
    private string _jsonText = string.Empty;
    private string _importError = string.Empty;
    private bool _promptCopied;
    private bool _importing;
    private bool _importSuccess;
    private List<RadioChannel> _radioChannels = new();

    private bool _sendingToClaude;
    private string _claudeError = string.Empty;
    private bool _claudeSuccess;
    private int _importedCount;

    private MissionSuite? _mission;
    private List<Team> _teams = new();
    private Guid? _selectedTeamId;
    private List<CotTemplate> _templates = new();
    private string _aiPromptTemplate = string.Empty;

    private int _coordsCreated;
    private int _coordsReused;
    private int _coordsStandalone;
    private List<string> _coordWarnings = new();

    private record PoiDetail(string Name, string Template);
    private List<PoiDetail> _coordsCreatedDetails = new();
    private List<PoiDetail> _coordsReusedDetails = new();

    public async Task ShowAsync()
    {
        _radioChannels = await radioChannelService.GetAllAsync();
        _teams = (await teamService.GetAllAsync()).OrderBy(t => t.Name).ToList();
        _templates = await CotTemplateService.GetAllAsync();
        var settings = await SettingsService.GetOrCreateAsync();
        _aiPromptTemplate = settings.AiPromptTemplate ?? string.Empty;

        if (MissionId.HasValue)
        {
            _mission = await missionService.GetAsync(MissionId.Value);
            _selectedTeamId = _mission?.TeamId;
        }

        await _modal.ShowAsync();
    }
    public async Task HideAsync() => await _modal.HideAsync();

    private void OnHidden()
    {
        _tab = 0;
        _rawText = string.Empty;
        _jsonText = string.Empty;
        _importError = string.Empty;
        _promptCopied = false;
        _importSuccess = false;
        _claudeError = string.Empty;
        _claudeSuccess = false;
        _importedCount = 0;
        _coordsCreated = 0;
        _coordsReused = 0;
        _coordsStandalone = 0;
        _coordWarnings = new();
        _coordsCreatedDetails = new();
        _coordsReusedDetails = new();
    }

    private async Task GeneratePrompt()
    {
        var prompt = BuildPrompt2(_rawText.Trim(), _radioChannels, _templates);
        await JS.InvokeVoidAsync("copyToClipboard", prompt);
        _promptCopied = true;
    }

    private async Task SendToClaudeCliAsync()
    {
        if (string.IsNullOrWhiteSpace(_rawText)) return;

        _sendingToClaude = true;
        _claudeError = string.Empty;
        _claudeSuccess = false;
        _importError = string.Empty;
        _importSuccess = false;
        _coordsCreated = 0; _coordsReused = 0; _coordsStandalone = 0; _coordWarnings = new();
        _coordsCreatedDetails = new(); _coordsReusedDetails = new();
        StateHasChanged();

        try
        {
            var prompt = BuildPrompt2(_rawText.Trim(), _radioChannels, _templates);

            var psi = new ProcessStartInfo
            {
                FileName = "claude",
                Arguments = "-p",
                RedirectStandardInput = true,
                RedirectStandardOutput = true,
                RedirectStandardError = true,
                UseShellExecute = false,
                CreateNoWindow = true,
                StandardInputEncoding = System.Text.Encoding.UTF8,
                StandardOutputEncoding = System.Text.Encoding.UTF8,
                StandardErrorEncoding = System.Text.Encoding.UTF8,
            };

            using var process = Process.Start(psi);
            if (process == null)
            {
                _claudeError = "Impossibile avviare 'claude'. Verifica che Claude Code CLI sia installato e nel PATH di sistema.";
                return;
            }

            await process.StandardInput.WriteAsync(prompt);
            process.StandardInput.Close();

            using var cts = new System.Threading.CancellationTokenSource(TimeSpan.FromSeconds(120));
            var outputTask = process.StandardOutput.ReadToEndAsync(cts.Token);
            var errorTask  = process.StandardError.ReadToEndAsync(cts.Token);

            await Task.WhenAll(outputTask, errorTask);
            await process.WaitForExitAsync(cts.Token);

            var output = await outputTask;
            var stderr = await errorTask;

            if (process.ExitCode != 0 && string.IsNullOrWhiteSpace(output))
            {
                _claudeError = $"Claude CLI ha terminato con errore (exit {process.ExitCode}): {stderr}";
                return;
            }

            _jsonText = StripJsonFences(output.Trim());

            if (string.IsNullOrWhiteSpace(_jsonText))
            {
                _claudeError = $"Claude CLI ha restituito una risposta vuota.{(string.IsNullOrEmpty(stderr) ? "" : $" Stderr: {stderr}")}";
                return;
            }

            await ImportJson();

            if (_importSuccess)
            {
                _claudeSuccess = true;
                _claudeError = string.Empty;
            }
            else
            {
                _tab = 1;
                if (string.IsNullOrEmpty(_importError))
                    _importError = "Controlla il JSON generato e clicca 'Crea Task'.";
            }
        }
        catch (OperationCanceledException)
        {
            _claudeError = "Timeout: Claude CLI non ha risposto entro 120 secondi.";
        }
        catch (Exception ex) when (ex.Message.Contains("The system cannot find") || ex.Message.Contains("No such file"))
        {
            _claudeError = "Comando 'claude' non trovato. Verifica che Claude Code CLI sia installato e nel PATH.";
        }
        catch (Exception ex)
        {
            _claudeError = $"Errore: {ex.Message}";
        }
        finally
        {
            _sendingToClaude = false;
        }
    }

    private static string StripJsonFences(string text)
    {
        var t = text.Trim();
        if (t.StartsWith("```json", StringComparison.OrdinalIgnoreCase))
            t = t[7..].TrimStart();
        else if (t.StartsWith("```"))
            t = t[3..].TrimStart();
        if (t.EndsWith("```"))
            t = t[..^3].TrimEnd();
        t = t.Trim();

        // Preferisce il tipo di struttura che compare prima nel testo
        var objStart = t.IndexOf('{');
        var arrStart = t.IndexOf('[');

        if (objStart >= 0 && (arrStart < 0 || objStart < arrStart))
        {
            var objEnd = t.LastIndexOf('}');
            if (objEnd > objStart) return t[objStart..(objEnd + 1)].Trim();
        }

        if (arrStart >= 0)
        {
            var arrEnd = t.LastIndexOf(']');
            if (arrEnd > arrStart) return t[arrStart..(arrEnd + 1)].Trim();
        }

        return t;
    }
    private string BuildPrompt2(string text, List<RadioChannel> channels, List<CotTemplate> cotTemplates)
    {
        // Base prompt: use DB setting or default role description
        var basePrompt = string.IsNullOrWhiteSpace(_aiPromptTemplate)
            ? "Sei un assistente per la pianificazione tattica. Analizza il testo seguente ed estrai TUTTI gli obiettivi/task presenti."
            : _aiPromptTemplate.Replace("{{INPUT}}", "").Trim();

        // Channels
        var channelList = channels?.Count > 0
            ? string.Join(", ", channels.OrderBy(c => c.Name).Select(c => $"\"{c.Name}\""))
            : "nessun canale disponibile";

        // COT templates
        var templateTitles = cotTemplates?.Count > 0
            ? string.Join(", ", cotTemplates.Select(t => $"\"{t.Title}\""))
            : "\"EMPTY\"";

        var templateRules = cotTemplates?.Count > 0
            ? string.Join("\n", cotTemplates.Select(t =>
                $"- {t.Title}{(t.IsPrimary ? " ⭐ [PRIMARIO]" : "")}: {t.Description}")) +
              "\n- EMPTY: nessun template corrisponde"
            : "- EMPTY: nessun template disponibile";

        // ATAK colors
        var colorList = string.Join(", ", ATAKHelper.ATAKPredefinedColors.Select(c => $"\"{c.Name}\""));

        // Coord examples using real template titles
        var t0 = cotTemplates?.Count > 0 ? cotTemplates[0].Title : "EMPTY";
        var t1 = cotTemplates?.Count > 1 ? cotTemplates[1].Title : "EMPTY";

        var coordExample = $"{{ \"name\": \"OBJ ECHO\", \"coordinate\": \"32T 373313 4992906\", \"template\": \"{t0}\" }}";

        var multiCoordExample =
            "(Esempio multi-coordinata):\n" +
            "\"coordinates\": [\n" +
            $"  {{ \"name\": \"OBJ FOXTROT\", \"coordinate\": \"32T 372714 4992403\", \"template\": \"{t0}\" }},\n" +
            $"  {{ \"name\": \"IN FOXTROT\",  \"coordinate\": \"32T 372841 4992352\", \"template\": \"{t1}\" }},\n" +
            "  { \"name\": \"DZ FOXTROT\",  \"coordinate\": \"32T 372799 4992282\", \"template\": \"EMPTY\" }\n" +
            "]";

        var format =
            "{\n" +
            "  \"tasks\": [\n" +
            "    {\n" +
            "      \"name\": \"titolo breve del task\",\n" +
            "      \"sottotitolo\": \"sottotitolo opzionale\",\n" +
            "      \"tipologiaObiettivo\": \"tipo di obiettivo (es: A+E, E, I)\",\n" +
            "      \"durata\": 30,\n" +
            "      \"radioChannel\": \"nome canale dalla lista o null\",\n" +
            "      \"description\": \"descrizione estesa in markdown\",\n" +
            "      \"color\": \"nome colore ATAK dalla lista o null\",\n" +
            "      \"coordinates\": [\n" +
            $"        {coordExample}\n" +
            "      ],\n" +
            "      \"items\": [\n" +
            "        { \"type\": \"Info\",   \"value\": \"informazione importante\" },\n" +
            "        { \"type\": \"Note\",   \"value\": \"nota di attenzione\" },\n" +
            "        { \"type\": \"Action\", \"value\": \"azione operativa da eseguire\" }\n" +
            "      ]\n" +
            "    }\n" +
            "  ],\n" +
            "  \"standalone_coords\": [\n" +
            "    { \"nome\": \"WP EXTRA\", \"coordinate\": \"32T 123456 4500000\", \"template\": \"EMPTY\" }\n" +
            "  ]\n" +
            "}\n\n" +
            multiCoordExample;

        return
            basePrompt + "\n\n" +
            "=== CANALI RADIO DISPONIBILI ===\n" +
            channelList + "\n\n" +
            "=== TEMPLATE COT (classificazione punti TAK) ===\n" +
            templateRules + "\n" +
            $"Usa SOLO questi template: [{templateTitles}] oppure \"EMPTY\". NON inventare template, NON usare sinonimi.\n\n" +
            "=== COLORI ATAK DISPONIBILI ===\n" +
            colorList + "\n\n" +
            "=== FORMATO OUTPUT ATTESO ===\n" +
            "Restituisci SOLO il JSON puro (senza markdown, senza backtick, senza spiegazioni):\n" +
            format + "\n\n" +
            "Regole:\n" +
            "- Restituisci SEMPRE la struttura completa, anche se c’è un solo obiettivo\n" +
            "- Ogni obiettivo nel testo → un elemento dell’array tasks\n" +
            "- \"type\" negli items: SOLO Info, Note, Action\n" +
            "- \"durata\": numero intero (minuti stimati)\n" +
            "- \"description\": può contenere markdown\n" +
            "- \"radioChannel\": scegli dalla lista canali, oppure null\n" +
            "- \"color\": scegli dalla lista colori ATAK, oppure null\n" +
            "- \"template\" nelle coordinate: titolo esatto dalla lista oppure \"EMPTY\" — NON inventare\n" +
            "- \"coordinate\": copia il testo ESATTAMENTE come appare, NON convertire\n" +
            "- \"nome\" coordinate: max 20 caratteri, basato sul contesto\n" +
            "- Coordinate senza obiettivo associato → standalone_coords\n" +
            "- Se non ci sono coordinate: \"coordinates\":[] e \"standalone_coords\":[]\n" +
            "- Rispondi SOLO con JSON puro\n\n" +
            "=== TESTO DA ANALIZZARE ===\n" +
            text;
    }

    private async Task ImportJson()
    {
        _importError = string.Empty;
        _importSuccess = false;
        _importedCount = 0;
        _coordsCreated = 0; _coordsReused = 0; _coordsStandalone = 0; _coordWarnings = new();
        _coordsCreatedDetails = new(); _coordsReusedDetails = new();
        _importing = true;
        StateHasChanged();
        try
        {
            var options = new JsonSerializerOptions { PropertyNameCaseInsensitive = true };
            var json = _jsonText.Trim();

            List<TaskImportDto> dtos;
            List<CoordDto> standaloneCoords = new();

            if (json.StartsWith('{'))
            {
                // Nuovo formato: { tasks: [...], standalone_coords: [...] }
                var wrapper = JsonSerializer.Deserialize<ImportWrapper>(json, options);
                dtos = wrapper?.Tasks ?? new();
                standaloneCoords = wrapper?.StandaloneCoords ?? new();
            }
            else if (json.StartsWith('['))
            {
                dtos = JsonSerializer.Deserialize<List<TaskImportDto>>(json, options)
                       ?? new List<TaskImportDto>();
            }
            else
            {
                _importError = "JSON non valido: deve iniziare con { o [.";
                return;
            }

            dtos = dtos.Where(d => !string.IsNullOrWhiteSpace(d.Name)).ToList();
            if (dtos.Count == 0)
            {
                _importError = "JSON non valido o nessun campo 'name' trovato.";
                return;
            }

            // Carica TUTTI i punti con coordinate dalla missione (usati per deduplicazione per prossimità)
            var existingPoints = new List<TAKSuite.Data.ServicesTak.TakPoint>();
            if (!string.IsNullOrEmpty(MissionTakUid))
            {
                try
                {
                    existingPoints = await WaypointService.GetAllMissionPointsAsync(MissionTakUid);
                }
                catch (Exception ex) { _coordWarnings.Add($"Impossibile caricare punti esistenti da ATAK: {ex.Message}"); }
            }

            var warnings = new List<string>();
            int saved = 0;

            foreach (var dto in dtos)
            {
                Guid? radioChannelId = null;
                if (!string.IsNullOrWhiteSpace(dto.RadioChannel))
                {
                    var channelName = dto.RadioChannel.Trim();
                    var match = _radioChannels.FirstOrDefault(r =>
                        string.Equals(r.Name, channelName, StringComparison.OrdinalIgnoreCase))
                        ?? _radioChannels.FirstOrDefault(r =>
                        r.Name.Contains(channelName, StringComparison.OrdinalIgnoreCase))
                        ?? _radioChannels.FirstOrDefault(r =>
                        channelName.Contains(r.Name, StringComparison.OrdinalIgnoreCase));

                    if (match != null)
                        radioChannelId = match.Id;
                    else
                        warnings.Add($"Canale \"{channelName}\" non trovato per il task \"{dto.Name}\".");
                }

                var task = new TaskEntity
                {
                    Name = dto.Name.Trim(),
                    Sottotitolo = dto.Sottotitolo?.Trim() ?? string.Empty,
                    TipologiaObiettivo = dto.TipologiaObiettivo?.Trim() ?? string.Empty,
                    Durata = dto.Durata,
                    RadioChannelId = radioChannelId,
                    MissionTAKSuiteId = MissionId,
                    AssignedTeamId = _selectedTeamId,
                    Description = dto.Description?.Trim() ?? string.Empty,
                    CreationDate = DateTime.UtcNow,
                    LastModified = DateTime.UtcNow,
                    Status = TaskStatusTak.Created
                };

                if (dto.Items != null)
                {
                    int order = 0;
                    foreach (var item in dto.Items)
                    {
                        if (string.IsNullOrWhiteSpace(item.Value)) continue;
                        if (!Enum.TryParse<TaskStringItemType>(item.Type, true, out var itemType)) continue;
                        task.Items.Add(new TaskStringItem
                        {
                            Type = itemType,
                            Value = item.Value.Trim(),
                            Order = order++
                        });
                    }
                }

                var created = await taskService.AddAsync(task);
                if (created == null)
                {
                    warnings.Add($"Errore nel salvataggio del task \"{dto.Name}\".");
                    continue;
                }
                saved++;

                // Sincronizzazione coordinate con ATAK
                if (!string.IsNullOrEmpty(MissionTakUid) && dto.Coordinates?.Count > 0)
                {
                    var validCoords = dto.Coordinates
                        .Where(c => !string.IsNullOrWhiteSpace(c.ResolvedRaw) || c.Lat != 0 || c.Lon != 0)
                        .ToList();

                    string? primaryPoiUid = null;
                    string? primaryPoiName = null;
                    Guid? primaryTemplateId = null;
                    var poiLinks = new List<TaskPoiLink>();

                    foreach (var coord in validCoords)
                    {
                        var callsign = coord.ResolvedCallsign(dto.Name.Trim());
                        var rawCoord  = coord.ResolvedRaw;

                        if (dto.Color is not null) coord.Color = ATAKHelper.ATAKPredefinedColors.Where(_ => _.Name.ToLower() == dto.Color.ToLower()).FirstOrDefault()?.Argb;


                        try
                        {
                            double lat, lon;
                            if (!string.IsNullOrWhiteSpace(rawCoord))
                            {
                                if (!GeoUtils.TryParseCoordinate(rawCoord, out lat, out lon))
                                {
                                    warnings.Add($"Impossibile convertire coordinata \"{rawCoord}\" per \"{callsign}\".");
                                    continue;
                                }
                            }
                            else
                            {
                                lat = coord.Lat;
                                lon = coord.Lon;
                            }

                            coord.Lat = lat;
                            coord.Lon = lon;
                            coord.Callsign = callsign;

                            coord.Radio = dto.RadioChannel;
                            coord.Durata = dto.Durata;
                            coord.Tipo = dto.TipologiaObiettivo;



                            string poiUid;
                            Guid? usedTemplateId = null;
                            Data.Models.CotTemplate? resolvedTemplate = null;
                            var nearbyPoint = existingPoints
                                .FirstOrDefault(p => GeoUtils.ArePointsClose(p.Lat, p.Lon, lat, lon, 10.0));
                            if (nearbyPoint != null)
                            {
                                poiUid = nearbyPoint.Uid;
                                _coordsReused++;
                                _coordsReusedDetails.Add(new PoiDetail(callsign, "esistente"));
                            }
                            else
                            {
                                string? newUid = null;

                                // Risolvi template: prima UUID legacy, poi titolo stringa (nuovo formato)
                                if (!string.IsNullOrEmpty(coord.TemplateId) &&
                                    Guid.TryParse(coord.TemplateId, out var tmplGuid))
                                {
                                    resolvedTemplate = _templates.FirstOrDefault(t => t.Id == tmplGuid);
                                }
                                else if (!string.IsNullOrEmpty(coord.Template) &&
                                         !string.Equals(coord.Template, "EMPTY", StringComparison.OrdinalIgnoreCase))
                                {
                                    var tName = coord.Template.Trim();
                                    // Exact match, poi partial (es. "IN/OUT" trova "IN" e viceversa)
                                    resolvedTemplate =
                                        _templates.FirstOrDefault(t => string.Equals(t.Title, tName, StringComparison.OrdinalIgnoreCase))
                                        ?? _templates.FirstOrDefault(t => t.Title.Contains(tName, StringComparison.OrdinalIgnoreCase))
                                        ?? _templates.FirstOrDefault(t => tName.Contains(t.Title, StringComparison.OrdinalIgnoreCase));

                                    if (resolvedTemplate == null)
                                    {
                                        var available = _templates.Count > 0
                                            ? "Titoli disponibili: " + string.Join(", ", _templates.Select(t => $"\"{t.Title}\""))
                                            : "Nessun template configurato in Impostazioni › Template COT";
                                        warnings.Add($"⚠ Template \"{tName}\" non trovato per \"{callsign}\" → punto bianco. {available}.");
                                    }
                                }

                                if (resolvedTemplate != null)
                                {
                                    var dicName = ToLowerDictionary(coord);
                                    
                                    newUid = await CoTManager.CreateFromTemplateAsync(
                                        resolvedTemplate, MissionTakUid,dicName);
                                    if (!string.IsNullOrEmpty(newUid))
                                        usedTemplateId = resolvedTemplate.Id;
                                }

                                if (string.IsNullOrEmpty(newUid))
                                    newUid = await CoTManager.CreateAndPublishPoiAsync(
                                        MissionTakUid, callsign, PoiType.Spotmap, lat, lon);

                                if (string.IsNullOrEmpty(newUid))
                                {
                                    warnings.Add($"Impossibile creare POI \"{callsign}\" su ATAK.");
                                    continue;
                                }
                                poiUid = newUid;
                                existingPoints.Add(new TAKSuite.Data.ServicesTak.TakPoint(poiUid, callsign, lat, lon));
                                _coordsCreated++;
                                var tmplLabel = resolvedTemplate?.Title ?? (!string.IsNullOrEmpty(coord.Template) ? coord.Template : "bianco");
                                _coordsCreatedDetails.Add(new PoiDetail(callsign, tmplLabel));
                            }

                            // Primario: template marcato IsPrimary nel DB, oppure Primary==true (legacy), oppure primo in assoluto
                            bool isPrimary = (resolvedTemplate?.IsPrimary == true && primaryPoiUid == null)
                                             || (coord.Primary == true && primaryPoiUid == null)
                                             || primaryPoiUid == null;
                            if (isPrimary)
                            {
                                primaryPoiUid = poiUid;
                                primaryPoiName = callsign;
                                primaryTemplateId = usedTemplateId;
                            }

                            var role = !string.IsNullOrEmpty(coord.Template) ? coord.Template
                                     : !string.IsNullOrEmpty(coord.Label)    ? coord.Label
                                     : isPrimary ? "Principale" : "Secondario";

                            poiLinks.Add(new TaskPoiLink
                            {
                                Uid = poiUid,
                                Name = callsign,
                                IsPrimary = isPrimary,
                                Role = role,
                                TemplateId = usedTemplateId
                            });
                        }
                        catch (Exception ex)
                        {
                            warnings.Add($"Errore POI \"{callsign}\": {ex.Message}");
                        }
                    }

                    if (primaryPoiUid != null)
                    {
                        created.PoiUid = primaryPoiUid;
                        created.PoiName = primaryPoiName;
                        created.MissionUid = MissionTakUid;
                        created.PoiLinks = poiLinks;
                        await taskService.UpdateAsync(created);
                    }
                }
            }

            // Coordinate standalone (non associate a nessun obiettivo)
            foreach (var coord in standaloneCoords.Where(c => !string.IsNullOrWhiteSpace(c.ResolvedRaw) || c.Lat != 0 || c.Lon != 0))
            {
                _coordsStandalone++;
            }

            if (saved > 0)
            {
                _importSuccess = true;
                _importedCount = saved;
                _jsonText = string.Empty;
                if (warnings.Count > 0)
                    _importError = string.Join(" ", warnings);
                _coordWarnings.AddRange(warnings.Except(_coordWarnings));
                await OnTaskCreated.InvokeAsync();
            }
            else
            {
                _importError = "Nessun task salvato. " + string.Join(" ", warnings);
            }
        }
        catch (JsonException ex)
        {
            _importError = $"Errore nel parsing JSON: {ex.Message}";
        }
        catch (Exception ex)
        {
            _importError = $"Errore: {ex.Message}";
        }
        finally
        {
            _importing = false;
        }
    }


    
    public static Dictionary<string, object> ToLowerDictionary(object dto)
    {
        if (dto == null)
            throw new ArgumentNullException(nameof(dto));

        var result = new Dictionary<string, object>();

        var properties = dto.GetType()
                            .GetProperties(BindingFlags.Public | BindingFlags.Instance)
                            .Where(p => p.CanRead);

        foreach (var prop in properties)
        {
            var key = prop.Name.ToLowerInvariant();
            var value = prop.GetValue(dto);

            result[key] = value; // nessuna conversione
        }

        return result;
    }


