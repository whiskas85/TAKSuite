    private async Task<IEnumerable<NavItem>> RetrieveAllMissions(IList<NavItem> navItems, string listTitle)
    {
        var parentId = navItems.FirstOrDefault(x => x.Text == listTitle)?.Id;
        if (parentId == null) return navItems;

        navItems.Add(new NavItem
        {
            Id = $"{parentId}.list",
            Href = "/missionstaksuite",
            IconName = IconName.ListNested,
            Text = "Lista missioni",
            ParentId = parentId
        });
        navItems.Add(new NavItem
            {
                Id = $"{parentId}.datasync",
                Href = "/datasync",
                IconName = IconName.ArrowRepeat,
                Text = "DataSync Mission",
                ParentId = parentId
        });

        var missions = await MissionSuiteService.GetAllAsync();
        var allTasks = await TaskService.GetAllAsync();
        var tasksByMission = allTasks
            .Where(t => t.MissionTAKSuiteId.HasValue)
            .GroupBy(t => t.MissionTAKSuiteId!.Value)
            .ToDictionary(g => g.Key, g => g.OrderBy(t => t.Name).ToList());

        foreach (var mission in missions.OrderBy(m => m.Name))
        {
            var missionMenuId = $"{parentId}.{mission.Id}";
            navItems.Add(new NavItem
            {
                Id = missionMenuId,
                Href = "",
                IconName = IconName.MapFill,
                Text = mission.Name,
                ParentId = parentId
            });
            navItems.Add(new NavItem
            {
                Id = $"{missionMenuId}.ops",
                Href = $"/missiontak/{mission.Id}",
                IconName = IconName.Activity,
                Text = "Operativo",
                ParentId = missionMenuId
            });
            navItems.Add(new NavItem
            {
                Id = $"{missionMenuId}.cfg",
                Href = $"/missionedit/{mission.Id}",
                IconName = IconName.GearFill,
                Text = "Configura",
                ParentId = missionMenuId
            });
            navItems.Add(new NavItem
            {
                Id = $"{missionMenuId}.parking",
                Href = $"/missiontak/{mission.Id}/parking",
                IconName = IconName.PCircleFill,
                Text = "Parking",
                ParentId = missionMenuId
            });
            navItems.Add(new NavItem
            {
                Id = $"{missionMenuId}.waypoints",
                Href = $"/missiontak/{mission.Id}/waypoints",
                IconName = IconName.PinAngleFill,
                Text = "Waypoints",
                ParentId = missionMenuId
            });
            navItems.Add(new NavItem
            {
                Id = $"{missionMenuId}.wpSimple",
                Href = $"/missiontak/{mission.Id}/waypoints-simple",
                IconName = IconName.PinFill,
                Text = "WP Simple",
                ParentId = missionMenuId
            });

            if (tasksByMission.TryGetValue(mission.Id, out var tasks))
            {
                int i = 0;
                foreach (var task in tasks)
                {
                    var taskMenuId = $"{missionMenuId}.t{i++}";
                    navItems.Add(new NavItem
                    {
                        Id = taskMenuId,
                        Href = "",
                        IconName = IconName.CheckSquareFill,
                        Text = task.Name,
                        ParentId = missionMenuId
                    });
                    navItems.Add(new NavItem
                    {
                        Id = $"{taskMenuId}.ops",
                        Href = $"/taskdetail/{task.Id}",
                        IconName = IconName.Activity,
                        Text = "Operativo",
                        ParentId = taskMenuId
                    });
                    navItems.Add(new NavItem
                    {
                        Id = $"{taskMenuId}.cfg",
                        Href = $"/taskedit/{task.Id}",
                        IconName = IconName.GearFill,
                        Text = "Configura",
                        ParentId = taskMenuId
                    });
                    navItems.Add(new NavItem
                    {
                        Id = $"{taskMenuId}.edi",
                        Href = $"/objeditor/{task.Id}",
                        IconName = IconName.FileEarmarkCode,
                        Text = "Editor HTML",
                        ParentId = taskMenuId
                    });
                }
            }
        }

        return navItems;
    }


    private async Task<IEnumerable<NavItem>> RetrieveAllTeams(IList<NavItem> navItems, string teamsTitle)
    {
        var id = navItems.FirstOrDefault(x => x.Text == teamsTitle)?.Id;
        if (id != null)
        {
            // if (ConnectedAtakUser == null) 
            //     return new List<NavItem>();
            // if (ConnectedAtakUser.Team == null)
            //     return new List<NavItem>();

            // var teams = await TeamService.GetSubTeamsAsync(ConnectedAtakUser.Team, true);
            var teams = await TeamService.GetAllAsync();

            foreach (var team in teams)
            {
                var teamMenuid = $"{id}.{team.Id}";
                var hrefBase = $"/team/{team.Id}";

                navItems.Add(new NavItem { Id = teamMenuid, Href = $"/team/{team.Id}/details", IconName = IconName.PeopleFill, Text = team.Name, ParentId = id });

                int counter = 0;
                // navItems.Add(new NavItem { Href = $"{hrefBase}", Text = "Pagina old", IconName = IconName.PeopleFill, ParentId = teamMenuid, Id = $"{id}.{team.Id}.{counter++}" });
                navItems.Add(new NavItem { Href = $"{hrefBase}/details", Text = "Dettagli", IconName = IconName.HouseFill, ParentId = teamMenuid, Id = $"{id}.{team.Id}.{counter++}" });
                navItems.Add(new NavItem { Href = $"{hrefBase}/comms", Text = "Comunicazioni", IconName = IconName.Headset, ParentId = teamMenuid, Id = $"{id}.{team.Id}.{counter++}" });
                navItems.Add(new NavItem { Href = $"{hrefBase}/operators", Text = "Operatori", IconName = IconName.PersonFill, ParentId = teamMenuid, Id = $"{id}.{team.Id}.{counter++}" });
                navItems.Add(new NavItem { Href = $"{hrefBase}/documentation", Text = "Documentazione", IconName = IconName.FileTypeDoc, ParentId = teamMenuid, Id = $"{id}.{team.Id}.{counter++}" });
                navItems.Add(new NavItem { Href = $"{hrefBase}/tasks", Text = "Tasks", IconName = IconName.FileTypeDoc, ParentId = teamMenuid, Id = $"{id}.{team.Id}.{counter++}" });
                navItems.Add(new NavItem { Href = $"{hrefBase}/tasks/inprogress", Text = "Task in progress", IconName = IconName.FileTypeDoc, ParentId = teamMenuid, Id = $"{id}.{team.Id}.{counter++}" });
                navItems.Add(new NavItem { Href = $"{hrefBase}/parkings", Text = "Parking", IconName = IconName.PCircleFill, ParentId = teamMenuid, Id = $"{id}.{team.Id}.{counter++}" });
                navItems.Add(new NavItem { Href = $"{hrefBase}/waypoints", Text = "Waypoint", IconName = IconName.PinAngleFill, ParentId = teamMenuid, Id = $"{id}.{team.Id}.{counter++}" });

            }
        }
        return navItems;
    }











    private string? currentUrl;

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
    }
    protected override void OnInitialized()
    {
        currentUrl = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        NavigationManager.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        currentUrl = NavigationManager.ToBaseRelativePath(e.Location);
        StateHasChanged();
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }
