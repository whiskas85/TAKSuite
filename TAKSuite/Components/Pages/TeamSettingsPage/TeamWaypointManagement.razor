@page "/team/{TeamId:guid}/waypoints"
@inherits ConnectedUserInfo

@rendermode InteractiveServer

@using System.ComponentModel.DataAnnotations
@using TAKSuite.Components.Layout
@using TAKSuite.Components.Pages.Attachment
@using TAKSuite.Data
@using TAKSuite.Data.Models
@using TAKSuite.Data.ModelsTak
@using TAKSuite.Data.Services
@using TAKSuite.Data.ServicesTak
@using TAKSuite.Helper
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@using TAKSuite.TAK.CoT
@using TAKSuite.TAK.Helper


@inject TeamService TeamService;
@inject WaypointService WaypointService

@inject IJSRuntime JS
@inject TAKSuite.Helpers.JsInteropHelper JsHelper
@inject ToastService ToastService;
@inject NavigationManager NavigationManager
@inject CoTManager CoTManager
@inject AttachmentService AttachmentService

<style>
    .icon-header {
    width: 50px;
    }
</style>
<script>
    function copyToClipboard(text) {
    navigator.clipboard.writeText(text).then(() => {
    console.log("Testo copiato: " + text);
    }).catch(err => {
    console.error("Errore nella copia:", err);
    });
    }
</script>

<PageTitle>Waypoint</PageTitle>
<h3>Waypoint</h3>
<p>In questa schermata ci sono tutti i waypoint</p>


<Modal @ref="_uploadModal" Title="Allega file" Size="ModalSize.Regular">
    <BodyTemplate>
        <InputFile OnChange="OnUploadFileSelected" class="form-control" />
    </BodyTemplate>
    <FooterTemplate>
        <Button Color="ButtonColor.Primary" @onclick="ConfirmUploadAsync" Disabled="_uploading">
            @if (_uploading) { <text>Caricamento...</text> } else { <text>Allega</text> }
        </Button>
        <Button Color="ButtonColor.Secondary" @onclick="() => _uploadModal.HideAsync()">Annulla</Button>
    </FooterTemplate>
</Modal>

<Modal @ref="modal" Title="Lista allegati" OnHidden="OnModalHidden" Size="ModalSize.Large">
    <BodyTemplate>
        <AttachmentListGrid Item="itemAttach" MissionUid="@team?.MissionUid"></AttachmentListGrid>


    </BodyTemplate>
    <FooterTemplate>
        <Button Color="ButtonColor.Primary" @onclick="OnHideModalClick">Chiudi</Button>
    </FooterTemplate>
</Modal>



<Grid @ref="grid"
TItem="Waypoint"
Class="table table-hover"
HeaderRowCssClass="bg-success text-white border-bottom-0 h5"
FiltersRowCssClass="bg-success text-white bg-opacity-25 border-bottom-0"

Data="list"
AllowFiltering="false"
AllowPaging="false"
PageSize="20"
AllowSorting="true"
AllowSelection="false"
SelectionMode="GridSelectionMode.Multiple"
SelectedItemsChanged="OnSelectedItemsChanged"
Unit="Unit.Px"
Responsive="true">
    <GridColumns>
        <GridColumn TItem="Waypoint" HeaderText="" class="align-middle icon-header">
            <TAKSuite.Components.Pages.Components.IconComponent Component="context" IconName="circle" />
            @* <Icon Name="IconName.CircleFill"  Color="IconColor.Primary" /> *@
        </GridColumn>
        <GridColumn TItem="Waypoint" HeaderText="Callsign" Class="align-middle" SortKeySelector="item => item.Callsign">
            @context.Callsign
        </GridColumn>
        <GridColumn TItem="Waypoint" HeaderText="Ultima modifica" Class="align-middle" SortKeySelector="item => item.LastUpdateTime">
            @context.LastUpdateTime
        </GridColumn>
        <GridColumn TItem="Waypoint" HeaderText="Lat" Class="align-middle">
            @context.Lat
        </GridColumn>
        <GridColumn TItem="Waypoint" HeaderText="Lon" Class="align-middle">
            @context.Lon
        </GridColumn>
        <GridColumn TItem="Waypoint" HeaderText="Completa WP">
            @if (context.Color != ATAKHelper.COLOR_WAYPOINT_COMPLETED)
            {
                <Button @onclick="()=> CompleteWaypoint(context)"><Icon Name="IconName.Check" Color="IconColor.Success"></Icon></Button>
            }
        </GridColumn>
        <GridColumn TItem="Waypoint" HeaderText="Allega documentazione">
            <Button @onclick="()=> UploadAttachmentWaypoint(context)"><Icon Name="IconName.Upload" Color="IconColor.Primary"></Icon></Button>
            <Button @onclick="()=> GetAttachmentWaypoint(context)" Position="Position.Relative">
                <Icon Name="IconName.Paperclip" Color="IconColor.Secondary"></Icon>
                @if (context.AttachmentUidList.Count > 0)
                {
                    <Badge Color="BadgeColor.Danger"
                    Position="Position.Absolute"
                    Placement="BadgePlacement.TopRight"
                    IndicatorType="BadgeIndicatorType.RoundedPill"
                    VisuallyHiddenText="unread messages">@context.AttachmentUidList.Count</Badge>
                }
            </Button>
        </GridColumn>

    </GridColumns>
</Grid>


@code {
    [Parameter]public Guid TeamId { get; set; }

    private List<Waypoint> list = new();
    Grid<Waypoint> grid = default!;
    private Team team;

    private Modal _uploadModal = default!;
    private IBrowserFile? _uploadFile;
    private Waypoint? _uploadWaypoint;
    private bool _uploading;

    private string GetColor(IColoredCoT item)
    {
        var color = Helper.ColorConverterHelper.ArgbToHex(item.Color.Value);
        if (color.ToLower() == "#ffffff")
            color = "#000000";
        return color;
    }


    private async Task NavigateToCounterComponent(Waypoint item)
    {
        var url = $"https://www.google.com/maps?q={item.Lat.ToString().Replace(",", ".")},{item.Lon.ToString().Replace(",", ".")}";
        await JsHelper.OpenInNewTab(url);
    }


    private Task OnSelectedItemsChanged(HashSet<Waypoint> codes)
    {
        var selecteCodes = codes is not null && codes.Any() ? codes : new();
        return Task.CompletedTask;
    }


    protected override async Task OnParametersSetAsync()
    {
        await base.OnParametersSetAsync();
        team = await TeamService.GetAsync(TeamId);

        await RefreshData();
        StateHasChanged();
    }
    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
    }
    protected async Task RefreshData()
    {
        if (team == null || string.IsNullOrEmpty(team.MissionUid)) return;
        list = await WaypointService.GetAllWaypointsAsync(team.MissionUid);
    }
    private async Task CompleteWaypoint(Waypoint item)
    {
        await CoTManager.ChangeCotColor(team?.MissionUid ?? string.Empty, item.Uid, ATAKHelper.COLOR_WAYPOINT_COMPLETED);
        await RefreshData();
        await grid.RefreshDataAsync();

        StateHasChanged();
    }



    private Modal modal = default!;
    private Waypoint itemAttach = default!;

    private async Task OnModalHidden()
    {
        itemAttach = null;
        StateHasChanged();
    }
    private async Task OnHideModalClick()
    {
        await modal.HideAsync();
    }
    private async Task GetAttachmentWaypoint(Waypoint item)
    {
        itemAttach = item;
        StateHasChanged();
        await modal.ShowAsync();
    }

    private async Task UploadAttachmentWaypoint(Waypoint item)
    {
        _uploadWaypoint = item;
        _uploadFile = null;
        await _uploadModal.ShowAsync();
    }

    private void OnUploadFileSelected(InputFileChangeEventArgs e) => _uploadFile = e.File;

    private async Task ConfirmUploadAsync()
    {
        if (_uploadFile == null || _uploadWaypoint == null) return;
        _uploading = true;
        try
        {
            using var ms = new System.IO.MemoryStream();
            await _uploadFile.OpenReadStream(maxAllowedSize: 20 * 1024 * 1024).CopyToAsync(ms);
            var ct = string.IsNullOrEmpty(_uploadFile.ContentType) ? "application/octet-stream" : _uploadFile.ContentType;
            var ok = await AttachmentService.UploadToCotAsync(_uploadWaypoint.Uid, ms.ToArray(), _uploadFile.Name, ct);
            if (ok)
            {
                ToastService.Notify(new(ToastType.Success, "Allegato", "File allegato con successo."));
                await _uploadModal.HideAsync();
            }
            else
            {
                ToastService.Notify(new(ToastType.Danger, "Errore", "Impossibile allegare il file."));
            }
        }
        finally { _uploading = false; }
    }






}