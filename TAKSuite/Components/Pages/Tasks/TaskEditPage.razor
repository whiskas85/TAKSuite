@page "/taskedit/{TaskId:guid}"
@attribute [Authorize]
@* @inherits ConnectedUserInfo *@
@implements IDisposable
@using Microsoft.AspNetCore.Authorization
@using TAKSuite.Components.Pages.Components
@using TAKSuite.Data.Models
@using TAKSuite.Data.Services
@inject TaskService TaskService
@inject TaskPrioritiesService PrioritiesService
@inject RadioChannelService RadioChannelService
@inject TeamService TeamService
@inject MissionSuiteEntityServices MissionSuiteService
@inject NavigationManager Navigation
@inject ToastService ToastService

<PageTitle>@(_task != null ? $"Configura — {_task.Name}" : "Configura Task")</PageTitle>

@if (_task == null)
{
    <p>Caricamento...</p>
}
else
{
    <div style="position: fixed; top: 0; left: 300px; right: 0; z-index: 100;
                background: var(--bs-body-bg); border-bottom: 1px solid var(--bs-border-color);
                padding: 0.5rem 1.5rem;">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <h2 class="mb-0 fs-4">Configura Task</h2>
                <p class="text-muted mb-0 small">@_task.Name</p>
            </div>
            <div class="d-flex gap-2">
                @if (_mission != null)
                {
                    <Button Color="ButtonColor.Secondary" Outline="true"
                            @onclick='() => Navigation.NavigateTo($"/missiontak/{_mission.Id}")'>
                        <Icon Name="IconName.ArrowLeft" /> @_mission.Name
                    </Button>
                }
                <Button Color="ButtonColor.Info" Outline="true"
                        @onclick='() => Navigation.NavigateTo($"/taskdetail/{_task.Id}")'>
                    <Icon Name="IconName.Eye" /> Operativo
                </Button>
                <Button Color="ButtonColor.Secondary" Outline="true"
                        @onclick='() => Navigation.NavigateTo($"/objeditor/{_task.Id}")'>
                    <Icon Name="IconName.FileEarmarkCode" /> Editor HTML
                </Button>
                <Button Color="ButtonColor.Success" @onclick="Save" Loading="_saving" LoadingText="Salvataggio...">
                    <Icon Name="IconName.Save" /> Salva Task
                </Button>
            </div>
        </div>
    </div>
    <div style="height: 72px;"></div>

    <!-- Informazioni Base -->
    <div class="card mb-3">
        <div class="card-header fw-bold">Informazioni Base</div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">Nome</label>
                    <input class="form-control" @bind="_task.Name" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Sottotitolo</label>
                    <input class="form-control" @bind="_task.Sottotitolo" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Priorità</label>
                    <select class="form-select" @bind="_task.PriorityId">
                        <option value="">— nessuna —</option>
                        @foreach (var p in _priorities)
                        {
                            <option value="@p.Id">@p.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Tipologia Obiettivo</label>
                    <input class="form-control" @bind="_task.TipologiaObiettivo" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Punti</label>
                    <input type="number" class="form-control" @bind="_task.Points" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Durata (min)</label>
                    <input type="number" class="form-control" @bind="_task.Durata" />
                </div>
            </div>
        </div>
    </div>

    <!-- Teams -->
    <div class="card mb-3">
        <div class="card-header fw-bold">Assegnazioni Team</div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">Team Assegnato</label>
                    <select class="form-select" @bind="_task.AssignedTeamId">
                        <option value="">— nessuno —</option>
                        @foreach (var t in _teams)
                        {
                            <option value="@t.Id">@t.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Team Esecutivo</label>
                    <select class="form-select" @bind="_task.ExecutingTeamId">
                        <option value="">— nessuno —</option>
                        @foreach (var t in _teams)
                        {
                            <option value="@t.Id">@t.Name</option>
                        }
                    </select>
                </div>
            </div>
        </div>
    </div>

    <!-- Finestre Temporali -->
    <div class="card mb-3">
        <div class="card-header fw-bold d-flex justify-content-between align-items-center">
            <span>Finestre Temporali</span>
            <Button Color="ButtonColor.Primary" Size="ButtonSize.Small"
                    Disabled="_visibleCount >= 10"
                    @onclick="AddWindow">
                <Icon Name="IconName.PlusCircle" /> Aggiungi Finestra
            </Button>
        </div>
        <div class="card-body">
            @for (int wi = 0; wi < _visibleCount; wi++)
            {
                var idx = wi; // cattura per closure
                var w   = _windows[idx];
                <div class="border rounded p-3 mb-3">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="fw-semibold small text-muted">
                            Finestra @(idx + 1)
                        </span>
                        @if (_visibleCount > 1)
                        {
                            <Button Color="ButtonColor.Danger" Size="ButtonSize.Small" Outline="true"
                                    @onclick="() => RemoveWindow(idx)">
                                <Icon Name="IconName.Trash" />
                            </Button>
                        }
                    </div>
                    <div class="row g-2">
                        <div class="col-md-6">
                            <label class="form-label small mb-1">Inizio (ora locale)</label>
                            <input type="datetime-local" class="form-control form-control-sm"
                                   value="@ToLocalInput(w.StartDateTime)"
                                   @onchange="e => { _windows[idx].StartDateTime = ParseLocalDt(e.Value?.ToString()); }" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small mb-1">Fine (ora locale)</label>
                            <input type="datetime-local" class="form-control form-control-sm"
                                   value="@ToLocalInput(w.EndDateTime)"
                                   @onchange="e => { _windows[idx].EndDateTime = ParseLocalDt(e.Value?.ToString()); }" />
                        </div>
                    </div>
                    @if (_mission?.StartDateTime.HasValue == true && _mission.EndDateTime.HasValue &&
                         ((w.StartDateTime.HasValue && (w.StartDateTime.Value < _mission.StartDateTime.Value || w.StartDateTime.Value > _mission.EndDateTime.Value)) ||
                          (w.EndDateTime.HasValue   && (w.EndDateTime.Value   < _mission.StartDateTime.Value || w.EndDateTime.Value   > _mission.EndDateTime.Value))))
                    {
                        <div class="alert alert-warning py-1 px-2 mt-2 small mb-0">
                            ⚠️ Data fuori dal range della missione (@DateTime.SpecifyKind(_mission.StartDateTime.Value, DateTimeKind.Utc).ToLocalTime().ToString("dd/MM HH:mm") – @DateTime.SpecifyKind(_mission.EndDateTime.Value, DateTimeKind.Utc).ToLocalTime().ToString("dd/MM HH:mm"))
                        </div>
                    }
                </div>
            }

            <hr class="my-2" />
            <div class="row g-2">
                @if (_task.Durata is > 0)
                {
                <div class="col-md-4">
                    <label class="form-label small mb-1 text-success fw-semibold">
                        <Icon Name="IconName.CircleFill" /> Luce Verde (ora locale)
                    </label>
                    <input type="datetime-local" class="form-control form-control-sm"
                           value="@ToLocalInput(_task.GreenLightDateTime)"
                           @onchange="e => _task.GreenLightDateTime = ParseLocalDt(e.Value?.ToString())" />
                    <small class="text-muted">Unica per il task — indipendente dalle finestre</small>
                </div>
                }
                <div class="col-md-4">
                    <label class="form-label small mb-1 text-secondary">Inizio finestra schedulata</label>
                    <input type="datetime-local" class="form-control form-control-sm"
                           value="@ToLocalInput(_task.PlannedStartDateTime)"
                           @onchange="e => _task.PlannedStartDateTime = ParseLocalDt(e.Value?.ToString())" />
                </div>
                <div class="col-md-4">
                    <label class="form-label small mb-1 text-secondary">Fine finestra schedulata</label>
                    <input type="datetime-local" class="form-control form-control-sm"
                           value="@ToLocalInput(_task.PlannedEndDateTime)"
                           @onchange="e => _task.PlannedEndDateTime = ParseLocalDt(e.Value?.ToString())" />
                </div>
            </div>
        </div>
    </div>

    <!-- Configurazione Operativa -->
    <div class="card mb-3">
        <div class="card-header fw-bold">Configurazione Operativa</div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">Canale Radio</label>
                    <select class="form-select" @bind="_task.RadioChannelId">
                        <option value="">— nessuno —</option>
                        @foreach (var r in _radioChannels)
                        {
                            <option value="@r.Id">@r.Name (@r.Frequency @r.FrequencyType)</option>
                        }
                    </select>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Missione</label>
                    @if (_mission != null)
                    {
                        <div>
                            <NavLink href="@($"/missiontak/{_mission.Id}")" class="btn btn-sm btn-outline-secondary">
                                <Icon Name="IconName.MapFill" /> @_mission.Name
                            </NavLink>
                        </div>
                    }
                    else
                    {
                        <span class="form-control-plaintext text-muted">— non assegnato a nessuna missione —</span>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Riferimenti TAK -->
    <div class="card mb-3">
        <div class="card-header fw-bold">POI Riferimento TAK</div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">POI</label>
                    <PoiSearchField Value="@_task.PoiUid"
                                    ValueChanged="@(v => _task.PoiUid = v)"
                                    NameValue="@_task.PoiName"
                                    NameValueChanged="@(v => _task.PoiName = v)"
                                    MissionTakName="@(_mission?.TakMissionUid)"
                                    OnPoiCreated="Save" />
                </div>
            </div>
        </div>
    </div>

}

@code {
    [Parameter] public Guid TaskId { get; set; }

    private TaskEntity? _task;
    private MissionSuite? _mission;
    private List<Team> _teams = new();
    private List<TaskPriority> _priorities = new();
    private List<RadioChannel> _radioChannels = new();
    private bool _saving;

    // Finestre temporali: 10 slot pre-allocati
    private List<TaskTimeWindow> _windows = Enumerable.Range(0, 10).Select(_ => new TaskTimeWindow()).ToList();
    private int _visibleCount = 1;

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        _task = await TaskService.GetAsync(TaskId);
        if (_task == null) return;

        if (_task.MissionTAKSuiteId.HasValue)
            _mission = await MissionSuiteService.GetAsync(_task.MissionTAKSuiteId.Value);

        _teams = (await TeamService.GetAllAsync()).OrderBy(t => t.Name).ToList();
        _priorities = (await PrioritiesService.GetAllAsync()).OrderBy(p => p.Level).ToList();
        _radioChannels = (await RadioChannelService.GetAllAsync()).OrderBy(r => r.Name).ToList();

        InitWindows();
    }

    private void InitWindows()
    {
        if (_task == null) return;
        var saved = _task.TimeWindows;

        // Se non ci sono finestre salvate ma esistono i vecchi campi, migra (solo Start/End, GL resta separata)
        if (saved.Count == 0 && (_task.StartDateTime.HasValue || _task.EndDateTime.HasValue))
        {
            saved = new List<TaskTimeWindow>
            {
                new() { StartDateTime = _task.StartDateTime, EndDateTime = _task.EndDateTime }
            };
        }

        for (int i = 0; i < Math.Min(saved.Count, 10); i++)
            _windows[i] = saved[i];

        _visibleCount = Math.Max(1, saved.Count(w => !w.IsEmpty));
    }

    private void AddWindow()
    {
        if (_visibleCount < 10) _visibleCount++;
    }

    private void RemoveWindow(int index)
    {
        // Rimuove e compatta
        _windows.RemoveAt(index);
        _windows.Add(new TaskTimeWindow());
        _visibleCount = Math.Max(1, _windows.Take(10).Count(w => !w.IsEmpty));
    }

    private async Task Save()
    {
        if (_task == null) return;
        _saving = true;
        try
        {
            // Salva solo le finestre non vuote tra quelle visibili
            var toSave = _windows.Take(_visibleCount).Where(w => !w.IsEmpty).ToList();
            _task.TimeWindows = toSave;

            // Sincronizza la finestra principale (0) con i vecchi campi legacy
            var w0 = toSave.FirstOrDefault();
            _task.StartDateTime = w0?.StartDateTime;
            _task.EndDateTime   = w0?.EndDateTime;
            // GreenLightDateTime è indipendente dalle finestre, non va sovrascritto

            _task.LastModified = DateTime.UtcNow;
            await TaskService.UpdateAsync(_task);
            ToastService.Notify(new(ToastType.Success, "Task", "Configurazione salvata"));
        }
        finally
        {
            _saving = false;
        }
    }

    private static string ToLocalInput(DateTime? utc)
        => utc.HasValue ? DateTime.SpecifyKind(utc.Value, DateTimeKind.Utc).ToLocalTime().ToString("yyyy-MM-ddTHH:mm") : "";

    private static DateTime? ParseLocalDt(string? s)
        => string.IsNullOrWhiteSpace(s) ? null
           : DateTime.SpecifyKind(DateTime.Parse(s), DateTimeKind.Local).ToUniversalTime();

    public void Dispose() { }
}
