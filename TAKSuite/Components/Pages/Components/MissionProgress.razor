@using BlazorReflection
@using TAKSuite.Data.Models

<div class="d-flex mb-3">
    <div class="flex-fill">
        <RangeInput TValue="int"
                    @bind-Value="missionProgress"
                    Min="@missionProgressMin"
                    Max="@missionProgressMax"
                    TickMarks="listTaskStatus"
                    Disabled="true"
                    Step="1" />
    </div>
</div>

@code {
    [Parameter] public MissionSuite MissionEntity { get; set; }

    private int missionProgressMin = 0;
    private int missionProgressMax = VisualStates.Length - 1;
    private int missionProgress;
    private List<TickMark> listTaskStatus = new();

    private static readonly MissionStatusTak[] VisualStates = new[]
    {
        MissionStatusTak.Created,
        MissionStatusTak.Assigned,
        MissionStatusTak.InProgress,
        MissionStatusTak.Completed
    };

    private static readonly HashSet<MissionStatusTak> CompletedEquivalents = new()
    {
        MissionStatusTak.Archived,
        MissionStatusTak.Canceled,
        MissionStatusTak.Stopped,
    };

    private static MissionStatusTak NormalizeStatus(MissionStatusTak status)
    {
        return CompletedEquivalents.Contains(status) ? MissionStatusTak.Completed : status;
    }

    private static List<TickMark> GetTickMarks()
    {
        return VisualStates.Select((status, index) => new TickMark
        {
            Label = status.GetDisplayName(),
            Value = index.ToString()
        }).ToList();
    }

    private static int GetNormalizedProgress(MissionStatusTak status)
    {
        var normalized = NormalizeStatus(status);
        var index = Array.IndexOf(VisualStates, normalized);
        return index >= 0 ? index : 0;
    }

    protected override void OnInitialized()
    {
        listTaskStatus = GetTickMarks();
        missionProgress = GetNormalizedProgress(MissionEntity.Status);
    }
}
