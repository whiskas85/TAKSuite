@page "/objeditor/{TaskId:guid}"
@inherits ConnectedUserInfo

@using TAKSuite.Data.Models
@using Microsoft.AspNetCore.Components.Forms
@using BlazorReflection
@using Microsoft.AspNetCore.Authorization
@using TAKSuite.Components.Layout
@using TAKSuite.Components.Pages.Documentation
@using TAKSuite.Components.Pages.Missions
@using TAKSuite.Components.Pages.Tasks.TaskComponents
@using TAKSuite.Data.Models
@using TAKSuite.Data.ModelsTak
@using TAKSuite.Data.Services
@using TAKSuite.TAK.CoT

@inject TaskService taskService
@inject RadioChannelService radioChannelService
@inject TaskTemplateService templateService
@inject IJSRuntime JS
@inject TAKSuite.Data.Services.NavRefreshService NavRefreshService

@implements IDisposable

<PageTitle>@taskEntity?.Name</PageTitle>

@if (taskEntity == null)
{
    <p>Caricamento...</p>
}
else
{
    <!-- TAB DOCK VERTICALE — sempre visibile sul bordo destro -->
    <button id="preview-dock-tab"
            class="preview-dock-tab @(_previewOpen ? "open" : "")"
            @onclick="TogglePreview"
            title="@(_previewOpen ? "Chiudi anteprima" : "Apri anteprima")">
        <span class="tab-label">Anteprima</span>
    </button>

    <!-- LAYOUT PRINCIPALE -->
    <div class="obj-editor-content">

        <PageHeader Title="@(taskEntity?.Name ?? "Task Editor")" TitleIcon="IconName.FileEarmarkCodeFill" />

        <div class="row mb-3">
            <div class="col">
                <label class="form-label">Nome</label>
                <InputText class="form-control"
                           @bind-Value="taskEntity.Name"
                           @bind-Value:after="DebouncedRefresh" />
            </div>
            <div class="col">
                <label class="form-label">Sottotitolo</label>
                <InputText class="form-control"
                           @bind-Value="taskEntity.Sottotitolo"
                           @bind-Value:after="DebouncedRefresh" />
            </div>
        </div>

        <div class="row mb-3">
            <div class="col">
                <label class="form-label">Tipologia Obiettivo</label>
                <InputText class="form-control"
                           @bind-Value="taskEntity.TipologiaObiettivo"
                           @bind-Value:after="DebouncedRefresh" />
            </div>
            <div class="col">
                <label class="form-label">Durata (min)</label>
                <InputNumber class="form-control"
                             @bind-Value="taskEntity.Durata"
                             @bind-Value:after="DebouncedRefresh" />
            </div>
            <div class="col">
                <label class="form-label">Canale Radio</label>
                <InputSelect class="form-control"
                             @bind-Value="taskEntity.RadioChannelId"
                             @bind-Value:after="DebouncedRefresh">
                    <option value="">Seleziona un canale</option>
                    @foreach (var r in RadioList.OrderBy(r => r.Name))
                    {
                        <option value="@r.Id">@r.Name</option>
                    }
                </InputSelect>
            </div>
        </div>

        <h5>Descrizione</h5>
        <MarkdownEditor SpellChecker="false"
                        @bind-Value="taskEntity.Description"
                        @bind-Value:after="DebouncedRefresh" />

        <div class="mb-3 mt-3">
            <TaskStringSection Title="ℹ INFO"
                               Items="taskEntity.Items"
                               AccentColor="#3399ff"
                               ButtonText="Aggiungi Info"
                               Placeholder="Inserisci informazione…"
                               Task="taskEntity"
                               SectionType="TaskStringItemType.Info"
                               OnChanged="DebouncedRefresh" />
        </div>

        <div class="mb-3">
            <TaskStringSection Title="⚠ NOTE"
                               Items="taskEntity.Items"
                               AccentColor="#ff4444"
                               ButtonText="Aggiungi Nota"
                               Placeholder="Inserisci nota…"
                               Task="taskEntity"
                               SectionType="TaskStringItemType.Note"
                               OnChanged="DebouncedRefresh" />
        </div>

        <div class="mb-3">
            <TaskStringSection Title="🚧 AZIONI"
                               Items="taskEntity.Items"
                               AccentColor="#ffcc00"
                               ButtonText="Aggiungi Azione"
                               Placeholder="Inserisci azione operativa…"
                               Task="taskEntity"
                               SectionType="TaskStringItemType.Action"
                               OnChanged="DebouncedRefresh" />
        </div>

        <div class="mt-4 d-flex gap-2 flex-wrap">
            <Button Color="ButtonColor.Success" @onclick="Save">
                <Icon Name="IconName.Save" /> Salva Task
            </Button>
            <Button Color="ButtonColor.Primary" @onclick="DownloadHtml">
                <Icon Name="IconName.Download" /> Genera HTML
            </Button>
        </div>

    </div>

    <!-- PANNELLO ANTEPRIMA -->
    <div id="preview-panel"
         class="obj-preview-panel @(_previewOpen ? "open" : "")">

        <!-- Handle resize (bordo sinistro trascinabile) -->
        <div id="preview-resize-handle" class="preview-resize-handle"></div>

        <!-- Header -->
        <div class="preview-panel-header">
            <span>Anteprima</span>
            <div class="d-flex gap-1">
                <button class="btn btn-sm btn-outline-secondary py-0 px-2"
                        @onclick="RefreshPreview"
                        title="Aggiorna">
                    <Icon Name="IconName.ArrowClockwise" />
                </button>
                <button class="btn btn-sm btn-close btn-close-white"
                        @onclick="TogglePreview" />
            </div>
        </div>

        <!-- iframe -->
        <iframe id="task-preview-frame"
                class="preview-iframe"
                sandbox="allow-same-origin">
        </iframe>
    </div>
}

<style>
    /* TAB DOCK VERTICALE */
    .preview-dock-tab {
        position: fixed;
        right: 0;
        top: 0;
        height: 100vh;
        width: 28px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 0;
        background: #2a2a2a;
        color: #bbb;
        border: none;
        border-left: 1px solid #444;
        cursor: pointer;
        z-index: 1052;
        transition: right 0.35s cubic-bezier(.4,0,.2,1), background 0.15s;
        user-select: none;
        box-shadow: -2px 0 8px rgba(0,0,0,.4);
    }

    .preview-dock-tab:hover {
        background: #383838;
        color: #fff;
    }

    .preview-dock-tab.open {
        right: min(46vw, 760px);
    }

    .tab-label {
        writing-mode: vertical-rl;
        transform: rotate(180deg);
        font-size: 0.75rem;
        letter-spacing: 0.12em;
        white-space: nowrap;
        text-transform: uppercase;
        font-weight: 600;
    }

    /* EDITOR — si sposta a sinistra quando il pannello è aperto */
    .obj-editor-content {
        padding: 1rem 1.5rem;
        transition: margin-right 0.35s cubic-bezier(.4,0,.2,1);
    }

    /* PANNELLO */
    .obj-preview-panel {
        position: fixed;
        top: 0;
        right: 0;
        width: min(46vw, 760px);
        height: 100vh;
        background: #111;
        border-left: 2px solid #333;
        display: flex;
        flex-direction: column;
        transform: translateX(100%);
        transition: transform 0.35s cubic-bezier(.4,0,.2,1);
        z-index: 1050;
    }

    .obj-preview-panel.open {
        transform: translateX(0);
        box-shadow: -6px 0 28px rgba(0,0,0,.55);
    }

    /* HANDLE RESIZE */
    .preview-resize-handle {
        position: absolute;
        left: 0;
        top: 0;
        width: 5px;
        height: 100%;
        cursor: ew-resize;
        background: transparent;
        transition: background 0.15s;
        z-index: 10;
    }

    .preview-resize-handle:hover,
    .preview-resize-handle:active {
        background: rgba(255,255,255,0.12);
    }

    /* HEADER PANNELLO */
    .preview-panel-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0.45rem 0.75rem 0.45rem 1rem;
        background: #1c1c1c;
        border-bottom: 1px solid #333;
        color: #ccc;
        font-size: 0.85rem;
        font-weight: 600;
        flex-shrink: 0;
    }

    /* IFRAME */
    .preview-iframe {
        flex: 1;
        width: 100%;
        border: none;
        background: #0f0f0f;
    }
</style>

@code {
    [Parameter] public Guid TaskId { get; set; }

    TaskEntity? taskEntity;
    List<RadioChannel> RadioList = new();
    bool _previewOpen;

    CancellationTokenSource? _cts;

    private Guid _loadedTaskId = Guid.Empty;

    protected override async Task OnParametersSetAsync()
    {
        if (TaskId == _loadedTaskId) return;
        _loadedTaskId = TaskId;
        taskEntity = null;
        taskEntity = await taskService.GetAsync(TaskId);
        RadioList = await radioChannelService.GetAllAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || !_previewOpen) return;
        await InitResize();
    }

    // --- Preview ---

    private async Task TogglePreview()
    {
        _previewOpen = !_previewOpen;
        if (_previewOpen)
        {
            await RefreshPreview();
            // Piccolo delay per attendere il render del pannello prima di inizializzare il resize
            await System.Threading.Tasks.Task.Delay(400);
            await InitResize();
        }
        else
        {
            await JS.InvokeVoidAsync("resetPanelPosition", "preview-dock-tab", ".obj-editor-content");
        }
    }

    private async Task InitResize()
    {
        await JS.InvokeVoidAsync("initResizablePanel",
            "preview-panel", "preview-resize-handle",
            "preview-dock-tab", ".obj-editor-content", 300);
    }

    private async Task RefreshPreview()
    {
        if (taskEntity == null) return;
        var html = await templateService.CompileAsync(taskEntity);
        await JS.InvokeVoidAsync("setIframeSrcdoc", "task-preview-frame", html);
    }

    private async Task DebouncedRefresh()
    {
        if (!_previewOpen) return;
        _cts?.Cancel();
        _cts = new CancellationTokenSource();
        try
        {
            await System.Threading.Tasks.Task.Delay(700, _cts.Token);
            await RefreshPreview();
        }
        catch (OperationCanceledException) { }
    }

    // --- Save / Download ---

    private async Task Save()
    {
        if (taskEntity == null) return;
        taskEntity.LastModified = DateTime.UtcNow;
        await taskService.UpdateAsync(taskEntity);
        NavRefreshService.NotifyNavChanged();
        if (_previewOpen) await RefreshPreview();
    }

    private async Task DownloadHtml()
    {
        if (taskEntity == null) return;
        var html = await templateService.CompileAsync(taskEntity);
        var filename = $"{taskEntity.Name.Replace(" ", "_")}.html";
        await JS.InvokeVoidAsync("downloadTextAsFile", filename, html, "text/html;charset=utf-8");
    }

    public void Dispose() => _cts?.Cancel();
}
