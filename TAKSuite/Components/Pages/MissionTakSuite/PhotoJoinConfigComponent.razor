@using TAKSuite.Data
@using TAKSuite.Data.Models
@using Microsoft.EntityFrameworkCore
@inject ApplicationDbContext Db
@inject ToastService ToastService

@if (_config == null)
{
    <p class="text-muted">Caricamento...</p>
}
else
{
    <div class="card mb-3">
        <div class="card-header d-flex align-items-center gap-2">
            <div class="form-check form-switch">
                <input class="form-check-input" type="checkbox" role="switch" id="switchEnabled"
                       checked="@_config.Enabled"
                       @onchange="e => _config!.Enabled = (bool)e.Value!" />
                <label class="form-check-label" for="switchEnabled">Abilita join automatico foto</label>
            </div>
        </div>
        <div class="card-body">
            <div class="row mb-3">
                <div class="col-md-4">
                    <label class="form-label">Raggio (metri)</label>
                    <NumberInput TValue="int" @bind-Value="_config.RadiusMeters" Min="5" Max="5000" />
                </div>
            </div>

            <h6>Regole di priorità</h6>
            <table class="table table-sm table-bordered mb-2">
                <thead class="table-light">
                    <tr>
                        <th style="width:60px">Priorità</th>
                        <th>Type contains</th>
                        <th>Callsign contains</th>
                        <th>Esclusi (csv)</th>
                        <th style="width:50px"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var rule in _config.PriorityRules.OrderBy(r => r.Priority))
                    {
                        <tr>
                            <td><NumberInput TValue="int" @bind-Value="rule.Priority" Min="1" Max="999" /></td>
                            <td><TextInput @bind-Value="rule.TypeContains" Placeholder="es: b-m-p-s-m" /></td>
                            <td><TextInput @bind-Value="rule.CallSignContains" Placeholder="es: OBJ" /></td>
                            <td><TextInput @bind-Value="rule.ExcludedTypesCsv" Placeholder="es: a-f-G" /></td>
                            <td>
                                <Button Color="ButtonColor.Danger" Size="ButtonSize.Small"
                                        @onclick="() => RemoveRule(rule)">
                                    <Icon Name="IconName.Trash" />
                                </Button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
            <Button Color="ButtonColor.Secondary" Size="ButtonSize.Small" @onclick="AddRule">
                <Icon Name="IconName.PlusCircle" /> Aggiungi regola
            </Button>
        </div>
        <div class="card-footer">
            <Button Color="ButtonColor.Primary" @onclick="SaveAsync">Salva</Button>
        </div>
    </div>
}

@code {
    [Parameter, EditorRequired] public Guid MissionId { get; set; }

    private MissionPhotoJoinConfig? _config;

    protected override async Task OnParametersSetAsync()
    {
        _config = await Db.MissionPhotoJoinConfigs
            .Include(c => c.PriorityRules)
            .FirstOrDefaultAsync(c => c.MissionId == MissionId);

        if (_config == null)
        {
            _config = new MissionPhotoJoinConfig { Id = Guid.NewGuid(), MissionId = MissionId };
            Db.MissionPhotoJoinConfigs.Add(_config);
            await Db.SaveChangesAsync();
        }
    }

    private void AddRule()
    {
        var next = _config!.PriorityRules.Any() ? _config.PriorityRules.Max(r => r.Priority) + 1 : 1;
        var rule = new CotPriorityRule
        {
            Id = Guid.NewGuid(),
            PhotoJoinConfigId = _config.Id,
            Priority = next
        };
        Db.CotPriorityRules.Add(rule);
        _config.PriorityRules.Add(rule);
    }

    private void RemoveRule(CotPriorityRule rule)
    {
        Db.CotPriorityRules.Remove(rule);
        _config!.PriorityRules.Remove(rule);
    }

    private async Task SaveAsync()
    {
        try
        {
            await Db.SaveChangesAsync();
            ToastService.Notify(new(ToastType.Success, "Salvato", "Configurazione join foto salvata."));
        }
        catch (Exception ex)
        {
            ToastService.Notify(new(ToastType.Danger, "Errore", ex.Message));
        }
    }
}
