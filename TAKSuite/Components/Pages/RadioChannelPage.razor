    private async Task<GridDataProviderResult<RadioChannel>> RadioChannelsDataProvider(GridDataProviderRequest<RadioChannel> request)
    {
        radioChannels = await RadioChannelService.GetAllAsync();
        return await Task.FromResult(request.ApplyTo(radioChannels));
    }

    private Task OnSelectedItemsChanged(HashSet<RadioChannel> channels)
    {
        var selectedChannels = channels is not null && channels.Any() ? channels : new();
        return Task.CompletedTask;
    }

    protected override async Task OnInitializedAsync()
    {
        radioChannels = await RadioChannelService.GetAllAsync();
        StateHasChanged();
    }

    private async Task ShareRadioChannel(Guid id)
    {
        await JS.InvokeVoidAsync("copyToClipboard", NavigationManager.BaseUri + "RadioChannel/Details?id=" + id.ToString());
        ToastService.Notify(new(ToastType.Success, "Condividi", $"Testo copiato negli appunti"));
    }


    private async Task DeleteChannel(Guid id)
    {
        await RadioChannelService.DeleteAsync(id);
        await grid.RefreshDataAsync();
        StateHasChanged();
    }
}
