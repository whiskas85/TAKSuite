@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@using TAKSuite.Data
@using TAKSuite.Data.Models
@using TAKSuite.Data.Services
@inject IUserStore<ApplicationUser> UserStore
@inject UserManager<ApplicationUser> UserManager
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject UserServiceAtak _userServiceAtak;
@attribute [Authorize]


@code {
    public UserAtak ConnectedAtakUser { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        ConnectedAtakUser = await User();

    }

    private async Task<UserAtak> User()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = await UserManager.GetUserAsync(authState.User);

        if (user != null)
        {
            var id = user.UserId; // Assumendo che "Nick" sia una proprietà di ApplicationUser
            var atakUser = await _userServiceAtak.GetAsync(id);
            return atakUser;
        }
        else
        {
            Console.WriteLine("Utente non trovato.");
        }
        return null;
    }

}
