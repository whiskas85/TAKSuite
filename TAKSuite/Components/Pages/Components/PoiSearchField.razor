@using TAKSuite.TAK.CoT
@using TAKSuite.TAK.Helper
@using TAKSuite.Components.Pages.MissionTakSuite
@inject MartiApiClient MartiApiClient
@inject CoTManager CoTManager

<ModalAddPoi @ref="_addPoiModal"
             MissionTakUid="@MissionTakName"
             OnPoiCreated="OnNewPoiCreated" />

@if (!string.IsNullOrEmpty(Value))
{
    <div class="d-flex align-items-center gap-2 p-2 border rounded bg-light-subtle">
        <Icon Name="IconName.GeoAltFill" class="text-danger flex-shrink-0" />
        <div class="flex-grow-1" style="min-width:0">
            <div class="fw-semibold">@(string.IsNullOrEmpty(NameValue) ? Value : NameValue)</div>
            @if (!string.IsNullOrEmpty(NameValue))
            {
                <div class="text-muted small font-monospace text-truncate">@Value</div>
            }
        </div>
        <Button Color="ButtonColor.Secondary" Outline="true" Size="ButtonSize.Small"
                @onclick="ShowModal"
                Disabled="@(string.IsNullOrEmpty(MissionTakName))"
                title="Cambia POI">
            <Icon Name="IconName.ArrowRepeat" />
        </Button>
        <Button Color="ButtonColor.Danger" Outline="true" Size="ButtonSize.Small"
                @onclick="ClearPoi" title="Rimuovi POI">
            <Icon Name="IconName.X" />
        </Button>
    </div>
}
else
{
    <div class="d-flex gap-2">
        <Button Color="ButtonColor.Secondary" Outline="true"
                @onclick="ShowModal"
                Disabled="@(string.IsNullOrEmpty(MissionTakName))">
            <Icon Name="IconName.Search" /> Cerca POI
        </Button>
        <Button Color="ButtonColor.Primary" Outline="true"
                title="Crea nuovo POI su TAK"
                @onclick="async () => await _addPoiModal.ShowAsync()">
            <Icon Name="IconName.GeoFill" /> Nuovo POI
        </Button>
    </div>
    @if (string.IsNullOrEmpty(MissionTakName))
    {
        <small class="form-text text-muted">Ricerca disponibile solo per task in una missione TAK</small>
    }
}

<Modal @ref="_modal" Title="Seleziona POI" Size="ModalSize.Large">
    <BodyTemplate>
        <div class="mb-3">
            <input class="form-control"
                   type="text"
                   value="@_searchText"
                   @oninput="e => OnSearchChanged(e.Value?.ToString() ?? string.Empty)"
                   placeholder="Cerca per nome o tipo..." />
        </div>
        <Grid TItem="UidEntry"
              Class="table table-hover border-top"
              Data="_filteredItems"
              HeaderRowCssClass="bg-success text-white border-bottom-0 h5"
              AllowSorting="true"
              AllowPaging="false"
              AllowSelection="false"
              AllowRowClick="true"
              OnRowDoubleClick="OnRowDoubleClick"
              Responsive="true">
            <GridColumns>
                <GridColumn TItem="UidEntry" HeaderText="Nome" SortKeySelector="item => item.Details.Callsign">
                    <strong>@context.Details?.Callsign</strong>
                </GridColumn>
                <GridColumn TItem="UidEntry" HeaderText="Tipo" SortKeySelector="item => item.Details.Type">
                    @context.Details?.Type
                </GridColumn>
                <GridColumn TItem="UidEntry" HeaderText="UID">
                    <span class="text-muted small font-monospace">@context.Data</span>
                </GridColumn>
            </GridColumns>
        </Grid>
    </BodyTemplate>
    <FooterTemplate>
        <Button Color="ButtonColor.Secondary" @onclick="() => _modal.HideAsync()">Chiudi</Button>
    </FooterTemplate>
</Modal>

@code {
    [Parameter] public string? Value { get; set; }
    [Parameter] public EventCallback<string?> ValueChanged { get; set; }
    [Parameter] public string? NameValue { get; set; }
    [Parameter] public EventCallback<string?> NameValueChanged { get; set; }
    [Parameter] public string? MissionTakName { get; set; }
    [Parameter] public EventCallback OnPoiCreated { get; set; }

    private Modal _modal = default!;
    private ModalAddPoi _addPoiModal = default!;
    private List<UidEntry> _allItems = new();
    private List<UidEntry> _filteredItems = new();
    private string _searchText = "";

    private async Task ShowModal()
    {
        _searchText = "";
        _allItems = string.IsNullOrEmpty(MissionTakName)
            ? new()
            : await MartiApiClient.GetAllMissionsUidAsync(MissionTakName);
        _filteredItems = _allItems;
        await _modal.ShowAsync();
    }

    private void OnSearchChanged(string value)
    {
        _searchText = value;
        var filter = _searchText.Trim().ToLower();
        _filteredItems = string.IsNullOrEmpty(filter)
            ? _allItems
            : _allItems
                .Where(u =>
                    (u.Details?.Callsign?.ToLower().Contains(filter) == true) ||
                    (u.Details?.Type?.ToLower().Contains(filter) == true))
                .ToList();
    }

    private async Task OnRowDoubleClick(GridRowEventArgs<UidEntry> args)
    {
        if (args.Item == null || string.IsNullOrEmpty(args.Item.Data)) return;
        await ValueChanged.InvokeAsync(args.Item.Data);
        await NameValueChanged.InvokeAsync(args.Item.Details?.Callsign);
        await _modal.HideAsync();
    }

    private async Task OnNewPoiCreated(ModalAddPoi.PoiResult result)
    {
        await ValueChanged.InvokeAsync(result.Uid);
        await NameValueChanged.InvokeAsync(result.Callsign);
        await OnPoiCreated.InvokeAsync();
    }

    private async Task ClearPoi()
    {
        await ValueChanged.InvokeAsync(null);
        await NameValueChanged.InvokeAsync(null);
    }
}
