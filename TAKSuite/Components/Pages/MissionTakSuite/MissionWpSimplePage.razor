@page "/missiontak/{MissionTakId:guid}/waypoints-simple"
@attribute [Authorize]
@using Microsoft.AspNetCore.Authorization
@using TAKSuite.Data.Models
@using TAKSuite.Data.ModelsTak
@using TAKSuite.Data.Services
@using TAKSuite.Data.ServicesTak
@using TAKSuite.TAK.CoT
@using TAKSuite.TAK.Helper
@inject MissionSuiteEntityServices MissionSuiteService
@inject WaypointService WaypointService
@inject AttachmentService AttachmentService
@inject CoTManager CoTManager
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>WP Simple — @(_mission?.Name ?? "Missione")</PageTitle>

@if (_mission == null)
{
    <p>Caricamento...</p>
}
else
{
    <PageHeader Title="WP Simple" Subtitle="@_mission.Name">
        <ChildContent>
            <Button Color="ButtonColor.Secondary" Outline="true"
                    @onclick='() => Navigation.NavigateTo($"/missiontak/{MissionTakId}")'>
                <Icon Name="IconName.ArrowLeft" />
            </Button>
        </ChildContent>
    </PageHeader>

    <!-- Allegati modal -->
    <Modal @ref="_attachmentModal" Title="Allegati waypoint">
        <BodyTemplate>
            @if (_attachList == null)
            {
                <div class="text-center py-3">
                    <div class="spinner-border spinner-border-sm" role="status"></div>
                    <span class="ms-2 text-muted">Caricamento...</span>
                </div>
            }
            else if (!_attachList.Any())
            {
                <p class="text-center text-muted py-3">Nessun allegato</p>
            }
            else
            {
                <div class="list-group list-group-flush">
                    @foreach (var a in _attachList)
                    {
                        var isImage = a.MediaType?.Contains("image") == true || a.MediaType?.Contains("jpeg") == true || a.MediaType?.Contains("png") == true;
                        var isPdf = a.MediaType?.Contains("pdf") == true;
                        <button class="list-group-item list-group-item-action d-flex align-items-center gap-3 py-2 border-0"
                                @onclick="() => ViewAttachment(a)">
                            @if (isImage)
                            {
                                <Icon Name="IconName.FileEarmarkImage" Color="IconColor.Primary" Size="IconSize.x5" />
                            }
                            else if (isPdf)
                            {
                                <Icon Name="IconName.FileEarmarkPdfFill" Color="IconColor.Danger" Size="IconSize.x5" />
                            }
                            else
                            {
                                <Icon Name="IconName.FileEarmarkFill" Color="IconColor.Secondary" Size="IconSize.x5" />
                            }
                            <span class="flex-grow-1 text-truncate small text-start">@Uri.UnescapeDataString(a.Name ?? "")</span>
                            <Icon Name="IconName.BoxArrowUpRight" Color="IconColor.Secondary" />
                        </button>
                    }
                </div>
            }
        </BodyTemplate>
        <FooterTemplate>
            <Button Color="ButtonColor.Secondary" @onclick="() => _attachmentModal.HideAsync()">Chiudi</Button>
        </FooterTemplate>
    </Modal>

    @if (string.IsNullOrEmpty(_mission.TakMissionUid))
    {
        <div class="alert alert-warning">
            Nessuna missione TAK collegata. Collega un TAK Mission UID dalla pagina dei dettagli.
        </div>
    }
    else if (_loading)
    {
        <div class="d-flex justify-content-center py-5">
            <div class="spinner-border text-secondary" role="status"></div>
        </div>
    }
    else if (!_waypoints.Any())
    {
        <div class="text-center py-5 text-muted">
            <Icon Name="IconName.GeoFill" Size="IconSize.x5" />
            <p class="mt-3">Nessun waypoint nella missione.</p>
        </div>
    }
    else
    {
        <div class="d-flex flex-column gap-2 px-2 pt-2">
            @foreach (var wp in _waypoints)
            {
                var completed = wp.Color == ATAKHelper.COLOR_WAYPOINT_COMPLETED;
                <div class="card shadow-sm @(completed ? "border-success border-2" : "")">
                    <div class="card-body py-3 px-3">
                        <div class="d-flex align-items-center gap-2 mb-3">
                            <span style="flex-shrink:0;width:22px;height:22px;border-radius:50%;
                                         background-color:@(TAKSuite.Helper.ColorConverterHelper.ArgbToHex(wp.Color ?? -1));
                                         border:2px solid var(--bs-border-color);display:inline-block;">
                            </span>
                            <span class="fw-semibold @(completed ? "text-success" : "")"
                                  style="font-size:1.1rem;">@wp.Callsign</span>
                        </div>
                        <div class="d-flex gap-2">
                            @if (!completed)
                            {
                                <Button Color="ButtonColor.Success" class="flex-grow-1"
                                        @onclick="() => CompleteWaypoint(wp)">
                                    <Icon Name="IconName.CheckLg" /> Completa
                                </Button>
                            }
                            else
                            {
                                <div class="flex-grow-1 text-success d-flex flex-column">
                                    <span class="fw-semibold small d-flex align-items-center gap-1">
                                        <Icon Name="IconName.CheckCircleFill" /> Completato
                                    </span>
                                    <span class="font-monospace" style="font-size:.8rem;">
                                        @wp.LastUpdateTime.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                                    </span>
                                </div>
                            }
                            <Button Color="ButtonColor.Secondary" Position="Position.Relative"
                                    @onclick="() => OpenAttachments(wp)">
                                <Icon Name="IconName.Paperclip" />
                                @if (wp.AttachmentUidList.Count > 0)
                                {
                                    <Badge Color="BadgeColor.Danger"
                                           Position="Position.Absolute"
                                           Placement="BadgePlacement.TopRight"
                                           IndicatorType="BadgeIndicatorType.RoundedPill">
                                        @wp.AttachmentUidList.Count
                                    </Badge>
                                }
                            </Button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
}

@code {
    [Parameter] public Guid MissionTakId { get; set; }

    private MissionSuite? _mission;
    private List<Waypoint> _waypoints = new();
    private bool _loading;
    private Guid _loadedMissionId = Guid.Empty;

    private Modal _attachmentModal = default!;
    private string? _selectedWaypointUid;
    private List<AtakAttachment>? _attachList;

    protected override async Task OnParametersSetAsync()
    {
        if (MissionTakId == _loadedMissionId) return;
        _loadedMissionId = MissionTakId;
        _mission = null;
        _waypoints = new();
        _mission = await MissionSuiteService.GetAsync(MissionTakId);
        await LoadWaypointsAsync();
    }

    private async Task LoadWaypointsAsync()
    {
        var missionUid = _mission?.TakMissionUid ?? string.Empty;
        if (string.IsNullOrEmpty(missionUid)) { _waypoints = new(); StateHasChanged(); return; }
        _loading = true;
        StateHasChanged();
        try
        {
            _waypoints = (await WaypointService.GetAllWaypointsAsync(missionUid))
                .OrderBy(w => w.Color == ATAKHelper.COLOR_WAYPOINT_COMPLETED)
                .ThenBy(w => w.Callsign)
                .ToList();
        }
        finally { _loading = false; StateHasChanged(); }
    }

    private async Task CompleteWaypoint(Waypoint item)
    {
        await CoTManager.ChangeCotColor(_mission?.TakMissionUid ?? string.Empty, item.Uid, ATAKHelper.COLOR_WAYPOINT_COMPLETED);
        await LoadWaypointsAsync();
    }

    private async Task OpenAttachments(Waypoint item)
    {
        _selectedWaypointUid = item.Uid;
        _attachList = null;
        await _attachmentModal.ShowAsync();
        _attachList = await AttachmentService.GetAllAsync(item.Uid);
        StateHasChanged();
    }

    private async Task ViewAttachment(AtakAttachment attach)
    {
        if (attach.FileBytes == null) return;
        var base64 = Convert.ToBase64String(attach.FileBytes);
        var mediaType = attach.MediaType ?? "application/octet-stream";
        await JS.InvokeVoidAsync("viewFile", base64, mediaType);
    }
}
