@using TAKSuite.Components.Pages.EventEntityComponents.GenercForm
@using TAKSuite.Data.Models
@using TAKSuite.Data.Services

<GenericGrid TItem="EventEntity"
Items="ItemList">

    <ColumnDefinitions>
        <GridColumn TItem="EventEntity" HeaderText="Ora" Class="align-middle" SortKeySelector="item => item.Timestamp">
            @context.Timestamp?.ToString("dd/MM HH:mm")
        </GridColumn>
        <GridColumn TItem="EventEntity" HeaderText="Evento" Class="align-middle" SortKeySelector="item => item.Title">
            @context.Title
        </GridColumn>
        <GridColumn TItem="EventEntity" HeaderText="Note" Class="align-middle" SortKeySelector="item => item.Note">
            @context.Note
        </GridColumn>
    </ColumnDefinitions>

</GenericGrid>

@code {
    [Inject] public EventEntityService eventEntityService { get; set; }
    [Parameter] public EventCallback<EventEntity> OnDoubleClick { get; set; }
    private List<EventEntity> ItemList = new List<EventEntity>();


    protected override async Task OnInitializedAsync()
    {

    }

    protected override async Task OnParametersSetAsync()
    {
        await base.OnParametersSetAsync();

        ItemList = (await eventEntityService.GetAllAsync()).OrderByDescending(_ => _.Timestamp).ToList();
        StateHasChanged();

    }
}
