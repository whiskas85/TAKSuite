@page "/test2"
@using TAKSuite.Components.Layout
@using TAKSuite.Components.Pages.EventEntityComponents
@using TAKSuite.Components.Pages.EventEntityComponents.GenercForm
@using TAKSuite.Data.Models
@using TAKSuite.Data.Services
@inject EventEntityService eventEntityService

@inherits ConnectedUserInfo

<PageTitle>Home</PageTitle>

<h1>Pagina test</h1>

<Button Color="ButtonColor.Primary" @onclick="OnClick">Test</Button>

<GenericGrid TItem="EventEntity"
             Items="ItemList"
             OnRowDoubleClick="OnDoubleClickHandler">
    <ColumnDefinitions>
        <GridColumn TItem="EventEntity" HeaderText="Ora" Class="align-middle" SortKeySelector="item => item.Timestamp">
            @context.Timestamp?.ToString("dd/MM HH:mm")
        </GridColumn>
        <GridColumn TItem="EventEntity" HeaderText="Evento" Class="align-middle" SortKeySelector="item => item.Title">
            @context.Title
        </GridColumn>
        <GridColumn TItem="EventEntity" HeaderText="Note" Class="align-middle" SortKeySelector="item => item.Note">
            @context.Note
        </GridColumn>
    </ColumnDefinitions>
</GenericGrid>

<Modal @ref="modal" Size="ModalSize.Large" Title="Aggiungi Evento">
    <BodyTemplate>
        <EventAdd OnSubmitted="OnSubmitted" />
    </BodyTemplate>
</Modal>

@code {
    private Modal modal = default!;
    private List<EventEntity> ItemList = new List<EventEntity>();
    

   

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        ItemList = (await eventEntityService.GetAllAsync()).OrderByDescending(_ => _.Timestamp).ToList();
    }

    private async Task OnClick()
    {
        await modal.ShowAsync();
    }

    private async Task OnSubmitted()
    {
        await modal.HideAsync();
        await LoadData();  // Ricarica i dati dopo aver aggiunto un nuovo evento
    }

    private async Task OnDoubleClickHandler(EventEntity item)
    {
        Console.WriteLine($"Hai selezionato: {item.Title}");
    }
}
