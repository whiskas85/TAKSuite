@page "/missions"
@attribute [Authorize]
@rendermode InteractiveServer

@using TAKSuite.Data.ModelsTak
@using TAKSuite.TAK.CoT
@using Microsoft.AspNetCore.Authorization
@using System.Text.Json


@inject NavigationManager Navigation
@inject TAKSuite.Helpers.JsInteropHelper JsHelper
@inject MartiApiClient MartiApiClient

<PageTitle>Missions</PageTitle>

<h1>Elenco missioni</h1>

<Grid TItem="MissionAtak"
      Class="table table-hover border-top"
      Data="MissionsList"
      HeaderRowCssClass="bg-success text-white border-bottom-0  h5"
      FiltersRowCssClass="bg-success text-white bg-opacity-25 border-bottom-0"
      AllowFiltering="false"
      AllowPaging="false"
      AllowSorting="true"
      AllowSelection="false"
      SelectionMode="GridSelectionMode.Multiple"
      Responsive="true">

    <GridColumns>
        <GridColumn TItem="MissionAtak" HeaderText="Nome" Class="align-middle" SortKeySelector="item => item.Name">
            @context.Name
        </GridColumn>

        <GridColumn TItem="MissionAtak" Class="align-middle" HeaderText="Azioni">
            <Button Color="ButtonColor.Primary" @onclick="() => View(context)"><Icon Name="IconName.PencilFill"></Icon></Button>
        </GridColumn>
    </GridColumns>

</Grid>




@code {
    private List<MissionAtak> MissionsList = new List<MissionAtak>();

    protected override async Task OnInitializedAsync()
    {
        // Carica i dati della missione all'inizializzazione
        var json = await MartiApiClient.GetAllMissionsDataAsync();
        var data = JsonSerializer.Deserialize<MissionsRoot>(json, new JsonSerializerOptions
            {
                PropertyNameCaseInsensitive = true
            });
        MissionsList = data.Data.ToList();
        StateHasChanged(); 
    }

    protected async Task View(MissionAtak mission)
    {
        // Naviga alla pagina di dettaglio della missione
        Navigation.NavigateTo($"/mission/{mission.Name}");
    }
   
}
