@using System.Text.Json
@using TAKSuite.Data.ModelsTak
@using TAKSuite.TAK.CoT
@inject MartiApiClient MartiApiClient


<Grid TItem="UidEntry"
Class="table table-hover border-top"
Data="MissionsUids"
HeaderRowCssClass="bg-success text-white border-bottom-0  h5"
FiltersRowCssClass="bg-success text-white bg-opacity-25 border-bottom-0"
AllowFiltering="false"
AllowPaging="false"
AllowSorting="true"
AllowSelection="true"
AllowRowClick="true"
OnRowDoubleClick="OnDoubleClickHandeler"
SelectionMode="GridSelectionMode.Multiple"
SelectedItemsChanged="OnSelectedItemsChanged"
PageSize="20"
Responsive="true">

    <GridColumns>
        <GridColumn TItem="UidEntry" HeaderText="Nome" Class="align-middle" SortKeySelector="item => item.Details.Callsign">
            @context.Details.Callsign
        </GridColumn>

        @* <GridColumn TItem="MissionAtak" Class="align-middle" HeaderText="Azioni">
            <Button Color="ButtonColor.Primary" @onclick="() => View(context)"><Icon Name="IconName.PencilFill"></Icon></Button>
        </GridColumn> *@
    </GridColumns>

</Grid>

@code {
    [Parameter] public EventCallback<List<MissionAtak>> OnDoubleClick { get; set; }
    [Parameter] public string MissionName { get; set; }

    [Parameter] public HashSet<UidEntry> SelectedItems { get; set; }
    [Parameter] public EventCallback<HashSet<UidEntry>?> SelectedItemsChanged { get; set; }


    private List<UidEntry> MissionsUids = new List<UidEntry>();





    protected override async Task OnInitializedAsync()
    {
        if (string.IsNullOrEmpty(MissionName))
            return;

        // Carica i dati della missione all'inizializzazione
        MissionsUids = await MartiApiClient.GetAllMissionsUidAsync(MissionName);
        StateHasChanged();
    }

    private async Task OnSelectedItemsChanged(HashSet<UidEntry> uidList)
    {
        SelectedItems = uidList is not null && uidList.Any() ? uidList : new();
        await SelectedItemsChanged.InvokeAsync(SelectedItems);
    }
    private async Task OnDoubleClickHandeler(GridRowEventArgs<UidEntry> args)
    {
        if (OnDoubleClick.HasDelegate) await OnDoubleClick.InvokeAsync(null);
    }
}
