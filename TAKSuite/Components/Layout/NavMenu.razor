    private async Task<IEnumerable<NavItem>> RetrieveAllTeams(IList<NavItem> navItems, string teamsTitle)
    {
        var id = navItems.FirstOrDefault(x => x.Text == teamsTitle)?.Id;
        if (id != null)
        {
            var teams = await TeamService.GetAllAsync();
            foreach (var team in teams)
            {
                var teamMenuid = $"{id}.{team.Id}";
                var hrefBase = $"/team/{team.Id}";

                navItems.Add(new NavItem { Id = teamMenuid, Href = $"/team/{team.Id}/details", IconName = IconName.PeopleFill, Text = team.Name, ParentId = id });

                int counter = 0;
                // navItems.Add(new NavItem { Href = $"{hrefBase}", Text = "Pagina old", IconName = IconName.PeopleFill, ParentId = teamMenuid, Id = $"{id}.{team.Id}.{counter++}" });
                navItems.Add(new NavItem { Href = $"{hrefBase}/details", Text = "Dettagli", IconName = IconName.HouseFill, ParentId = teamMenuid, Id = $"{id}.{team.Id}.{counter++}" });
                navItems.Add(new NavItem { Href = $"{hrefBase}/comms", Text = "Comunicazioni", IconName = IconName.Headset, ParentId = teamMenuid, Id = $"{id}.{team.Id}.{counter++}" });
                navItems.Add(new NavItem { Href = $"{hrefBase}/operators", Text = "Operatori", IconName = IconName.PersonFill, ParentId = teamMenuid, Id = $"{id}.{team.Id}.{counter++}" });
                navItems.Add(new NavItem { Href = $"{hrefBase}/documentation", Text = "Documentazione", IconName = IconName.FileTypeDoc, ParentId = teamMenuid, Id = $"{id}.{team.Id}.{counter++}" });
                navItems.Add(new NavItem { Href = $"{hrefBase}/tasks", Text = "Tasks", IconName = IconName.FileTypeDoc, ParentId = teamMenuid, Id = $"{id}.{team.Id}.{counter++}" });

            }
        }
        return navItems;
    }











    private string? currentUrl;

    protected override void OnInitialized()
    {
        currentUrl = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        NavigationManager.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        currentUrl = NavigationManager.ToBaseRelativePath(e.Location);
        StateHasChanged();
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }
}

