@using TAKSuite.Data.Models
@using TAKSuite.Data.Services
@inject TaskPrioritiesService taskPrioritiesService
@inject TaskService taskService
@inject TeamService teamService
@inject MissionSuiteEntityServices missionSuiteService
@code {
    [Parameter] public TaskModel? Model { get; set; }
    [Parameter] public EventCallback OnSuccess { get; set; }
    [Parameter] public EventCallback OnModalHidden { get; set; }
    [Parameter] public List<Team>? Teams { get; set; }
    [Parameter] public UserAtak User { get; set; }

    private Modal modal = default!;
    private ModalSelectPoi _poiModal = default!;
    private string title = "Aggiungi Task";
    private List<Team> teams = new();
    private List<TaskPriority> taskPriorities = new();
    private string? _takMissionName;


    public async Task ShowAsync()
    {
        if (Model == null)
        {
            Model = new TaskModel();
        }

        taskPriorities = (await taskPrioritiesService.GetAllAsync()).OrderBy(_ => _.Level).ToList();

        if (!Model.Id.HasValue && !Model.Priority.HasValue)
        {
            var defaultPriority = taskPriorities.FirstOrDefault(p => p.IsDefault);
            if (defaultPriority != null)
                Model.Priority = defaultPriority.Id;
        }

        if (Model.AssignedTeam == null)
        {
            if (Teams == null)
            {
                teams = await teamService.GetAllAsync();
            }
            else
            {
                teams.AddRange(Teams);
            }
        }
        else
        {
            teams.Add(await teamService.GetAsync(Model.AssignedTeam.Id));
            Model.AssignedTeamId = Model.AssignedTeam.Id;
        }

        _takMissionName = null;
        if (Model.Id.HasValue)
        {
            title = "Modifica Task";
            var entity = await taskService.GetAsync(Model.Id.Value);
            if (entity != null)
            {
                Model.PoiUid = entity.PoiUid;
                Model.PoiName = entity.PoiName;
                if (entity.MissionTAKSuiteId.HasValue)
                {
                    var mission = await missionSuiteService.GetAsync(entity.MissionTAKSuiteId.Value);
                    _takMissionName = mission?.TakMissionUid;
                }
            }
        }
        else
        {
            title = "Aggiungi Task";
        }

        await modal.ShowAsync();
    }

    public async Task HideAsync() => await modal.HideAsync();


    private async void OnHidden()
    {
        Model = new TaskModel();
        _takMissionName = null;
        await OnModalHidden.InvokeAsync();
    }

    private async Task ShowPoiModal() => await _poiModal.ShowAsync();

    private void OnPoiSelected(UidEntry entry)
    {
        Model!.PoiUid = entry.Data;
        Model!.PoiName = entry.Details?.Callsign;
        StateHasChanged();
    }

    private async void OnSubmit()
    {
        var newTask = new TaskEntity
        {
            Name = Model.Name,
            Description = Model.Description,
            Status = TaskStatusTak.Created,
            CreationDate = DateTime.UtcNow,
            LastModified = DateTime.UtcNow,
            PriorityId = Model.Priority,
            MissionUid = "",
            PoiUid = Model.PoiUid,
            PoiName = Model.PoiName
        };


        if (Model.AssignedTeamId.HasValue)
        {
            Model.AssignedTeam = teams.FirstOrDefault(_ => _.Id == Model.AssignedTeamId);
            newTask.AssignedTeamId = Model.AssignedTeamId;
        }

        TaskEntity taskEntity;
        if (Model.Id.HasValue)
        {
            newTask.Id = Model.Id.Value;
            taskEntity =  await taskService.UpdateAsync(newTask);  // Update existing task
        }
        else if(!Model.AssignedTeamId.HasValue)
        {
            taskEntity = await taskService.InsertTaskAsync(newTask, User);
            Model.Id = taskEntity.Id;
        }
        else
        {
            taskEntity = await taskService.InsertTaskByTeamAsync(newTask, Model.AssignedTeam, User);
        }

        if (OnSuccess.HasDelegate) await OnSuccess.InvokeAsync();
        await modal.HideAsync();
        
    }
}

<Modal @ref="modal" Title="@title" OnHidden="OnHidden">
    <BodyTemplate>
        <EditForm Model="Model" FormName="TaskForm">
            <DataAnnotationsValidator />
            <div>
                <div class="form-group row mb-3">
                    <label for="inputName" class="col-sm-2 col-form-label">Nome Task</label>
                    <div class="col-sm-10">
                        <TextInput id="inputName" class="form-control" @bind-Value="Model!.Name" />
                        <ValidationMessage For="() => Model!.Name" class="text-danger" />
                        <small class="form-text text-muted">Nome identificativo del task</small>
                    </div>
                </div>

                @if (Model.AssignedTeam == null)
                {
                    <div class="form-group row mb-3">
                        <label class="col-sm-2 col-form-label" for="AssignedTeamId">Squadra Assegnata</label>
                        <div class="col-sm-10">
                            <InputSelect id="AssignedTeamId" class="form-control" @bind-Value="Model!.AssignedTeamId">
                                <option value="">Seleziona una squadra</option>
                                @foreach (var team in teams)
                                {
                                    <option value="@team.Id" selected="@(Model.AssignedTeam != null && Model.AssignedTeam == team ? "selected" : null)">
                                        @team.Name
                                </option>
                            }
                            </InputSelect>
                        </div>
                    </div>
                }

                <div class="form-group row mb-3">
                    <label class="col-sm-2 col-form-label" for="taskPrio">Priorità</label>
                    <div class="col-sm-10">
                        <InputSelect id="taskPrio" class="form-control" @bind-Value="Model!.Priority">
                            <option value="">Seleziona una priorità</option>
                            @foreach (var priority in taskPriorities)
                            {
                                <option value="@priority.Id" selected="@(Model.Priority != null && Model.Priority == priority.Id ? "selected" : null)">
                                    @priority.Name
                            </option>
                            }
                        </InputSelect>
                    </div>
                </div>



                <div class="form-group row mb-3">
                    <label class="col-sm-2 col-form-label" for="Description">Descrizione</label>
                    <div class="col-sm-10">
                        <InputTextArea id="Description" class="form-control" @bind-Value="Model!.Description" />
                    </div>
                </div>

                <div class="form-group row mb-3">
                    <label for="inputPoiUid" class="col-sm-2 col-form-label">POI Riferimento</label>
                    <div class="col-sm-10">
                        <div class="input-group">
                            <InputText id="inputPoiUid" class="form-control" @bind-Value="Model!.PoiUid" placeholder="UID del POI di riferimento" />
                            <Button Color="ButtonColor.Secondary"
                                    @onclick="ShowPoiModal"
                                    Disabled="@(string.IsNullOrEmpty(_takMissionName))">
                                <Icon Name="IconName.Search" />
                            </Button>
                        </div>
                        @if (!string.IsNullOrEmpty(Model!.PoiName))
                        {
                            <div class="mt-1 text-info">
                                <Icon Name="IconName.GeoAltFill" /> <strong>@Model.PoiName</strong>
                            </div>
                        }
                        @if (string.IsNullOrEmpty(_takMissionName))
                        {
                            <small class="form-text text-muted">La ricerca è disponibile solo per task associati a una missione TAK</small>
                        }
                        else
                        {
                            <small class="form-text text-muted">Cerca il POI dalla missione <strong>@_takMissionName</strong></small>
                        }
                    </div>
                </div>
            </div>
        </EditForm>
    </BodyTemplate>
    <FooterTemplate>
        <Button Color="ButtonColor.Primary" @onclick="OnSubmit">Salva</Button>
        <Button Color="ButtonColor.Secondary" @onclick="HideAsync">Chiudi</Button>
    </FooterTemplate>
</Modal>

<ModalSelectPoi @ref="_poiModal"
                MissionTakName="@_takMissionName"
                OnPoiSelected="OnPoiSelected" />
