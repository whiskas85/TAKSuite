@typeparam TValue
@using BlazorColorPicker
@using BlazorReflection.Data
@using Microsoft.AspNetCore.Authorization
@using System.Linq.Expressions
@using TAKSuite.Components.Pages.Components
@using TAKSuite.Data.Models
@using TAKSuite.Data.Services
@using TAKSuite.Helper
@using TAKSuite.TAK.Helper

<style>
    .color-rounded-rectangle {
    width: 100%;
    height: 30px;
    border-radius: 5px;
    display: inline-block;
    border: 1px solid #ccc;
    }

    .color-button {
    width: 38px;
    height: 38px;
    border: none;
    margin: 5px;
    border-radius: 4px;
    cursor: pointer;
    border: 2px solid #ccc;
    }

    .color-button-active {
    border-color:dodgerblue;
    border-width:4px;
    }

    .custom-button {
    display: block;
    width: 100%;
    margin-top: 10px;
    padding: 5px;
    border: none;
    cursor: pointer;
    text-align: center;
    }

</style>


