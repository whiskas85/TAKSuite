@page "/missiontak/{MissionTakId:guid}/waypoints"
@attribute [Authorize]
@using Microsoft.AspNetCore.Authorization
@using TAKSuite.Data.Models
@using TAKSuite.Data.ModelsTak
@using TAKSuite.Data.Services
@using TAKSuite.Data.ServicesTak
@using TAKSuite.TAK.CoT
@using TAKSuite.TAK.Helper
@using TAKSuite.Helper
@inject MissionSuiteEntityServices MissionSuiteService
@inject WaypointService WaypointService
@inject AttachmentService AttachmentService
@inject CoTManager CoTManager
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject ToastService ToastService

<PageTitle>Waypoints — @(_mission?.Name ?? "Missione")</PageTitle>

@if (_mission == null)
{
    <p>Caricamento...</p>
}
else
{
    <ModalAddPoi @ref="_addPoiModal"
                 MissionTakUid="@_mission.TakMissionUid"
                 OnPoiCreated="OnPoiCreated" />
    <ConfirmDialog @ref="_confirmDialog" />

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-0">Waypoints</h2>
            <p class="text-muted mb-0">@_mission.Name</p>
        </div>
        <div class="d-flex gap-2">
            <Button Color="ButtonColor.Primary"
                    @onclick="async () => await _addPoiModal.ShowAsync()">
                <Icon Name="IconName.GeoFill" /> Aggiungi POI
            </Button>
            <Button Color="ButtonColor.Secondary" Outline="true"
                    @onclick='() => Navigation.NavigateTo($"/missiontak/{MissionTakId}")'>
                <Icon Name="IconName.ArrowLeft" /> Dettagli missione
            </Button>
        </div>
    </div>

    @if (string.IsNullOrEmpty(_mission.TakMissionUid))
    {
        <div class="alert alert-warning">
            Nessuna missione TAK collegata. Collega un TAK Mission UID dalla pagina dei dettagli.
        </div>
    }
    else
    {
        <Grid @ref="_grid"
              TItem="Waypoint"
              Class="table table-hover"
              HeaderRowCssClass="bg-success text-white border-bottom-0 h5"
              DataProvider="WaypointDataProvider"
              AllowFiltering="false"
              AllowPaging="false"
              AllowSorting="true"
              RowClass="GetRowClass"
              Responsive="true">
            <GridColumns>
                <GridColumn TItem="Waypoint" HeaderText="" TextAlignment="Alignment.Center">
                    @if (context.Color.HasValue)
                    {
                        <button type="button"
                                title="Cambia colore"
                                style="width:18px;height:18px;border-radius:50%;background-color:@ColorConverterHelper.ArgbToHex(context.Color.Value);border:1px solid #888;cursor:pointer;padding:0;display:block;margin:auto;"
                                @onclick="() => OpenColorPicker(context.Uid, context.Color)">
                        </button>
                    }
                </GridColumn>
                <GridColumn TItem="Waypoint" HeaderText="Callsign" SortKeySelector="x => x.Callsign">
                    @context.Callsign
                </GridColumn>
                <GridColumn TItem="Waypoint" HeaderText="Ultima modifica" SortKeySelector="x => x.LastUpdateTime">
                    @context.LastUpdateTime.ToString("dd/MM HH:mm")
                </GridColumn>
                <GridColumn TItem="Waypoint" HeaderText="Lat">
                    @context.Lat
                </GridColumn>
                <GridColumn TItem="Waypoint" HeaderText="Lon">
                    @context.Lon
                </GridColumn>
                <GridColumn TItem="Waypoint" HeaderText="">
                    @if (context.Color != ATAKHelper.COLOR_WAYPOINT_COMPLETED)
                    {
                        <Button Size="ButtonSize.Small" Color="ButtonColor.Success"
                                @onclick="async () => await CompleteWaypoint(context)">
                            <Icon Name="IconName.CheckLg" />
                        </Button>
                    }
                    <Button Size="ButtonSize.Small" Color="ButtonColor.Secondary" Position="Position.Relative"
                            @onclick="async () => await OpenAttachments(context)">
                        <Icon Name="IconName.Paperclip" />
                        @if (context.AttachmentUidList.Count > 0)
                        {
                            <Badge Color="BadgeColor.Danger"
                                   Position="Position.Absolute"
                                   Placement="BadgePlacement.TopRight"
                                   IndicatorType="BadgeIndicatorType.RoundedPill">
                                @context.AttachmentUidList.Count
                            </Badge>
                        }
                    </Button>
                    <Button Size="ButtonSize.Small" Color="ButtonColor.Primary"
                            @onclick="async () => await OpenMaps(context.Lat, context.Lon)">
                        <Icon Name="IconName.GeoAltFill" />
                    </Button>
                    <Button Size="ButtonSize.Small" Color="ButtonColor.Danger"
                            @onclick="async () => await RemoveWaypoint(context)">
                        <Icon Name="IconName.Trash3Fill" />
                    </Button>
                </GridColumn>
            </GridColumns>
        </Grid>
    }

    <!-- Modal: modifica colore waypoint -->
    <Modal @ref="_colorModal" Title="Cambia colore">
        <BodyTemplate>
            <p class="text-muted small mb-2">Colori predefiniti ATAK</p>
            <div class="d-flex flex-wrap gap-2 mb-3">
                @foreach (var pc in ATAKHelper.ATAKPredefinedColors)
                {
                    var isSelected = !_cpIsCustom && _cpArgb == pc.Argb;
                    <button type="button"
                            title="@pc.Name"
                            style="width:30px;height:30px;border-radius:50%;background-color:@pc.ToHex();border:@(isSelected ? "3px solid #000" : "1px solid #888");cursor:pointer;"
                            @onclick="() => CpSelectPredefined(pc.Argb)">
                    </button>
                }
            </div>
            <div class="d-flex align-items-center gap-2">
                <label class="form-label mb-0">Colore custom</label>
                <input type="color"
                       class="form-control form-control-color"
                       value="@_cpHex"
                       @oninput="CpOnCustomInput"
                       style="width:50px;height:34px;padding:2px;" />
                @if (_cpIsCustom)
                {
                    <span class="badge bg-secondary">@_cpHex</span>
                }
            </div>
        </BodyTemplate>
        <FooterTemplate>
            <Button Color="ButtonColor.Success" @onclick="SaveColor"
                    Loading="_cpSaving" LoadingText="Salvataggio...">
                <Icon Name="IconName.Save" /> Applica colore
            </Button>
            <Button Color="ButtonColor.Secondary" @onclick="async () => await _colorModal.HideAsync()">Annulla</Button>
        </FooterTemplate>
    </Modal>

    <Modal @ref="_attachmentModal" Title="Allegati waypoint" Size="ModalSize.Large">
        <BodyTemplate>
            <div class="mb-3 d-flex gap-2 align-items-center">
                <InputFile OnChange="OnAttachFileSelected" class="form-control form-control-sm" />
                <Button Color="ButtonColor.Primary" Size="ButtonSize.Small"
                        @onclick="UploadAttachmentAsync"
                        Loading="_uploading" LoadingText="Caricamento..."
                        Disabled="@(_uploadFile == null || _uploading)">
                    <Icon Name="IconName.CloudUploadFill" /> Allega
                </Button>
            </div>
            <Grid @ref="_attachmentGrid"
                  TItem="AtakAttachment"
                  Class="table table-hover"
                  HeaderRowCssClass="bg-success text-white border-bottom-0"
                  DataProvider="AttachmentDataProvider"
                  AllowFiltering="false"
                  AllowPaging="false"
                  AllowSorting="true"
                  Responsive="true">
                <GridColumns>
                    <GridColumn TItem="AtakAttachment" HeaderText="Nome" SortKeySelector="x => x.Name">
                        @context.Name
                    </GridColumn>
                    <GridColumn TItem="AtakAttachment" HeaderText="Tipo" SortKeySelector="x => x.MediaType">
                        @context.MediaType
                    </GridColumn>
                    <GridColumn TItem="AtakAttachment" HeaderText="">
                        <Button Size="ButtonSize.Small" @onclick="() => ViewAttachment(context)">
                            @if (context.MediaType?.Contains("jpeg") == true)
                            {
                                <Icon Name="IconName.FileEarmarkImage" Color="IconColor.Primary" />
                            }
                            else if (context.MediaType?.Contains("pdf") == true)
                            {
                                <Icon Name="IconName.FileEarmarkPdfFill" Color="IconColor.Primary" />
                            }
                            else
                            {
                                <Icon Name="IconName.FileEarmarkArrowDownFill" Color="IconColor.Primary" />
                            }
                        </Button>
                        <Button Size="ButtonSize.Small" Color="ButtonColor.Danger"
                                @onclick="async () => await DeleteAttachmentAsync(context)">
                            <Icon Name="IconName.Trash3Fill" />
                        </Button>
                    </GridColumn>
                </GridColumns>
            </Grid>
        </BodyTemplate>
        <FooterTemplate>
            <Button Color="ButtonColor.Secondary" @onclick="() => _attachmentModal.HideAsync()">Chiudi</Button>
        </FooterTemplate>
    </Modal>
}

@code {
    [Parameter] public Guid MissionTakId { get; set; }

    private MissionSuite? _mission;
    private Grid<Waypoint> _grid = default!;
    private Grid<AtakAttachment> _attachmentGrid = default!;
    private Modal _attachmentModal = default!;
    private Modal _colorModal = default!;
    private ModalAddPoi _addPoiModal = default!;
    private ConfirmDialog _confirmDialog = default!;
    private string? _selectedWaypointUid;
    private IBrowserFile? _uploadFile;
    private bool _uploading;

    // Color picker state
    private string? _cpUid;
    private int _cpArgb = -1;
    private bool _cpIsCustom;
    private string _cpHex = "#ffffff";
    private bool _cpSaving;

    private Guid _loadedMissionId = Guid.Empty;

    protected override async Task OnParametersSetAsync()
    {
        if (MissionTakId == _loadedMissionId) return;
        _loadedMissionId = MissionTakId;
        _mission = null;
        _mission = await MissionSuiteService.GetAsync(MissionTakId);
        if (_grid is not null)
            await _grid.RefreshDataAsync();
    }

    private async Task<GridDataProviderResult<Waypoint>> WaypointDataProvider(GridDataProviderRequest<Waypoint> request)
    {
        var missionUid = _mission?.TakMissionUid ?? string.Empty;
        var list = string.IsNullOrEmpty(missionUid)
            ? new List<Waypoint>()
            : (await WaypointService.GetAllWaypointsAsync(missionUid))
                .OrderBy(w => w.Color ?? 0)
                .ThenBy(w => w.Callsign)
                .ToList();
        return request.ApplyTo(list);
    }

    private string GetRowClass(Waypoint wpt)
        => wpt.Color == ATAKHelper.COLOR_WAYPOINT_COMPLETED ? "table-success" : string.Empty;

    private async Task OnPoiCreated(ModalAddPoi.PoiResult result)
    {
        await _grid.RefreshDataAsync();
    }

    private async Task RemoveWaypoint(Waypoint item)
    {
        var confirmed = await _confirmDialog.ShowAsync(
            title: "Rimuovi waypoint",
            message1: $"Rimuovere \"{item.Callsign}\" dalla missione TAK?",
            confirmDialogOptions: new ConfirmDialogOptions
            {
                YesButtonText = "Rimuovi",
                YesButtonColor = ButtonColor.Danger,
                NoButtonText = "Annulla",
                NoButtonColor = ButtonColor.Secondary
            });

        if (!confirmed) return;

        var ok = await CoTManager.DeleteMissionUidAsync(_mission!.TakMissionUid!, item.Uid);
        if (ok)
        {
            ToastService.Notify(new(ToastType.Success, "Waypoint", $"\"{item.Callsign}\" rimosso dalla missione."));
            await _grid.RefreshDataAsync();
        }
        else
        {
            ToastService.Notify(new(ToastType.Danger, "Errore", $"Impossibile rimuovere \"{item.Callsign}\"."));
        }
    }

    private async Task CompleteWaypoint(Waypoint item)
    {
        await CoTManager.ChangeCotColor(_mission?.TakMissionUid ?? string.Empty, item.Uid, ATAKHelper.COLOR_WAYPOINT_COMPLETED);
        await _grid.RefreshDataAsync();
    }

    private async Task OpenMaps(double? lat, double? lon)
    {
        if (lat == null || lon == null) return;
        var url = $"https://www.google.com/maps?q={lat.ToString()!.Replace(",", ".")},{lon.ToString()!.Replace(",", ".")}";
        await JS.InvokeVoidAsync("open", url, "_blank");
    }

    private async Task OpenAttachments(Waypoint item)
    {
        _selectedWaypointUid = item.Uid;
        _uploadFile = null;
        await _attachmentModal.ShowAsync();
    }

    private void OnAttachFileSelected(InputFileChangeEventArgs e) => _uploadFile = e.File;

    private async Task UploadAttachmentAsync()
    {
        if (_uploadFile == null || string.IsNullOrEmpty(_selectedWaypointUid) || string.IsNullOrEmpty(_mission?.TakMissionUid)) return;
        _uploading = true;
        try
        {
            using var ms = new System.IO.MemoryStream();
            await _uploadFile.OpenReadStream(maxAllowedSize: 20 * 1024 * 1024).CopyToAsync(ms);
            var ok = await AttachmentService.UploadAndAttachAsync(
                _mission.TakMissionUid, _selectedWaypointUid,
                ms.ToArray(), _uploadFile.Name,
                string.IsNullOrEmpty(_uploadFile.ContentType) ? "application/octet-stream" : _uploadFile.ContentType);
            if (ok)
            {
                ToastService.Notify(new(ToastType.Success, "Allegato", "File allegato con successo."));
                _uploadFile = null;
                await _attachmentGrid.RefreshDataAsync();
            }
            else
            {
                ToastService.Notify(new(ToastType.Danger, "Errore", "Impossibile allegare il file."));
            }
        }
        finally { _uploading = false; }
    }

    private async Task DeleteAttachmentAsync(AtakAttachment attach)
    {
        var confirmed = await _confirmDialog.ShowAsync(
            title: "Rimuovi allegato",
            message1: $"Rimuovere \"{attach.Name}\"?",
            confirmDialogOptions: new ConfirmDialogOptions
            {
                YesButtonText = "Rimuovi",
                YesButtonColor = ButtonColor.Danger,
                NoButtonText = "Annulla",
                NoButtonColor = ButtonColor.Secondary
            });
        if (!confirmed) return;
        var ok = await AttachmentService.DeleteAsync(_mission!.TakMissionUid!, attach);
        if (ok)
        {
            ToastService.Notify(new(ToastType.Success, "Allegato", "Allegato rimosso."));
            await _attachmentGrid.RefreshDataAsync();
        }
        else
        {
            ToastService.Notify(new(ToastType.Danger, "Errore", "Impossibile rimuovere l'allegato."));
        }
    }

    private async Task<GridDataProviderResult<AtakAttachment>> AttachmentDataProvider(GridDataProviderRequest<AtakAttachment> request)
    {
        var list = string.IsNullOrEmpty(_selectedWaypointUid)
            ? new List<AtakAttachment>()
            : await AttachmentService.GetAllAsync(_selectedWaypointUid);
        return request.ApplyTo(list);
    }

    private async Task ViewAttachment(AtakAttachment attach)
    {
        if (attach.FileBytes == null) return;
        var base64 = Convert.ToBase64String(attach.FileBytes);
        var mediaType = attach.MediaType ?? "application/octet-stream";
        await JS.InvokeVoidAsync("viewFile", base64, mediaType);
    }

    private async Task OpenColorPicker(string uid, int? currentArgb)
    {
        _cpUid = uid;
        _cpArgb = currentArgb ?? -1;
        _cpIsCustom = !ATAKHelper.ATAKPredefinedColors.Any(c => c.Argb == _cpArgb);
        _cpHex = ColorConverterHelper.ArgbToHex(_cpArgb);
        await _colorModal.ShowAsync();
    }

    private void CpSelectPredefined(int argb)
    {
        _cpArgb = argb;
        _cpIsCustom = false;
        _cpHex = ColorConverterHelper.ArgbToHex(argb);
    }

    private void CpOnCustomInput(ChangeEventArgs e)
    {
        _cpHex = e.Value?.ToString() ?? "#ffffff";
        _cpArgb = ColorConverterHelper.HexToArgb(_cpHex);
        _cpIsCustom = true;
    }

    private async Task SaveColor()
    {
        if (string.IsNullOrEmpty(_cpUid) || string.IsNullOrEmpty(_mission?.TakMissionUid)) return;
        _cpSaving = true;
        try
        {
            var ok = await CoTManager.ChangeCotColor(_mission.TakMissionUid, _cpUid, _cpArgb);
            if (ok)
            {
                await _colorModal.HideAsync();
                await _grid.RefreshDataAsync();
                ToastService.Notify(new(ToastType.Success, "Waypoint", "Colore aggiornato."));
            }
            else
            {
                ToastService.Notify(new(ToastType.Danger, "Errore", "Impossibile aggiornare il colore."));
            }
        }
        finally { _cpSaving = false; }
    }
}
