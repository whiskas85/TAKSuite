@using System.ComponentModel.DataAnnotations
@using TAKSuite.Components.Pages.Components
@using TAKSuite.Components.Pages.EventEntityComponents.GenercForm
@using TAKSuite.Data.Models
@using TAKSuite.Data.Services


<GenericForm TModel="EventEntity"
             Model="@modelView"
             IsEditMode="@(Item != null)"
             OnSubmitted="OnSubmitted">
    <FormFields>
        <DateTimeInput Title="Ora inizio:" @bind-Value="modelView.Timestamp" />

        <div class="form-group row mb-3">
            <label class="col-md-2 col-form-label">Name: <span class="text-danger">*</span></label>
            <div class="col-md-10">
                <TextInput @bind-Value="@modelView.Title" Rows="3" Placeholder="Enter title" />
                <ValidationMessage For="@(() => modelView.Title)" />
            </div>
        </div>

        <div class="form-group row mb-3">
            <label class="col-md-2 col-form-label">Description: <span class="text-danger">*</span></label>
            <div class="col-md-10">
                <TextAreaInput @bind-Value="@modelView.Note" Rows="3" Placeholder="Enter note" />
                <ValidationMessage For="@(() => modelView.Note)" />
            </div>
        </div>
    </FormFields>
</GenericForm>

@code {
    [Parameter] public EventEntity? Item { get; set; }
    [Parameter] public EventCallback OnSubmitted { get; set; }

    private EventEntityModel modelView;

    [Inject] public EventEntityService EventEntityService { get; set; }

    protected override void OnInitialized()
    {
        if (Item != null)
            modelView = new(EventEntityService, Item);
        else
            modelView = new(EventEntityService);
    }

}


